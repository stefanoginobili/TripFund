@inherits LayoutComponentBase

<div class="page">
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<style>
    .page {
        display: flex;
        flex-direction: column;
        height: 100vh;
    }
    main {
        flex: 1;
        overflow-y: auto;
    }
    .content {
        padding-top: 1rem;
        padding-bottom: 1rem;
    }
</style>
