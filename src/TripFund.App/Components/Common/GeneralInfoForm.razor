<section class="info-section">
    <h3 class="section-header-vibe">INFORMAZIONI GENERALI</h3>
    
    <div class="form-container-vibe">
    
        <div class="form-group-vibe">
            <label class="form-label-vibe">Nome Viaggio</label>
            <input type="text" class="form-control-vibe" value="@Name" @oninput="OnNameInput" @onblur="TrimName" placeholder="es. Patagonia 2026" />
        </div>

        <div class="form-group-vibe">
            <label class="form-label-vibe">Slug</label>
            <div class="input-wrapper read-only">
                <input type="text" class="form-control-vibe" value="@Slug" readonly />
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lock-icon">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
            </div>
        </div>

        <div class="row-group">
            <NativeDatePicker Label="Data Inizio" @bind-Value="StartDate" Class="flex-1" />
            <NativeDatePicker Label="Data Fine" @bind-Value="EndDate" Class="flex-1" />
        </div>

        @if (!string.IsNullOrEmpty(dateError))
        {
            <div class="text-danger fw-bold small mb-2">@dateError</div>
        }

        <div class="form-group-vibe">
            <label class="form-label-vibe">Descrizione</label>
            <textarea class="form-control-vibe" value="@Description" @oninput="OnDescriptionInput" @onblur="TrimDescription" placeholder="Aggiungi una descrizione..." rows="3"></textarea>
        </div>
    </div>
</section>

<style>

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-wrapper.read-only .form-control-vibe {
        background-color: #E9ECEF;
        color: #6C757D;
        font-style: italic;
        padding-right: 3rem;
    }

    .lock-icon {
        position: absolute;
        right: 1rem;
        color: #ADB5BD;
    }

    .row-group {
        display: flex;
        gap: 1rem;
    }

    .small { font-size: 0.75rem; }
    .mb-2 { margin-bottom: 0.5rem; }
</style>
