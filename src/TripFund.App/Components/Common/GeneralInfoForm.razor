@using TripFund.App.Models
@using TripFund.App.Utilities

<section class="info-section">
    <h3 class="section-header">INFORMAZIONI GENERALI</h3>
    
    <div class="form-group">
        <label>Nome Viaggio</label>
        <div class="input-wrapper">
            <input type="text" value="@Name" @oninput="OnNameInput" placeholder="es. Patagonia 2026" />
        </div>
    </div>

    <div class="form-group">
        <label>Slug</label>
        <div class="input-wrapper read-only">
            <input type="text" value="@Slug" readonly />
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lock-icon">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
        </div>
    </div>

    <div class="row-group">
        <div class="form-group flex-1">
            <label>Data Inizio</label>
            <div class="date-picker-wrapper">
                <span class="date-display">@FormatDate(StartDate)</span>
                <input type="date" value="@StartDate.ToString("yyyy-MM-dd")" @onchange="OnStartDateChange" class="native-date-input" />
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="calendar-icon">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
            </div>
        </div>
        <div class="form-group flex-1">
            <label>Data Fine</label>
            <div class="date-picker-wrapper">
                <span class="date-display">@FormatDate(EndDate)</span>
                <input type="date" value="@EndDate.ToString("yyyy-MM-dd")" @onchange="OnEndDateChange" class="native-date-input" />
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="calendar-icon">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(dateError))
    {
        <div class="date-validation-error">@dateError</div>
    }

    <div class="form-group">
        <label>Descrizione</label>
        <div class="input-wrapper">
            <textarea value="@Description" @oninput="OnDescriptionInput" placeholder="Aggiungi una descrizione..." rows="3"></textarea>
        </div>
    </div>
</section>

@code {
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public EventCallback<string> NameChanged { get; set; }
    
    [Parameter] public string Slug { get; set; } = "";
    [Parameter] public EventCallback<string> SlugChanged { get; set; }

    [Parameter] public DateTime StartDate { get; set; } = DateTime.Today;
    [Parameter] public EventCallback<DateTime> StartDateChanged { get; set; }

    [Parameter] public DateTime EndDate { get; set; } = DateTime.Today.AddDays(7);
    [Parameter] public EventCallback<DateTime> EndDateChanged { get; set; }

    [Parameter] public string Description { get; set; } = "";
    [Parameter] public EventCallback<string> DescriptionChanged { get; set; }

    [Parameter] public bool IsCreate { get; set; } = false;

    private string dateError = "";

    private async Task OnNameInput(ChangeEventArgs e)
    {
        var newName = e.Value?.ToString() ?? "";
        Name = newName;
        await NameChanged.InvokeAsync(newName);

        if (IsCreate)
        {
            var newSlug = SlugUtility.GenerateSlug(newName);
            Slug = newSlug;
            await SlugChanged.InvokeAsync(newSlug);
        }
    }

    private async Task OnStartDateChange(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            dateError = "";
            StartDate = date;
            await StartDateChanged.InvokeAsync(date);

            if (EndDate < StartDate)
            {
                EndDate = StartDate;
                await EndDateChanged.InvokeAsync(EndDate);
            }
        }
    }

    private async Task OnEndDateChange(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            if (date < StartDate)
            {
                dateError = "La data di fine non può essere precedente alla data di inizio.";
                // Reset visual state but keep valid model if possible, 
                // or just force it to StartDate. Let's force it to be safe.
                EndDate = StartDate;
                await EndDateChanged.InvokeAsync(EndDate);
            }
            else
            {
                dateError = "";
                EndDate = date;
                await EndDateChanged.InvokeAsync(date);
            }
        }
    }

    private async Task OnDescriptionInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        Description = val;
        await DescriptionChanged.InvokeAsync(val);
    }

    private string FormatDate(DateTime date)
    {
        return date.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("it-IT"));
    }
}

<style>
    .info-section {
        background-color: #FFFFFF;
        border-radius: 24px;
        padding: 1.5rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    }

    .section-header {
        font-size: 0.9rem;
        font-weight: 700;
        color: #6C757D;
        letter-spacing: 0.05em;
        margin-bottom: 1.5rem;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-group label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: #1A3C2F;
        margin-bottom: 0.5rem;
    }

    .input-wrapper {
        background-color: #F0F2F5;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
    }

    .input-wrapper input, .input-wrapper textarea {
        background: none;
        border: none;
        width: 100%;
        font-size: 1rem;
        color: #1A3C2F;
        outline: none;
        font-family: inherit;
    }

    .input-wrapper.read-only {
        background-color: #E9ECEF;
        color: #6C757D;
    }

    .input-wrapper.read-only input {
        color: #6C757D;
        font-style: italic;
    }

    .lock-icon {
        color: #ADB5BD;
        margin-left: 0.5rem;
    }

    .row-group {
        display: flex;
        gap: 1rem;
    }

    .flex-1 { flex: 1; }

    .date-validation-error {
        color: #DC3545;
        font-size: 0.75rem;
        font-weight: 600;
        margin-top: -0.5rem;
        margin-bottom: 1rem;
    }

    .date-picker-wrapper {
        background-color: #E9ECEF;
        border-radius: 16px;
        padding: 0.85rem 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        cursor: pointer;
    }

    .date-display {
        font-size: 1rem;
        font-weight: 700;
        color: #1A3C2F;
    }

    .calendar-icon {
        color: #8E9AAF;
    }

    .native-date-input {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
    }
</style>
