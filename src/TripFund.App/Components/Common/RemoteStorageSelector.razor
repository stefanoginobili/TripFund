@using TripFund.App.Models
@using TripFund.App.Utilities

@if (IsVisible)
{
    <div class="modal-backdrop-vibe" @onclick="Close">
        <div class="modal-sheet-vibe" @onclick:stopPropagation="true">
            <header class="modal-header-vibe">
                <h2 class="modal-title-vibe">@GetTitle()</h2>
                <button class="close-btn-vibe" @onclick="Close">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </header>

            <div class="modal-body-vibe">
                @if (selectedProvider == null)
                {
                    <div class="provider-list">
                        @if (!IsJoining)
                        {
                            <div class="provider-item" @onclick='() => SelectProvider("local")'>
                                <div class="provider-logo">
                                    <img src="images/smartphone.svg" width="32" height="32" alt="Memoria Dispositivo" />
                                </div>
                                <div class="provider-info">
                                    <div class="provider-name">Memoria Dispositivo</div>
                                </div>
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="9 18 15 12 9 6"></polyline>
                                </svg>
                            </div>
                        }

                        <div class="provider-item" @onclick='() => SelectProvider("onedrive")'>
                            <div class="provider-logo">
                                <img src="images/onedrive.svg" width="32" height="32" alt="Microsoft OneDrive" />
                            </div>
                            <div class="provider-info">
                                <div class="provider-name">Microsoft OneDrive</div>
                            </div>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="9 18 15 12 9 6"></polyline>
                            </svg>
                        </div>
                    </div>
                }
                else if (selectedProvider == "onedrive")
                {
                    <div class="provider-form">
                        <div class="help-section-vibe">
                            <h3 class="help-title-vibe">Accesso a Microsoft OneDrive:</h3>
                            <div class="help-item-vibe">
                                <p>Puoi scegliere qualsiasi cartella nel tuo account Microsoft OneDrive per sincronizzare il tuo viaggio.</p>
                            </div>
                        </div>
                        <div class="mb-3">
                            @if (string.IsNullOrEmpty(folderName))
                            {
                                @if (isPickerLoading)
                                {
                                    <div class="picker-loading-state">
                                        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                        <span>Connessione a OneDrive...</span>
                                        <button class="btn-link-vibe ms-3" @onclick="CancelLoading">Annulla</button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn-picker-vibe" @onclick="OpenPicker">
                                        <img src="images/onedrive.svg" width="20" height="20" alt="" class="me-2" />
                                        <span>Sfoglia Cartelle</span>
                                    </button>
                                }
                            }
                            else
                            {
                                <div class="selected-folder-info od-selected">
                                    <img src="images/onedrive.svg" width="20" height="20" alt="" />
                                    <span class="folder-name-vibe">@folderName</span>
                                    <button class="btn-link-vibe ms-auto" @onclick="OpenPicker">Cambia</button>
                                </div>
                            }
                        </div>

                        <div class="mt-4">
                            <button class="btn-primary-vibe w-100" @onclick="Complete" disabled="@(string.IsNullOrWhiteSpace(folderId))">Conferma</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<OneDrivePickerModal @bind-IsVisible="isOneDrivePickerVisible" 
                     AccessToken="@oneDriveToken" 
                     OnFolderSelected="OnOneDriveFolderSelected" />

<style>
    .od-selected {
        border-color: #0078D4 !important;
        background-color: #F3F9FF !important;
    }
    .btn-picker-vibe {
        width: 100%;
        padding: 0.8rem 1rem;
        border-radius: 12px;
        border: 2px dashed #E0E0E0;
        background-color: #FFFFFF;
        color: #1A3C2F;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        cursor: pointer;
    }

    .btn-picker-vibe:hover:not(:disabled) {
        border-color: #20563C;
        background-color: #F8FBF9;
    }

    .btn-picker-vibe:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .selected-folder-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.8rem 1rem;
        background-color: #F8FBF9;
        border-radius: 12px;
        border: 1px solid #20563C;
    }

    .folder-name-vibe {
        font-weight: 600;
        color: #1A3C2F;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .btn-link-vibe {
        background: none;
        border: none;
        color: #20563C;
        font-weight: 700;
        font-size: 0.85rem;
        text-decoration: underline;
        padding: 0;
        cursor: pointer;
    }

    .picker-loading-state {
        display: flex;
        align-items: center;
        padding: 0.8rem 1rem;
        background-color: #F8FBF9;
        border-radius: 12px;
        border: 1px solid #E0E0E0;
        font-size: 0.9rem;
        color: #6C757D;
    }
    .help-section-vibe {
        background-color: #E9F2EE;
        padding: 1rem;
        border-radius: 16px;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(32, 86, 60, 0.1);
    }

    .help-title-vibe {
        font-size: 0.95rem;
        font-weight: 700;
        color: #20563C;
        margin-bottom: 0.75rem;
    }

    .help-item-vibe {
        font-size: 0.85rem;
        color: #1A3C2F;
        line-height: 1.4;
    }

    .help-item-vibe strong {
        display: block;
        margin-top: 0.5rem;
    }

    .help-item-vibe p {
        margin: 0.2rem 0 0.5rem 0;
    }

    .provider-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .provider-item {
        background-color: #FFFFFF;
        padding: 1rem;
        border-radius: 16px;
        display: flex;
        align-items: center;
        gap: 1rem;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
        border: 1px solid #F0F0F0;
        transition: transform 0.1s;
    }

    .provider-logo {
        width: 48px;
        height: 48px;
        background-color: #F8FBF9;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .provider-info {
        flex: 1;
    }

    .provider-name {
        font-weight: 700;
        color: #1A3C2F;
        font-size: 1.1rem;
    }

    .provider-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-label-vibe {
        display: block;
        font-weight: 600;
        color: #1A3C2F;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .form-control-vibe {
        width: 100%;
        padding: 0.8rem 1rem;
        border-radius: 12px;
        border: 1px solid #E0E0E0;
        background-color: #FFFFFF;
        font-size: 1rem;
    }

    .form-control-vibe:focus {
        outline: none;
        border-color: #20563C;
        box-shadow: 0 0 0 3px rgba(32, 86, 60, 0.1);
    }

    .mt-4 { margin-top: 1.5rem; }
    .mb-3 { margin-bottom: 1rem; }
    .d-flex { display: flex; }
    .gap-2 { gap: 0.5rem; }
    .flex-1 { flex: 1; }
    .flex-2 { flex: 2; }
</style>
