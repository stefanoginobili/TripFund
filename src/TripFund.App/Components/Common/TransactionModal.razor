@using TripFund.App.Models
@using TripFund.App.Utilities
@using System.IO

@if (IsVisible && Transaction != null && Config != null)
{
    <div class="modal-backdrop-vibe" @onclick="Close">
        <div class="modal-sheet-vibe" @onclick:stopPropagation="true">
            <header class="modal-header-vibe">
                <h2 class="modal-title-vibe">@(string.IsNullOrWhiteSpace(Transaction.Description) ? (Transaction.Type == "expense" ? "Spesa" : "Versamento") : Transaction.Description)</h2>
                <button class="close-btn-vibe" @onclick="Close">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </header>

            <div class="modal-body-vibe">
                <div class="transaction-summary-card">
                    <div class="transaction-icon round @(Transaction.Type == "expense" ? "expense-icon" : "contrib-icon")">
                        @if (Transaction.Type == "expense")
                        {
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"></polyline><polyline points="17 18 23 18 23 12"></polyline></svg>
                        }
                        else
                        {
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                        }
                    </div>
                    <h2 class="amount-title @(Transaction.Type == "expense" ? "text-danger" : "text-success")">
                        @FormatAmountWithCode(Transaction.Amount, Transaction.Currency)
                    </h2>
                    <p class="transaction-meta">@GetDisplayDate(Transaction)</p>
                    <p class="transaction-meta tz-name">orario di @GetTimeZoneDisplayName(Transaction)</p>
                    <p class="transaction-meta author-line">Registrato da @Transaction.Author</p>
                </div>

                <div class="info-section">
                    <h3 class="section-header-vibe">Partecipanti</h3>
                    <div class="split-list">
                        @foreach (var split in Transaction.Split)
                        {
                            var isMissing = !Config.Members.ContainsKey(split.Key);
                            var memberName = !isMissing ? Config.Members[split.Key].Name : split.Key;
                            var memberAvatar = !isMissing ? Config.Members[split.Key].Avatar : "❓";

                            <div class="split-row @(isMissing ? "missing-member" : "")">
                                <div class="member-avatar">@memberAvatar</div>
                                <div class="member-name">@memberName</div>
                                <div class="split-amount">@FormatCurrency(split.Value.Amount, Transaction.Currency)</div>
                            </div>
                        }
                    </div>
                </div>

                @if (previews.Any())
                {
                    <div class="info-section">
                        <h3 class="section-header-vibe">Allegati</h3>
                        <div class="attachments-grid">
                            @foreach (var preview in previews)
                            {
                                <div class="attachment-preview-wrapper" @onclick="() => OpenAttachment(preview.FileName)">
                                    <div class="attachment-square">
                                        @if (preview.IsImage && !string.IsNullOrEmpty(preview.PreviewUrl))
                                        {
                                            <img src="@preview.PreviewUrl" alt="@preview.FileName" />
                                        }
                                        else
                                        {
                                            <div class="file-icon-placeholder">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
                                                    <polyline points="13 2 13 9 20 9"></polyline>
                                                </svg>
                                                <span class="file-ext">@(Path.GetExtension(preview.FileName).TrimStart('.').ToUpper())</span>
                                                <span class="file-original-name">@preview.OriginalName</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="attachment-name">@preview.DisplayTimestamp</div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (Transaction.Location != null)
                {
                    <div class="info-section">
                        <h3 class="section-header-vibe">Luogo</h3>
                        <div class="info-card clickable" @onclick="OpenMap">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 text-muted">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                <circle cx="12" cy="10" r="3"></circle>
                            </svg>
                            <div class="location-text">
                                <div class="location-name">@(string.IsNullOrWhiteSpace(Transaction.Location.Name) ? "Posizione" : Transaction.Location.Name)</div>
                                <div class="location-coords">@Transaction.Location.Latitude.ToString("F6"), @Transaction.Location.Longitude.ToString("F6")</div>
                            </div>
                        </div>
                    </div>
                }

                @if (!isReadonly)
                {
                    <div class="edit-action-wrapper">
                        <button class="edit-action-link" @onclick="Edit" disabled="@(!canEdit)">
                            Modifica Transazione
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    .modal-backdrop-vibe {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: flex-end;
        justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(4px);
    }

    .modal-sheet-vibe {
        width: 100%;
        max-width: 600px;
        background-color: #F8FBF9;
        border-top-left-radius: 32px;
        border-top-right-radius: 32px;
        display: flex;
        flex-direction: column;
        max-height: 90vh;
        animation: slide-up 0.3s ease-out;
        box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.1);
    }

    @@keyframes slide-up {
        from { transform: translateY(100%); }
        to { transform: translateY(0); }
    }

    .modal-header-vibe {
        padding: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }

    .modal-title-vibe {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1A3C2F;
        margin: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        padding-right: 1rem;
    }

    .close-btn-vibe {
        background: none;
        border: none;
        color: #6C757D;
        cursor: pointer;
        padding: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: background-color 0.2s;
    }

    .close-btn-vibe:hover {
        background-color: rgba(0,0,0,0.05);
    }

    .modal-body-vibe {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem 1.5rem 3rem;
    }

    .edit-action-wrapper {
        margin-top: 3rem;
        display: flex;
        justify-content: center;
    }

    .edit-action-link {
        background: none;
        border: none;
        color: #20563C;
        font-weight: 700;
        font-size: 1rem;
        display: flex;
        align-items: center;
        cursor: pointer;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        transition: background-color 0.2s;
        text-decoration: underline;
    }

    .edit-action-link:active {
        background-color: rgba(32, 86, 60, 0.05);
    }

    .edit-action-link:disabled {
        color: #6C757D;
        cursor: not-allowed;
        text-decoration: none;
    }

    /* Reuse styles from detail page */
    .transaction-summary-card {
        background-color: #FFFFFF;
        border-radius: 24px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        margin-bottom: 2rem;
    }

    .amount-title {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .transaction-meta {
        font-size: 0.85rem;
        color: #6C757D;
        margin: 0;
    }

    .tz-name {
        font-size: 0.75rem;
        opacity: 0.8;
    }

    .author-line {
        margin-top: 0.5rem !important;
    }

    .split-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .split-row {
        background-color: #FFFFFF;
        padding: 0.85rem;
        border-radius: 16px;
        display: flex;
        align-items: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    }

    .split-row.missing-member {
        filter: grayscale(100%);
        opacity: 0.7;
    }

    .member-avatar {
        font-size: 1.25rem;
        margin-right: 0.75rem;
        width: 36px;
        height: 36px;
        background-color: #F8FBF9;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .member-name {
        flex: 1;
        font-weight: 600;
        color: #1A3C2F;
        font-size: 0.95rem;
    }

    .split-amount {
        font-weight: 700;
        color: #1A3C2F;
        font-size: 0.95rem;
    }

    .info-card {
        background-color: #FFFFFF;
        padding: 1rem;
        border-radius: 16px;
        display: flex;
        align-items: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
        font-weight: 500;
        color: #1A3C2F;
    }

    .info-card.clickable {
        cursor: pointer;
    }

    .location-text {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .location-name {
        font-weight: 600;
        color: #1A3C2F;
    }

    .location-coords {
        font-size: 0.75rem;
        color: #6C757D;
    }

    .attachments-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    .attachment-preview-wrapper {
        display: flex;
        flex-direction: column;
        gap: 6px;
        cursor: pointer;
    }

    .attachment-square {
        aspect-ratio: 1 / 1;
        width: 100%;
        background-color: #C0C0C0;
        border: 1px solid #E0E0E0;
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    }

    .attachment-square img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .file-icon-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        color: #6C757D;
        width: 100%;
        overflow: hidden;
    }

    .file-ext {
        font-size: 0.6rem;
        font-weight: 800;
        margin-top: 2px;
    }

    .file-original-name {
        font-size: 0.75rem;
        color: #6C757D;
        text-align: center;
        margin-top: 4px;
        padding: 0 4px;
        width: 100%;
        overflow: hidden;
        white-space: normal;
        word-break: break-all;
        line-height: 1.1;
        max-height: 2.2em;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .attachment-name {
        font-size: 0.7rem;
        color: #6C757D;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        text-align: center;
    }

    .me-2 { margin-right: 0.5rem; }
    .text-muted { color: #6C757D; }
    .text-danger { color: #DC3545; }
    .text-success { color: #20563C; }
</style>
