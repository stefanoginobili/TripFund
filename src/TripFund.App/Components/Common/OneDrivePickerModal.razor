@using TripFund.App.Services
@inject IOneDrivePickerService OneDriveService
@inject IAlertService AlertService

@if (IsVisible)
{
    <div class="modal-backdrop-vibe modal-z-picker" @onclick="Close">
        <div class="modal-sheet-vibe" @onclick:stopPropagation="true">
            <header class="modal-header-vibe">
                <div class="header-left">
                    @if (navigationStack.Count > 0)
                    {
                        <button class="back-btn-vibe" @onclick="GoBack">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="15 18 9 12 15 6"></polyline>
                            </svg>
                        </button>
                    }
                    <h2 class="modal-title-vibe">@Title</h2>
                </div>
                <button class="close-btn-vibe" @onclick="Close">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </header>

            <div class="modal-body-vibe">
                <div class="view-toggle-vibe">
                    <button class="toggle-btn @(viewMode == "personal" ? "active" : "")" @onclick='() => ChangeView("personal")'>
                        I miei file
                    </button>
                    <button class="toggle-btn @(viewMode == "shared" ? "active" : "")" @onclick='() => ChangeView("shared")'>
                        Condivisi con me
                    </button>
                </div>

                <div class="breadcrumb-container-vibe">
                    <div class="breadcrumb-vibe">
                        <span class="breadcrumb-item @(navigationStack.Count == 0 ? "active" : "")" @onclick="GoToRoot">
                            @(viewMode == "personal" ? "I miei file" : "Condivisi con me")
                        </span>
                        @foreach (var step in navigationStack)
                        {
                            <span class="breadcrumb-separator">/</span>
                            <span class="breadcrumb-item @(step == navigationStack.Last() ? "active" : "")" @onclick="() => GoToStep(step)">@step.Name</span>
                        }
                    </div>
                    @if (viewMode == "personal" && !isLoading)
                    {
                        <button class="btn-new-folder-vibe" @onclick="ToggleCreateFolder" title="Nuova Cartella">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                                <line x1="12" y1="11" x2="12" y2="17"></line>
                                <line x1="9" y1="14" x2="15" y2="14"></line>
                            </svg>
                        </button>
                    }
                </div>

                @if (isCreatingFolder)
                {
                    <div class="create-folder-form-vibe">
                        <label class="form-label-vibe">NOME CARTELLA</label>
                        <input type="text" class="form-control-vibe" @bind="newFolderName" @bind:event="oninput" autofocus />
                        <div class="form-actions-vibe">
                            <button class="btn-cancel-vibe" @onclick="ToggleCreateFolder" disabled="@isFolderCreating">Annulla</button>
                            <button class="btn-confirm-vibe" @onclick="CreateFolder" disabled="@(isFolderCreating || string.IsNullOrWhiteSpace(newFolderName))">
                                @if (isFolderCreating) { <div class="spinner-border spinner-border-sm me-1" role="status"></div> }
                                Crea
                            </button>
                        </div>
                    </div>
                }

                @if (isLoading)
                {
                    <div class="loading-state">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p>Caricamento cartelle...</p>
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert-error-vibe mb-3">
                            <div class="error-content">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="8" x2="12" y2="12"></line>
                                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                                </svg>
                                <span>@errorMessage</span>
                            </div>
                            <button class="btn-close-error" @onclick="() => errorMessage = null">×</button>
                        </div>
                    }

                    <div class="item-list">
                        @foreach (var item in items)
                        {
                            bool isItemRemote = item.IsRemote;
                            <div class="item-row @(isItemRemote ? "disabled" : "") @(selectedId == item.Id ? "selected" : "")" @onclick="() => { if (!isItemRemote) SelectItem(item); }">
                                <div class="item-icon">
                                    @if (isItemRemote)
                                    {
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6C757D" stroke-width="2">
                                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                                            <circle cx="18" cy="18" r="3"></circle>
                                            <path d="M18 15v3"></path>
                                            <path d="M18 21v-3"></path>
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0078D4" stroke-width="2">
                                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                                        </svg>
                                    }
                                </div>
                                <div class="item-name">@item.Name</div>
                                <div class="item-actions">
                                    <button class="btn-open" disabled="@isItemRemote" @onclick:stopPropagation="true" @onclick="() => OpenFolder(item)">
                                        Apri
                                    </button>
                                </div>
                            </div>
                        }

                        @if (items.Count == 0)
                        {
                            <div class="empty-state">
                                <p>Nessuna cartella trovata.</p>
                            </div>
                        }
                    </div>
                }
            </div>

            <footer class="modal-footer-vibe">
                <button class="btn-vibe btn-primary-vibe w-100" @onclick="ConfirmSelection" disabled="@(string.IsNullOrEmpty(selectedId))">
                    Seleziona
                </button>
            </footer>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public string AccessToken { get; set; } = string.Empty;
    [Parameter] public string Title { get; set; } = "Seleziona Cartella OneDrive";
    [Parameter] public EventCallback<(string Id, string Name, string? DriveId)> OnFolderSelected { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private List<OneDriveItem> items = new();
    private List<NavigationStep> navigationStack = new();
    private string? selectedId;
    private string? selectedName;
    private string viewMode = "personal"; // personal or shared
    private string? currentDriveId;
    private bool _wasVisible;

    private bool isCreatingFolder = false;
    private string newFolderName = string.Empty;
    private bool isFolderCreating = false;

    private void ResetState()
    {
        items.Clear();
        navigationStack.Clear();
        selectedId = null;
        selectedName = null;
        viewMode = "personal";
        currentDriveId = null;
        errorMessage = null;
        isCreatingFolder = false;
        newFolderName = string.Empty;
    }

    private void ToggleCreateFolder()
    {
        isCreatingFolder = !isCreatingFolder;
        newFolderName = string.Empty;
        errorMessage = null;
    }

    private async Task CreateFolder()
    {
        if (string.IsNullOrWhiteSpace(newFolderName)) return;

        isFolderCreating = true;
        errorMessage = null;
        try
        {
            var parentId = navigationStack.LastOrDefault()?.Id;
            var folder = await OneDriveService.CreateFolderAsync(AccessToken, newFolderName, parentId, currentDriveId);
            
            // Reload folders to see the new one
            await LoadFolders(parentId, currentDriveId);
            
            // Auto-select the new folder
            SelectItem(folder);
            
            isCreatingFolder = false;
            newFolderName = string.Empty;
        }
        catch (Exception ex)
        {
            errorMessage = "Impossibile creare la cartella: " + ex.Message;
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isFolderCreating = false;
        }
    }

    private class NavigationStep
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? DriveId { get; set; }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !_wasVisible)
        {
            ResetState();
            if (!string.IsNullOrEmpty(AccessToken))
            {
                await LoadFolders();
            }
        }
        _wasVisible = IsVisible;
    }

    private async Task ChangeView(string mode)
    {
        if (viewMode == mode) return;
        viewMode = mode;
        navigationStack.Clear();
        selectedId = null;
        selectedName = null;
        currentDriveId = null;
        errorMessage = null;
        await LoadFolders();
    }

    private async Task<bool> LoadFolders(string? parentId = null, string? driveId = null)
    {
        isLoading = true;
        errorMessage = null;
        var previousDriveId = currentDriveId;
        currentDriveId = driveId;
        try
        {
            if (string.IsNullOrEmpty(parentId) && viewMode == "shared")
            {
                items = await OneDriveService.ListSharedFoldersAsync(AccessToken);
            }
            else
            {
                items = await OneDriveService.ListFoldersAsync(AccessToken, parentId, driveId);
            }
            return true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore nel caricamento della cartella: {ex.Message}";
            currentDriveId = previousDriveId;
            Console.WriteLine(ex.Message);
            return false;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OpenFolder(OneDriveItem folder)
    {
        var driveId = folder.ParentReference?.DriveId ?? currentDriveId;
        
        // Try to load the content of the folder FIRST
        var success = await LoadFolders(folder.Id, driveId);
        
        // Only add to navigation stack if loading was successful
        if (success)
        {
            navigationStack.Add(new NavigationStep { Id = folder.Id, Name = folder.Name, DriveId = driveId });
        }
    }

    private async Task GoBack()
    {
        if (navigationStack.Count > 0)
        {
            navigationStack.RemoveAt(navigationStack.Count - 1);
            var lastStep = navigationStack.LastOrDefault();
            await LoadFolders(lastStep?.Id, lastStep?.DriveId);
        }
    }

    private async Task GoToRoot()
    {
        navigationStack.Clear();
        errorMessage = null;
        await LoadFolders();
    }

    private async Task GoToStep(NavigationStep step)
    {
        var index = navigationStack.IndexOf(step);
        if (index >= 0)
        {
            navigationStack = navigationStack.Take(index + 1).ToList();
            await LoadFolders(step.Id, step.DriveId);
        }
    }

    private void SelectItem(OneDriveItem item)
    {
        selectedId = item.Id;
        selectedName = item.Name;
        // For shared items, the driveId is in the item itself
        // For personal items, it's either null or the current personal drive context
        var itemDriveId = item.ParentReference?.DriveId ?? currentDriveId;
        currentDriveId = itemDriveId;
    }

    private async Task ConfirmSelection()
    {
        if (!string.IsNullOrEmpty(selectedId) && !string.IsNullOrEmpty(selectedName))
        {
            await OnFolderSelected.InvokeAsync((selectedId, selectedName, currentDriveId));
            await Close();
        }
    }

    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(false);
    }
}

<style>
