<div class="form-group @Class">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label>@Label</label>
    }
    <div class="native-picker-box" @onclick="HandleClick">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="picker-icon">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        <span class="picker-value">@Value.ToString("HH:mm")</span>
        <input type="time" class="hidden-native-input" value="@Value.ToString("HH:mm")" @onchange="OnInputChanged" readonly="@isAndroid" />
    </div>
</div>

<style>
    /* Reuse styles or define if missing */
    .native-picker-box {
        background-color: #F1F3F5;
        border-radius: 16px;
        padding: 0.85rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        position: relative;
        cursor: pointer;
        min-height: 56px;
    }

    .picker-icon {
        color: #20563C;
    }

    .picker-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1A3C2F;
    }

    .hidden-native-input {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
    }
</style>
