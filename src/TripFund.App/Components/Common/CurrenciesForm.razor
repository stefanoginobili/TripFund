<section class="info-section">
    <h3 class="section-header-vibe">CASSE DEL VIAGGIO</h3>
    <div class="currencies-list">
        @foreach (var curr in Currencies)
        {
            @if (editingCurrencyCode == curr.Key)
            {
                <div id="edit-currency-form" class="currency-edit-container">
                    <div class="new-currency-form">
                        <div class="new-currency-header">
                            <span class="wallet-icon">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"></path>
                                    <path d="M4 6v12c0 1.1.9 2 2 2h14v-4"></path>
                                    <path d="M18 12a2 2 0 0 0-2 2c0 1.1.9 2 2 2h4v-4h-4z"></path>
                                </svg>
                            </span>
                            <span class="new-currency-title">Modifica Cassa</span>
                        </div>
                        
                        <div class="new-currency-grid relative-grid">
                            <div class="new-curr-col">
                                <label>CODICE</label>
                                <input type="text" value="@newCurrCode" readonly class="form-control-vibe readonly-input" />
                            </div>
                            <div class="new-curr-col">
                                <label>SIMBOLO</label>
                                <input type="text" class="form-control-vibe" @bind="newCurrSymbol" @bind:event="oninput" @onblur="TrimSymbol" />
                            </div>
                            <div class="new-curr-col">
                                <label>DECIMALI</label>
                                <input type="text" class="form-control-vibe" inputmode="numeric" value="@newCurrDecimals" @oninput="OnDecimalsChanged" onfocus="appLogic.selectText(this)" />
                            </div>
                        </div>
                        
                        <div class="new-currency-footer">
                            <div class="new-curr-col quota-col">
                                <label>QUOTA</label>
                                <input type="text" class="form-control-vibe" inputmode="decimal" value="@newCurrQuotaString" @oninput="OnQuotaChanged" onfocus="appLogic.selectText(this)" />
                            </div>
                            <div class="action-buttons">
                                <button class="confirm-btn" @onmousedown="AddOrUpdateCurrency" @onclick="AddOrUpdateCurrency">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                </button>
                                <button class="cancel-btn" @onmousedown="CancelCurrencyEdit" @onclick="CancelCurrencyEdit">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="18" y1="6" x2="6" y2="18"></line>
                                        <line x1="6" y1="6" x2="18" y2="18"></line>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="currency-card">
                    <span class="currency-code">@curr.Key</span>
                    <div class="currency-value-container">
                        <span class="currency-quota-value">@FormatCurrencyValue(curr.Value.ExpectedQuotaPerMember, curr.Value)</span>
                        @if (!IsReadonly)
                        {
                            <div class="more-actions-container">
                                <VibeMenu>
                                    <Trigger>
                                        <div class="action-trigger">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <circle cx="12" cy="5" r="1"></circle>
                                                <circle cx="12" cy="12" r="1"></circle>
                                                <circle cx="12" cy="19" r="1"></circle>
                                            </svg>
                                        </div>
                                    </Trigger>
                                    <ChildContent>
                                        @{
                                            var keys = Currencies.Keys.ToList();
                                            int index = keys.IndexOf(curr.Key);
                                            bool isFirst = index == 0;
                                            bool isLast = index == keys.Count - 1;
                                        }
                                        <button class="dropdown-item-vibe" @onclick="() => { StartEditCurrency(curr.Key, curr.Value); }">
                                            Modifica
                                        </button>
                                        <button class="dropdown-item-vibe @(isFirst ? "disabled" : "")" @onclick="async () => { if(!isFirst) { await MoveCurrencyUp(curr.Key); } }">
                                            Sposta su
                                        </button>
                                        <button class="dropdown-item-vibe @(isLast ? "disabled" : "")" @onclick="async () => { if(!isLast) { await MoveCurrencyDown(curr.Key); } }">
                                            Sposta giù
                                        </button>
                                        <button class="dropdown-item-vibe text-danger" @onclick="async () => { await ConfirmDeleteCurrency(curr.Key); }">
                                            Elimina
                                        </button>
                                    </ChildContent>
                                </VibeMenu>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>

    @if (!IsReadonly)
    {
        <div class="add-item-dashed @(isAddingCurrency ? "expanded" : "")" @onclick="() => { if(!isAddingCurrency) StartAddCurrency(); }">
            @if (!isAddingCurrency)
            {
                <div class="dashed-btn-content">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    <span>Aggiungi Cassa</span>
                </div>
            }
            else
            {
                <div id="new-currency-form" class="new-currency-form" @onclick:stopPropagation>
                    <div class="new-currency-header">
                        <span class="wallet-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"></path>
                                <path d="M4 6v12c0 1.1.9 2 2 2h14v-4"></path>
                                <path d="M18 12a2 2 0 0 0-2 2c0 1.1.9 2 2 2h4v-4h-4z"></path>
                            </svg>
                        </span>
                        <span class="new-currency-title">Nuova Cassa</span>
                    </div>
                    
                    <div class="new-currency-grid relative-grid">
                        <div class="new-curr-col">
                            <label>CODICE</label>
                            <input type="text" class="form-control-vibe" value="@newCurrCode" @oninput="OnCodeInput" @onfocus="OnCodeFocus" @onblur="OnCodeBlur" autocomplete="off" />
                        </div>
                        <div class="new-curr-col">
                            <label>SIMBOLO</label>
                            <input type="text" class="form-control-vibe" @bind="newCurrSymbol" @bind:event="oninput" @onblur="TrimSymbol" />
                        </div>

                        <div class="new-curr-col">
                            <label>DECIMALI</label>
                            <input type="text" class="form-control-vibe" inputmode="numeric" value="@newCurrDecimals" @oninput="OnDecimalsChanged" onfocus="appLogic.selectText(this)" />
                        </div>

                        @if (showSuggestions && filteredCurrencies.Any())
                        {
                            <div class="suggestions-dropdown">
                                @foreach (var curr in filteredCurrencies)
                                {
                                    <div class="suggestion-item" @onmousedown="() => SelectSuggestion(curr)">
                                        <span class="sugg-code">@HighlightMatch(curr.Code, newCurrCode)</span>
                                        <span class="sugg-divider">-</span>
                                        <span class="sugg-name">@HighlightMatch(curr.Name, newCurrCode)</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    
                    <div class="new-currency-footer">
                        <div class="new-curr-col quota-col">
                            <label>QUOTA</label>
                            <input type="text" class="form-control-vibe" inputmode="decimal" value="@newCurrQuotaString" @oninput="OnQuotaChanged" onfocus="appLogic.selectText(this)" />
                        </div>
                        <div class="action-buttons">
                            <button class="confirm-btn" @onmousedown="AddOrUpdateCurrency" @onclick="AddOrUpdateCurrency">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                            </button>
                            <button class="cancel-btn" @onmousedown="() => isAddingCurrency = false" @onclick="() => isAddingCurrency = false">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="18" y1="6" x2="6" y2="18"></line>
                                    <line x1="6" y1="6" x2="18" y2="18"></line>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="error-container mt-2">
            <p class="error-text">@error</p>
        </div>
    }
</section>

<style>
    .currencies-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .currency-card {
        background-color: #FFFFFF;
        padding: 1rem 1.25rem;
        border-radius: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
        border: 1px solid #F0F0F0;
    }

    .currency-code {
        font-weight: 700;
        color: #1A3C2F;
        font-size: 1rem;
    }

    .currency-value-container {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .currency-quota-value {
        font-weight: 700;
        color: #1A3C2F;
        font-size: 1rem;
    }

    .more-actions-container {
        position: relative;
        display: flex;
        align-items: center;
    }

    .action-trigger {
        display: flex;
        align-items: center;
        color: #ADB5BD;
        cursor: pointer;
        padding: 0.5rem;
        margin: -0.5rem;
    }

    .dropdown-item-vibe.disabled {
        color: #ADB5BD;
        cursor: default;
        background-color: transparent !important;
    }

    .currency-edit-container {
        border: 2px dashed #D1D9E0;
        border-radius: 32px;
        background-color: #FFFFFF;
        margin-bottom: 0.75rem;
    }

    .new-currency-form {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        text-align: left;
        width: 100%;
    }

    .new-currency-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: #1A3C2F;
    }

    .wallet-icon {
        display: flex;
        color: #20563C;
    }

    .new-currency-title {
        font-weight: 700;
        font-size: 1.1rem;
    }

    .new-currency-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 1rem;
    }

    .new-curr-col {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .new-curr-col label {
        font-size: 0.7rem;
        font-weight: 700;
        color: #8E9AAF;
        letter-spacing: 0.05em;
    }

    .readonly-input-form {
        background-color: #E9ECEF !important;
        color: #6C757D !important;
        cursor: not-allowed;
    }

    .new-currency-footer {
        display: flex;
        align-items: flex-end;
        gap: 1rem;
    }

    .quota-col {
        flex: 1;
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
    }

    .confirm-btn, .cancel-btn {
        background-color: #F1F3F5;
        border: none;
        border-radius: 12px;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .confirm-btn { color: #20563C; }
    .cancel-btn { color: #6C757D; }

    .confirm-btn:active { background-color: #D6EDE2; }
    .cancel-btn:active { background-color: #E9ECEF; }

    .error-container { text-align: center; }
    .error-text { color: #DC3545; font-size: 0.85rem; font-weight: 600; }
    .me-2 { margin-right: 0.5rem; }
    .mt-2 { margin-top: 0.5rem; }

    .relative-grid {
        position: relative;
    }

    .suggestions-dropdown {
        position: absolute;
        top: calc(100% - 0.25rem);
        left: 0;
        right: 0;
        background: white;
        border: 1px solid #F0F0F0;
        border-radius: 12px;
        margin-top: 4px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        z-index: 100;
        max-height: 350px;
        overflow-y: auto;
        padding: 0.5rem;
    }

    .suggestion-item {
        padding: 0.75rem 1rem;
        cursor: pointer;
        display: flex;
        gap: 0.5rem;
        align-items: center;
        font-size: 0.9rem;
        border-radius: 8px;
        transition: background-color 0.2s;
    }

    .suggestion-item:hover {
        background-color: #F8FBF9;
    }

    .sugg-code {
        font-weight: 700;
        color: #1A3C2F;
        min-width: 40px;
    }

    .sugg-divider {
        color: #ADB5BD;
    }

    .sugg-name {
        color: #6C757D;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .suggestion-item b {
        color: #20563C;
        text-decoration: underline;
    }
</style>
