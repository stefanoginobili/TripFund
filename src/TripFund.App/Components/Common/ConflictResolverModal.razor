@using TripFund.App.Models
@using TripFund.App.Utilities

@if (IsVisible && Conflict != null)
{
    <div class="modal-backdrop-vibe modal-z-resolver" @onclick="Close">
        <div class="modal-sheet-vibe" @onclick:stopPropagation="true">
            <header class="modal-header-vibe">
                <h2 class="modal-title-vibe">Risolvi Conflitto</h2>
                <button class="close-btn-vibe" @onclick="Close">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </header>

            <div class="modal-body-vibe">

                <p class="conflict-subtitle">Scegli la versione corretta per <br /><strong>@Conflict.Label</strong></p>

                <div class="version-tiles-container">
                    @if (Conflict.Type == "config" && configVersions != null)
                    {
                        @for (int i = 0; i < configVersions.Count; i++)
                        {
                            var index = i;
                            var v = configVersions[i];
                            <div class="version-tile @(selectedIndex == index ? "selected" : (selectedIndex.HasValue ? "dimmed" : ""))">
                                <div class="version-header">
                                    <div class="version-author">Versione di @v.Author</div>
                                    <div class="version-date">
                                        Creata il @v.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        @if (v.DeviceId == currentDeviceId)
                                        {
                                            <span> da questo dispositivo</span>
                                        }
                                    </div>
                                </div>
                                <div class="version-details">
                                    @if (v.Data == null)
                                    {
                                        <div class="detail-item text-danger fw-bold">
                                            <i class="glyph">🗑️</i> Eliminata
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="detail-item">
                                            <i class="glyph">🏷️</i>
                                            <span class="@GetDiffClass("Name")" @onclick='() => ShowDiffInfo("Name", index)'>@v.Data.Name</span>
                                        </div>
                                        <div class="detail-item">
                                            <i class="glyph">📅</i>
                                            <span class="@GetDiffClass("Dates")" @onclick='() => ShowDiffInfo("Dates", index)'>@v.Data.StartDate.ToString("dd/MM/yyyy") - @v.Data.EndDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <div class="detail-item">
                                            <i class="glyph">📝</i>
                                            <span class="@GetDiffClass("Description")" @onclick='() => ShowDiffInfo("Description", index)'>
                                                @if (string.IsNullOrWhiteSpace(v.Data.Description))
                                                {
                                                    <i>Nessuna descrizione</i>
                                                }
                                                else
                                                {
                                                    @v.Data.Description
                                                }
                                            </span>
                                        </div>
                                        <div class="detail-item">
                                            <i class="glyph">👥</i>
                                            <span class="@GetDiffClass("Members")" @onclick='() => ShowDiffInfo("Members", index)'>@(v.Data.Members.Count == 1 ? "Un partecipante" : $"{v.Data.Members.Count} partecipanti")</span>
                                        </div>
                                        <div class="detail-item">
                                            <i class="glyph">💰</i> 
                                            <span class="@GetDiffClass("Currencies")" @onclick='() => ShowDiffInfo("Currencies", index)'>
                                                @if (v.Data.Currencies != null && v.Data.Currencies.Any())
                                                {
                                                    <span>@string.Join(" / ", v.Data.Currencies.Select(curr => $"{curr.Key} {curr.Value.ExpectedQuotaPerMember.ToString("N" + curr.Value.Decimals)}"))</span>
                                                }
                                                else
                                                {
                                                    <i>Nessuna cassa</i>
                                                }
                                            </span>
                                        </div>
                                    }
                                </div>
                                <div class="version-footer">
                                    <button class="btn-select-version-vibe" @onclick="() => SelectVersion(index)">
                                        Usa questa versione
                                    </button>
                                </div>
                            </div>
                        }
                    }
                    else if (transactionVersions != null)
                    {
                        @for (int i = 0; i < transactionVersions.Count; i++)
                        {
                            var index = i;
                            var v = transactionVersions[i];
                            <div class="version-tile @(selectedIndex == index ? "selected" : (selectedIndex.HasValue ? "dimmed" : ""))">
                                <div class="version-header">
                                    <div class="version-author">Versione di @v.Author</div>
                                    <div class="version-date">
                                        Creata il @v.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        @if (v.DeviceId == currentDeviceId)
                                        {
                                            <span> da questo dispositivo</span>
                                        }
                                    </div>
                                </div>
                                <div class="version-details">
                                    @if (v.Data == null)
                                    {
                                        <div class="detail-item text-danger fw-bold">
                                            <i class="glyph">🗑️</i> Eliminata
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="detail-item">
                                            <i class="glyph">💵</i>
                                            <span class="@GetDiffClass("Amount")" @onclick='() => ShowDiffInfo("Amount", index)'>@v.Data.Currency @v.Data.Amount.ToString(_itCulture)</span>
                                        </div>
                                        <div class="detail-item">
                                            <i class="glyph">📝</i>
                                            <span class="@GetDiffClass("Description")" @onclick='() => ShowDiffInfo("Description", index)'>
                                                @if (string.IsNullOrWhiteSpace(v.Data.Description))
                                                {
                                                    <i>Nessuna descrizione</i>
                                                }
                                                else
                                                {
                                                    @v.Data.Description
                                                }
                                            </span>
                                        </div>
                                        <div class="detail-item">
                                            <i class="glyph">🕒</i>
                                            <span class="@GetDiffClass("DateTime")" @onclick='() => ShowDiffInfo("DateTime", index)'>@v.Data.Date.ToLocalTime().ToString("dd/MM/yyyy HH:mm")<br/>ora di @GetTimeZoneDisplayName(v.Data)</span>
                                        </div>
                                        @if (v.Data.Type == "contribution")
                                        {
                                            <div class="detail-item">
                                                <i class="glyph">👤</i>
                                                <span class="@GetDiffClass("Participant")" @onclick='() => ShowDiffInfo("Participant", index)'>@v.Data.Split.Keys.FirstOrDefault()</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="detail-item">
                                                <i class="glyph">👥</i>
                                                <span class="@GetDiffClass("Participants")" @onclick='() => ShowDiffInfo("Participants", index)'>@(v.Data.Split.Count == 1 ? "Un partecipante" : $"{v.Data.Split.Count} partecipanti")</span>
                                            </div>
                                            <div class="detail-item">
                                                <i class="glyph">📎</i>
                                                <span class="@GetDiffClass("Attachments")" @onclick='() => ShowDiffInfo("Attachments", index)'>@(v.Data.Attachments.Count == 1 ? "Un allegato" : $"{v.Data.Attachments.Count} allegati")</span>
                                            </div>
                                            <div class="detail-item">
                                                <i class="glyph">📍</i>
                                                <span class="@GetDiffClass("Location")" @onclick='() => ShowDiffInfo("Location", index)'>
                                                    @if (string.IsNullOrWhiteSpace(v.Data.Location?.Name))
                                                    {
                                                        <i>Nessun luogo</i>
                                                    }
                                                    else
                                                    {
                                                        @v.Data.Location.Name
                                                    }
                                                </span>
                                            </div>
                                        }
                                    }
                                </div>
                                <div class="version-footer">
                                    <button class="btn-select-version-vibe" @onclick="() => SelectVersion(index)">
                                        Usa questa versione
                                    </button>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="confirm-action-container">
                    <button class="btn-primary-vibe w-100" @onclick="Confirm" disabled="@(!selectedIndex.HasValue || isSaving)">
                        @if (isSaving)
                        {
                            <span>Salvataggio...</span>
                        }
                        else
                        {
                            <span>Conferma</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .conflict-subtitle {
        color: #6C757D;
        margin-bottom: 1.5rem;
    }

    .version-tiles-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .version-tile {
        background-color: #FFFFFF;
        border-radius: 16px;
        padding: 1.25rem;
        border: 2px solid transparent;
        transition: all 0.2s ease;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .version-tile.selected {
        border-color: #20563C;
        background-color: #F0F7F3;
    }

    .version-tile.dimmed .version-header,
    .version-tile.dimmed .version-details {
        opacity: 0.5;
        filter: grayscale(0.5);
    }

    .version-header {
        border-bottom: 1px solid #F0F0F0;
        padding-bottom: 0.5rem;
    }

    .version-author {
        font-weight: 700;
        color: #1A3C2F;
        font-size: 0.95rem;
    }

    .version-date {
        font-size: 0.8rem;
        color: #6C757D;
    }

    .version-details {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .detail-item {
        font-size: 0.9rem;
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }

    .clickable-diff {
        cursor: pointer;
        text-decoration: underline dotted;
    }

    .version-footer {
        margin-top: 0.5rem;
    }

    .btn-select-version-vibe {
        width: 100%;
        background-color: #E8F0EC;
        color: #20563C;
        border: 1.5px solid #20563C;
        padding: 0.6rem;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-select-version-vibe:active {
        background-color: #20563C;
        color: white;
    }

    .selected .btn-select-version-vibe {
        background-color: #20563C;
        color: white;
    }

    .glyph {
        font-style: normal;
        flex-shrink: 0;
    }

    .text-danger {
        color: #DC3545;
        font-weight: 600;
    }

    .text-neutral {
        color: #6C757D;
    }

    .mini-list {
        list-style: none;
        padding: 0;
        margin: 0;
        font-size: 0.8rem;
    }

    .confirm-action-container {
        padding-top: 1rem;
    }

    .btn-primary-vibe {
        background-color: #20563C;
        color: white;
        border: none;
        padding: 1rem;
        border-radius: 12px;
        font-weight: 700;
        cursor: pointer;
    }

    .btn-primary-vibe:disabled {
        background-color: #ADB5BD;
        cursor: not-allowed;
    }
</style>
