@using TripFund.App.Models
@using TripFund.App.Utilities

@if (IsVisible && Conflict != null)
{
    <div class="modal-backdrop-vibe" @onclick="Close">
        <div class="modal-sheet-vibe" @onclick:stopPropagation="true">
            <header class="modal-header-vibe">
                <h2 class="modal-title-vibe">Risolvi Conflitto</h2>
                <button class="close-btn-vibe" @onclick="Close">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </header>

            <div class="modal-body-vibe">
                <p class="conflict-subtitle">Scegli la versione corretta per <br /><strong>@Conflict.Label</strong></p>

                <div class="version-tiles-container">
                    @if (Conflict.Type == "config" && configVersions != null)
                    {
                        @for (int i = 0; i < configVersions.Count; i++)
                        {
                            var index = i;
                            var v = configVersions[i];
                            <div class="version-tile @(selectedIndex == index ? "selected" : (selectedIndex.HasValue ? "dimmed" : ""))" @onclick="() => SelectVersion(index)">
                                <div class="version-header">
                                    <div class="version-author">Versione di @v.Author</div>
                                    <div class="version-date">
                                        Creata il @v.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        @if (v.DeviceId == currentDeviceId)
                                        {
                                            <span> da questo dispositivo</span>
                                        }
                                    </div>
                                </div>
                                <div class="version-details">
                                    @if (v.Data == null)
                                    {
                                        <div class="detail-item text-danger fw-bold">
                                            <i class="glyph">🗑️</i> Eliminata
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="detail-item @GetDiffClass("Name")">
                                            <i class="glyph">🏷️</i> @v.Data.Name
                                        </div>
                                        <div class="detail-item @GetDiffClass("Dates")">
                                            <i class="glyph">📅</i> @v.Data.StartDate.ToString("dd/MM/yyyy") - @v.Data.EndDate.ToString("dd/MM/yyyy")
                                        </div>
                                        <div class="detail-item @GetDiffClass("Description")">
                                            <i class="glyph">📝</i>
                                            @if (string.IsNullOrWhiteSpace(v.Data.Description))
                                            {
                                                <i>Nessuna descrizione</i>
                                            }
                                            else
                                            {
                                                @v.Data.Description
                                            }
                                        </div>
                                        <div class="detail-item @GetDiffClass("Members")">
                                            <i class="glyph">👥</i> @(v.Data.Members.Count == 1 ? "Un partecipante" : $"{v.Data.Members.Count} partecipanti")
                                        </div>
                                        <div class="detail-item @GetDiffClass("Currencies")">
                                            <i class="glyph">💰</i> 
                                            @if (v.Data.Currencies != null && v.Data.Currencies.Any())
                                            {
                                                <span>@string.Join(" / ", v.Data.Currencies.Select(curr => $"{curr.Key} {curr.Value.Symbol}{curr.Value.ExpectedQuotaPerMember.ToString("N" + curr.Value.Decimals)}"))</span>
                                            }
                                            else
                                            {
                                                <i>Nessuna cassa</i>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else if (transactionVersions != null)
                    {
                        @for (int i = 0; i < transactionVersions.Count; i++)
                        {
                            var index = i;
                            var v = transactionVersions[i];
                            <div class="version-tile @(selectedIndex == index ? "selected" : (selectedIndex.HasValue ? "dimmed" : ""))" @onclick="() => SelectVersion(index)">
                                <div class="version-header">
                                    <div class="version-author">Versione di @v.Author</div>
                                    <div class="version-date">
                                        Creata il @v.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        @if (v.DeviceId == currentDeviceId)
                                        {
                                            <span> da questo dispositivo</span>
                                        }
                                    </div>
                                </div>
                                <div class="version-details">
                                    @if (v.Data == null)
                                    {
                                        <div class="detail-item text-danger fw-bold">
                                            <i class="glyph">🗑️</i> Eliminata
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="detail-item @GetDiffClass("Amount")">
                                            <i class="glyph">💵</i> @v.Data.Currency @v.Data.Amount.ToString("N2")
                                        </div>
                                        <div class="detail-item @GetDiffClass("Description")">
                                            <i class="glyph">📝</i>
                                            @if (string.IsNullOrWhiteSpace(v.Data.Description))
                                            {
                                                <i>Nessuna descrizione</i>
                                            }
                                            else
                                            {
                                                @v.Data.Description
                                            }
                                        </div>
                                        <div class="detail-item @GetDiffClass("DateTime")">
                                            <i class="glyph">🕒</i> @v.Data.Date.ToLocalTime().ToString("dd/MM/yyyy HH:mm")<br/>ora di @GetTimeZoneDisplayName(v.Data)
                                        </div>
                                        @if (v.Data.Type == "contribution")
                                        {
                                            <div class="detail-item @GetDiffClass("Participant")">
                                                <i class="glyph">👤</i> @v.Data.Split.Keys.FirstOrDefault()
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="detail-item @GetDiffClass("Participants")">
                                                <i class="glyph">👥</i> @(v.Data.Split.Count == 1 ? "Un partecipante" : $"{v.Data.Split.Count} partecipanti")
                                            </div>
                                            <div class="detail-item @GetDiffClass("Attachments")">
                                                <i class="glyph">📎</i> @(v.Data.Attachments.Count == 1 ? "Un allegato" : $"{v.Data.Attachments.Count} allegati")
                                            </div>
                                            <div class="detail-item @GetDiffClass("Location")">
                                                <i class="glyph">📍</i>
                                                @if (string.IsNullOrWhiteSpace(v.Data.Location?.Name))
                                                {
                                                    <i>Nessun luogo</i>
                                                }
                                                else
                                                {
                                                    @v.Data.Location.Name
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="modal-footer-vibe">
                    <button class="btn-primary-vibe w-100" @onclick="Confirm" disabled="@(!selectedIndex.HasValue || isSaving)">
                        @if (isSaving)
                        {
                            <span>Salvataggio...</span>
                        }
                        else
                        {
                            <span>Conferma</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .modal-backdrop-vibe {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: flex-end;
        justify-content: center;
        z-index: 2100;
        backdrop-filter: blur(4px);
    }

    .modal-sheet-vibe {
        width: 100%;
        max-width: 600px;
        background-color: #F8FBF9;
        border-top-left-radius: 32px;
        border-top-right-radius: 32px;
        display: flex;
        flex-direction: column;
        max-height: 95vh;
        animation: slide-up 0.3s ease-out;
        box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.1);
    }

    @@keyframes slide-up {
        from { transform: translateY(100%); }
        to { transform: translateY(0); }
    }

    .modal-header-vibe {
        padding: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }

    .modal-title-vibe {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1A3C2F;
        margin: 0;
    }

    .close-btn-vibe {
        background: none;
        border: none;
        color: #6C757D;
        cursor: pointer;
        padding: 4px;
        border-radius: 50%;
    }

    .modal-body-vibe {
        flex: 1;
        overflow-y: auto;
        padding: 1rem 1.5rem 3rem;
    }

    .conflict-subtitle {
        color: #6C757D;
        margin-bottom: 1.5rem;
    }

    .version-tiles-container {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .version-tile {
        background-color: #FFFFFF;
        border-radius: 16px;
        padding: 1rem;
        border: 2px solid transparent;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }

    .version-tile.selected {
        border-color: #20563C;
        background-color: #F0F7F3;
    }

    .version-tile.dimmed {
        opacity: 0.5;
        filter: grayscale(0.5);
    }

    .version-header {
        border-bottom: 1px solid #F0F0F0;
        padding-bottom: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .version-author {
        font-weight: 700;
        color: #1A3C2F;
        font-size: 0.95rem;
    }

    .version-date {
        font-size: 0.8rem;
        color: #6C757D;
    }

    .version-details {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .detail-item {
        font-size: 0.9rem;
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }

    .glyph {
        font-style: normal;
        flex-shrink: 0;
    }

    .text-danger {
        color: #DC3545;
        font-weight: 600;
    }

    .text-neutral {
        color: #6C757D;
    }

    .mini-list {
        list-style: none;
        padding: 0;
        margin: 0;
        font-size: 0.8rem;
    }

    .modal-footer-vibe {
        position: sticky;
        bottom: 0;
        background-color: #F8FBF9;
        padding-top: 1rem;
    }

    .btn-primary-vibe {
        background-color: #20563C;
        color: white;
        border: none;
        padding: 1rem;
        border-radius: 12px;
        font-weight: 700;
        cursor: pointer;
    }

    .btn-primary-vibe:disabled {
        background-color: #ADB5BD;
        cursor: not-allowed;
    }
</style>
