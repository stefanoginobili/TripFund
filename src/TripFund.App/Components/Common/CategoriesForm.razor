@using TripFund.App.Models
@using TripFund.App.Constants
@using TripFund.App.Utilities

<section class="info-section">
    <h3 class="section-header-vibe">CATEGORIE DI SPESA</h3>

    <div class="categories-list">
        @if (Categories != null && Categories.Any())
        {
            @foreach (var cat in Categories)
            {
                @if (editingSlug == cat.Key)
                {
                    <div id="edit-category-form" class="category-edit-container">
                        <div class="edit-category-form">

                            <div class="new-category-header">
                                <span class="header-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M12 20h9"></path>
                                        <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                                    </svg>
                                </span>
                                <span class="new-category-title">Modifica Categoria</span>
                            </div>

                            <div class="category-form-row">
                                <div class="icon-col">
                                    <label>ICONA E COLORE</label>
                                    <div class="form-row-compact">
                                        <VibeMenu>
                                            <Trigger>
                                                <div class="icon-input-box" style="background-color: @newCategoryColor">
                                                    <span>@newCategoryIcon</span>
                                                </div>
                                            </Trigger>
                                            <ChildContent>
                                                <div class="emoji-picker-container">
                                                    <div class="emoji-grid">
                                                        @foreach (var emoji in expenseEmojis)
                                                        {
                                                            <button class="emoji-btn @(newCategoryIcon == emoji ? "selected" : "")" @onclick="() => SelectEmoji(emoji)">
                                                                @emoji
                                                            </button>
                                                        }
                                                    </div>
                                                </div>
                                            </ChildContent>
                                        </VibeMenu>
                                        
                                        <VibeMenu>
                                            <Trigger>
                                                <div class="color-picker-trigger" style="background-color: @newCategoryColor">
                                                </div>
                                            </Trigger>
                                            <ChildContent>
                                                <div class="color-picker-popup">
                                                    <div class="color-grid">
                                                        @foreach (var color in palette)
                                                        {
                                                            <div class="color-option @(newCategoryColor == color ? "selected" : "")" 
                                                                 style="background-color: @color" 
                                                                 @onclick="() => SelectColor(color)">
                                                                @if (newCategoryColor == color)
                                                                {
                                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                                                                        <polyline points="20 6 9 17 4 12"></polyline>
                                                                    </svg>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </ChildContent>
                                        </VibeMenu>
                                    </div>
                                </div>
                                <div class="name-col">
                                    <label>NOME</label>
                                    <input type="text" class="form-control-vibe" @bind="newCategoryName" placeholder="Esempio: Trasporti" />
                                </div>
                            </div>

                            <div class="category-form-footer">
                                <div class="slug-col">
                                    <label>SLUG</label>
                                    <input type="text" value="@editingSlug" readonly class="form-control-vibe readonly-input" />
                                </div>
                                <div class="action-buttons">
                                    <button class="confirm-btn" @onclick="SaveCategory">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="20 6 9 17 4 12"></polyline>
                                        </svg>
                                    </button>
                                    <button class="cancel-btn" @onclick="CancelEdit">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="18" y1="6" x2="6" y2="18"></line>
                                            <line x1="6" y1="6" x2="18" y2="18"></line>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="category-item">
                        <div class="category-avatar" style="background-color: @cat.Value.Color">@cat.Value.Icon</div>
                        <div class="category-details">
                            <span class="category-name-text">@cat.Value.Name</span>
                        </div>
                        @if (!IsReadonly)
                        {
                            <div class="more-actions-container">
                                <VibeMenu>
                                    <Trigger>
                                        <div class="action-trigger">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <circle cx="12" cy="5" r="1"></circle>
                                                <circle cx="12" cy="12" r="1"></circle>
                                                <circle cx="12" cy="19" r="1"></circle>
                                            </svg>
                                        </div>
                                    </Trigger>
                                    <ChildContent>
                                        @{
                                            var keys = Categories.Keys.ToList();
                                            int index = keys.IndexOf(cat.Key);
                                            bool isFirst = index == 0;
                                            bool isLast = index == keys.Count - 1;
                                        }
                                        <button class="dropdown-item-vibe" @onclick="async () => await StartEdit(cat.Key, cat.Value)">
                                            Modifica
                                        </button>
                                        <button class="dropdown-item-vibe @(isFirst ? "disabled" : "")" @onclick="async () => { if(!isFirst) await MoveUp(cat.Key); }">
                                            Sposta su
                                        </button>
                                        <button class="dropdown-item-vibe @(isLast ? "disabled" : "")" @onclick="async () => { if(!isLast) await MoveDown(cat.Key); }">
                                            Sposta giù
                                        </button>
                                        <button class="dropdown-item-vibe text-danger" @onclick="async () => await DeleteCategory(cat.Key)">
                                            Elimina
                                        </button>
                                    </ChildContent>
                                </VibeMenu>
                            </div>
                        }
                    </div>
                }
            }
        }
    </div>

    @if (!IsReadonly)
    {
        <div class="add-item-dashed @(isAdding ? "expanded" : "")" @onclick="() => { if(!isAdding) StartAdd(); }">
            @if (!isAdding)
            {
                <div class="dashed-btn-content">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    <span>Aggiungi Categoria</span>
                </div>
            }
            else
            {
                <div id="new-category-form" class="new-category-form" @onclick:stopPropagation>
                    <div class="new-category-header">
                        <span class="header-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="12" y1="5" x2="12" y2="19"></line>
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                        </span>
                        <span class="new-category-title">Nuova Categoria</span>
                    </div>

                    <div class="category-form-row">
                        <div class="icon-col">
                            <label>ICONA E COLORE</label>
                            <div class="form-row-compact">
                                <VibeMenu>
                                    <Trigger>
                                        <div class="icon-input-box" style="background-color: @newCategoryColor">
                                            <span>@newCategoryIcon</span>
                                        </div>
                                    </Trigger>
                                    <ChildContent>
                                        <div class="emoji-picker-container">
                                            <div class="emoji-grid">
                                                @foreach (var emoji in expenseEmojis)
                                                {
                                                    <button class="emoji-btn @(newCategoryIcon == emoji ? "selected" : "")" @onclick="() => SelectEmoji(emoji)">
                                                        @emoji
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </ChildContent>
                                </VibeMenu>
                                
                                <VibeMenu>
                                    <Trigger>
                                        <div class="color-picker-trigger" style="background-color: @newCategoryColor">
                                        </div>
                                    </Trigger>
                                    <ChildContent>
                                        <div class="color-picker-popup">
                                            <div class="color-grid">
                                                @foreach (var color in palette)
                                                {
                                                    <div class="color-option @(newCategoryColor == color ? "selected" : "")" 
                                                         style="background-color: @color" 
                                                         @onclick="() => SelectColor(color)">
                                                        @if (newCategoryColor == color)
                                                        {
                                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                                                                <polyline points="20 6 9 17 4 12"></polyline>
                                                            </svg>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </ChildContent>
                                </VibeMenu>
                            </div>
                        </div>
                        <div class="name-col">
                            <label>NOME</label>
                            <input type="text" class="form-control-vibe" @bind="newCategoryName" @oninput="OnNameInput" placeholder="Esempio: Trasporti" />
                        </div>
                    </div>

                    <div class="category-form-footer">
                        <div class="slug-col">
                            <label>SLUG</label>
                            <input type="text" class="form-control-vibe" @bind="newCategorySlug" placeholder="trasporti" />
                        </div>
                        <div class="action-buttons">
                            <button class="confirm-btn" @onclick="SaveCategory">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                            </button>
                            <button class="cancel-btn" @onclick="() => isAdding = false">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="18" y1="6" x2="6" y2="18"></line>
                                    <line x1="6" y1="6" x2="18" y2="18"></line>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(error))
    {
        <p class="error-text text-center mt-2">@error</p>
    }
</section>

<style>
    .info-section { margin-bottom: 2rem; }
    .me-2 { margin-right: 0.5rem; }
    .mt-2 { margin-top: 0.5rem; }
    .text-center { text-align: center; }

    .categories-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .category-item {
        background-color: #FFFFFF;
        padding: 1rem 1.25rem;
        border-radius: 20px;
        display: flex;
        align-items: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
        gap: 1rem;
    }

    .category-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: black;
    }

    .category-details {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .category-name-text {
        font-weight: 700;
        color: #1A3C2F;
        font-size: 1rem;
    }

    .more-actions-container {
        position: relative;
        display: flex;
        align-items: center;
    }

    .action-trigger {
        display: flex;
        align-items: center;
        color: #ADB5BD;
        cursor: pointer;
        padding: 0.5rem;
        margin: -0.5rem;
    }

    .dropdown-item-vibe.disabled {
        opacity: 0.5;
        cursor: default;
        pointer-events: none;
    }

    .category-edit-container {
        border: 2px dashed #D1D9E0;
        border-radius: 24px;
        background-color: #FFFFFF;
    }

    .category-edit-container {
        width: 100%;
        background-color: #FFFFFF;
        border-radius: 32px;
        margin-bottom: 0.75rem;
        border: 2px dashed #D1D9E0;
    }

    .new-category-form, .edit-category-form {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        text-align: left;
        width: 100%;
    }

    .new-category-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #1A3C2F;
        margin-bottom: 0.25rem;
    }

    .header-icon { display: flex; color: #20563C; }
    .new-category-title { font-weight: 700; font-size: 1rem; }

    .category-form-row {
        display: flex;
        gap: 1rem;
        align-items: flex-end;
    }

    .icon-col { display: flex; flex-direction: column; gap: 0.4rem; }
    .icon-col label, .name-col label, .slug-col label {
        font-size: 0.65rem;
        font-weight: 700;
        color: #8E9AAF;
        letter-spacing: 0.05em;
    }

    .form-row-compact {
        display: flex;
        gap: 0.5rem;
    }

    .icon-input-box, .color-picker-trigger {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        cursor: pointer;
        color: black;
    }

    .color-picker-trigger {
        border: 2px solid rgba(0,0,0,0.05);
    }

    .name-col { flex: 1; display: flex; flex-direction: column; gap: 0.4rem; }

    .color-picker-popup {
    }

    .color-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 0.5rem;
    }

    .color-option {
        aspect-ratio: 1;
        width: 32px;
        height: 32px;
        border-radius: 6px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.1s;
    }

    .color-option:active { transform: scale(0.9); }
    .color-option.selected { box-shadow: 0 0 0 2px #FFFFFF, 0 0 0 2px black; }

    .category-form-footer {
        display: flex;
        align-items: flex-end;
        gap: 1rem;
    }

    .name-col, .slug-col { flex: 1; display: flex; flex-direction: column; gap: 0.5rem; }
    .name-col label, .slug-col label { font-size: 0.7rem; font-weight: 700; color: #8E9AAF; letter-spacing: 0.05em; }

    .emoji-picker-container { width: 100%; max-width: calc(100vw - 4rem); }

    .emoji-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 0.4rem;
        max-height: 200px;
        overflow-y: auto;
    }

    .emoji-btn {
        background: none;
        border: none;
        font-size: 1.3rem;
        padding: 0.25rem;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .emoji-btn.selected { background-color: #D6EDE2; }

    .action-buttons { display: flex; gap: 0.5rem; }
    .confirm-btn, .cancel-btn {
        background-color: #F1F3F5;
        border: none;
        border-radius: 12px;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .confirm-btn { color: #20563C; }
    .cancel-btn { color: #6C757D; }

    .error-text { color: #DC3545; font-size: 0.8rem; font-weight: 600; }
    .readonly-input-form { opacity: 0.7; }
</style>
