@using Microsoft.AspNetCore.Components.Routing
@using TripFund.App.Services
@inject NavigationManager Nav
@inject LocalStorageService Storage
@inject TripFund.App.Services.INavigationService NavService

<Router AppAssembly="@typeof(MauiProgram).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(Layout.MainLayout)">
            <TripFund.App.Components.Pages.NotFound />
        </LayoutView>
    </NotFound>
</Router>

@code {
    protected override async Task OnInitializedAsync()
    {
        NavService.Register(Nav);
        var settings = await Storage.GetAppSettingsAsync();
        if (string.IsNullOrEmpty(settings?.DeviceId) && !Nav.Uri.EndsWith("/onboarding"))
        {
            await NavService.NavigateAsync(string.Empty, "/onboarding");
        }
    }
}
