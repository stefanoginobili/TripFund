@page "/"
@using TripFund.App.Models
@using TripFund.App.Services
@using TripFund.App.Utilities
@inject LocalTripStorageService Storage
@inject IDriveService Drive
@inject NavigationManager Nav

<div class="home-page">
    <header class="app-header">
        <div class="spacer"></div>
        <h1 class="brand-name">TripFund</h1>
        <button class="settings-btn" @onclick="NavigateToSettings">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
            </svg>
        </button>
    </header>

    <main class="content">
        <h2 class="page-title">I miei viaggi</h2>

        <div class="trips-list">
            @if (trips == null)
            {
                <p class="status-text">Caricamento...</p>
            }
            else if (trips.Count == 0)
            {
                <div class="empty-state">
                    <p>Nessun viaggio trovato.</p>
                    <p class="small">Crea il tuo primo viaggio per iniziare!</p>
                </div>
            }
            else
            {
                @foreach (var item in trips)
                {
                    <div class="trip-card" @onclick="() => NavigateToTrip(item.Slug)">
                        <div class="card-top">
                            <div class="trip-icon-container">
                                <span class="trip-icon">🏔️</span>
                            </div>
                            <div class="member-badge">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                                <span>@item.Config.Members.Count Partecipanti</span>
                            </div>
                        </div>
                        <div class="card-bottom">
                            <h3 class="trip-name">@item.Config.Name</h3>
                            <p class="trip-dates">@FormatDates(item.Config.StartDate, item.Config.EndDate)</p>
                        </div>
                    </div>
                }
            }
        </div>
    </main>

    <footer class="footer">
        <button class="btn-create" @onclick="NavigateToCreate">Crea viaggio</button>
        <button class="btn-add" @onclick="HandleJoinTrip">Aggiungi viaggio esistente</button>
    </footer>
</div>

@code {
    private List<TripListItem>? trips;

    protected override async Task OnInitializedAsync()
    {
        await LoadTrips();
    }

    private void NavigateToSettings() => Nav.NavigateTo("/settings");
    private void NavigateToCreate() => Nav.NavigateTo("/create-trip");
    private void NavigateToTrip(string slug) => Nav.NavigateTo($"/trip/{slug}");

    private async Task LoadTrips()
    {
        var registry = await Storage.GetTripRegistryAsync();
        var loadedTrips = new List<TripListItem>();

        foreach (var entry in registry.Trips)
        {
            var config = await Storage.GetTripConfigAsync(entry.Key);
            if (config != null)
            {
                loadedTrips.Add(new TripListItem { Slug = entry.Key, Config = config });
            }
        }
        trips = loadedTrips.OrderByDescending(t => t.Config.StartDate).ToList();
    }

    private async Task HandleJoinTrip()
    {
        var folder = await Drive.PickFolderAsync();
        if (folder == null) return;

        string slug = SlugUtility.GenerateSlug(folder.Name);
        var existingConfig = await Storage.GetTripConfigAsync(slug);
        
        if (existingConfig == null)
        {
            existingConfig = new TripConfig
            {
                Id = Guid.NewGuid().ToString(),
                Name = folder.Name,
                StartDate = DateTime.Today,
                EndDate = DateTime.Today.AddDays(7),
                CreatedAt = DateTime.UtcNow,
                Currencies = new Dictionary<string, Currency> { 
                    { "EUR", new Currency { Symbol = "€", Name = "Euro", ExpectedQuotaPerMember = 500 } } 
                }
            };
            var settings = await Storage.GetAppSettingsAsync();
            var deviceId = settings?.DeviceId ?? "unknown";
            await Storage.SaveTripConfigAsync(slug, existingConfig, deviceId);
        }

        var registry = await Storage.GetTripRegistryAsync();
        registry.Trips[slug] = new TripRegistryEntry { DriveFolderId = folder.Id };
        await Storage.SaveTripRegistryAsync(registry);

        NavigateToTrip(slug);
    }

    private string FormatDates(DateTime start, DateTime end)
    {
        // Example: 1 Nov - 20 Nov 2026
        if (start.Year == end.Year)
        {
            return $"{start:d MMM} - {end:d MMM yyyy}";
        }
        return $"{start:d MMM yyyy} - {end:d MMM yyyy}";
    }

    private class TripListItem
    {
        public string Slug { get; set; } = "";
        public TripConfig Config { get; set; } = new();
    }
}

<style>
    .home-page {
        background-color: #F8FBF9;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        margin: -1.5rem;
    }

    .app-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background-color: #FFFFFF;
        border-bottom: 1px solid #F0F0F0;
    }

    .brand-name {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1A3C2F;
        margin: 0;
    }

    .spacer { width: 40px; }

    .settings-btn {
        background: none;
        border: none;
        color: #495057;
        padding: 0.5rem;
        display: flex;
    }

    .content {
        flex: 1;
        padding: 2rem 1.5rem;
        padding-bottom: 10rem;
    }

    .page-title {
        font-size: 2.2rem;
        font-weight: 700;
        color: #1A3C2F;
        margin-bottom: 2rem;
    }

    .trips-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .trip-card {
        background-color: #FFFFFF;
        border-radius: 28px;
        padding: 1.5rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        cursor: pointer;
        transition: transform 0.1s;
    }

    .trip-card:active {
        transform: scale(0.98);
    }

    .card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }

    .trip-icon-container {
        width: 56px;
        height: 56px;
        background-color: #D6EDE2;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }

    .member-badge {
        background-color: #E9F2EE;
        color: #20563C;
        padding: 0.4rem 0.8rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .trip-name {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1A3C2F;
        margin: 0 0 0.4rem 0;
    }

    .trip-dates {
        font-size: 0.95rem;
        color: #6C757D;
        margin: 0;
    }

    .footer {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 1.5rem;
        background: linear-gradient(0deg, rgba(248,251,249,1) 60%, rgba(248,251,249,0) 100%);
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .btn-create {
        background-color: #20563C;
        color: #FFFFFF;
        border: none;
        border-radius: 20px;
        padding: 1.1rem;
        font-size: 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        box-shadow: 0 4px 12px rgba(32, 86, 60, 0.2);
    }

    .btn-add {
        background-color: #FFFFFF;
        color: #1A3C2F;
        border: 1px solid #E9ECEF;
        border-radius: 20px;
        padding: 1.1rem;
        font-size: 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    }

    .status-text, .empty-state {
        text-align: center;
        color: #6C757D;
        margin-top: 3rem;
    }

    .small { font-size: 0.9rem; }
</style>
