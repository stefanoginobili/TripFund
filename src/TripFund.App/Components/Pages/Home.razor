@page "/"
@using TripFund.App.Models
@using TripFund.App.Services
@using TripFund.App.Utilities
@inject LocalTripStorageService Storage
@inject IDriveService Drive
@inject NavigationManager Nav

<div class="home-page">
    <header class="app-header">
        <div class="spacer"></div>
        <h1 class="brand-name">TripFund</h1>
        <button class="settings-btn" @onclick="NavigateToSettings">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#20563C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.1a2 2 0 0 1-1-1.72v-.51a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
                <circle cx="12" cy="12" r="3"></circle>
            </svg>
        </button>
    </header>

    <div class="content">
        <h2 class="page-title">I miei viaggi</h2>

        <div class="trips-sections">
            @if (isLoading)
            {
                <p class="status-text">Caricamento...</p>
            }
            else if (currentTrips.Count == 0 && futureTrips.Count == 0 && pastTrips.Count == 0)
            {
                <div class="empty-state">
                    <p>Nessun viaggio trovato.</p>
                    <p class="small">Crea il tuo primo viaggio per iniziare!</p>
                </div>
            }
            else
            {
                @if (currentTrips.Any())
                {
                    <section class="info-section">
                        <h3 class="section-header">IN CORSO</h3>
                        <div class="trips-grid">
                            @foreach (var item in currentTrips)
                            {
                                @RenderTripCard(item, "🛫", false, true)
                            }
                        </div>
                    </section>
                }

                @if (futureTrips.Any())
                {
                    <section class="info-section">
                        <h3 class="section-header">FUTURI</h3>
                        <div class="trips-grid">
                            @foreach (var item in futureTrips)
                            {
                                @RenderTripCard(item, "🕒", false, false)
                            }
                        </div>
                    </section>
                }

                @if (pastTrips.Any())
                {
                    <section class="info-section">
                        <h3 class="section-header">PASSATI</h3>
                        <div class="trips-grid">
                            @foreach (var item in pastTrips)
                            {
                                @RenderTripCard(item, "🏁", true, false)
                            }
                        </div>
                    </section>
                }
            }
        </div>
    </div>

    <footer class="footer">
        <button class="btn-create" @onclick="NavigateToCreate">Crea viaggio</button>
        <button class="btn-add" @onclick="HandleJoinTrip">Aggiungi viaggio esistente</button>
    </footer>
</div>

@code {
    private List<TripListItem> currentTrips = new();
    private List<TripListItem> futureTrips = new();
    private List<TripListItem> pastTrips = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadTrips();
    }

    private void NavigateToSettings() => Nav.NavigateTo("/settings");
    private void NavigateToCreate() => Nav.NavigateTo("/create-trip");
    private void NavigateToTrip(string slug) => Nav.NavigateTo($"/trip/{slug}");

    private async Task LoadTrips()
    {
        isLoading = true;
        var registry = await Storage.GetTripRegistryAsync();
        var allLoaded = new List<TripListItem>();

        foreach (var entry in registry.Trips)
        {
            var config = await Storage.GetTripConfigAsync(entry.Key);
            if (config != null)
            {
                allLoaded.Add(new TripListItem { Slug = entry.Key, Config = config });
            }
        }

        var today = DateTime.Today;

        currentTrips = allLoaded
            .Where(t => today >= t.Config.StartDate.Date && today <= t.Config.EndDate.Date)
            .OrderBy(t => t.Config.StartDate)
            .ToList();

        futureTrips = allLoaded
            .Where(t => t.Config.StartDate.Date > today)
            .OrderBy(t => t.Config.StartDate)
            .ToList();

        pastTrips = allLoaded
            .Where(t => t.Config.EndDate.Date < today)
            .OrderByDescending(t => t.Config.StartDate)
            .ToList();

        isLoading = false;
    }

    private async Task HandleJoinTrip()
    {
        var folder = await Drive.PickFolderAsync();
        if (folder == null) return;

        string slug = SlugUtility.GenerateSlug(folder.Name);
        var existingConfig = await Storage.GetTripConfigAsync(slug);
        
        if (existingConfig == null)
        {
            existingConfig = new TripConfig
            {
                Id = Guid.NewGuid().ToString(),
                Name = folder.Name,
                StartDate = DateTime.Today,
                EndDate = DateTime.Today.AddDays(7),
                CreatedAt = DateTime.UtcNow,
                Currencies = new Dictionary<string, Currency> { 
                    { "EUR", new Currency { Symbol = "€", Name = "Euro", ExpectedQuotaPerMember = 500 } } 
                }
            };
            var settings = await Storage.GetAppSettingsAsync();
            var deviceId = settings?.DeviceId ?? "unknown";
            await Storage.SaveTripConfigAsync(slug, existingConfig, deviceId);
        }

        var registry = await Storage.GetTripRegistryAsync();
        registry.Trips[slug] = new TripRegistryEntry { DriveFolderId = folder.Id };
        await Storage.SaveTripRegistryAsync(registry);

        NavigateToTrip(slug);
    }

    private string FormatDates(DateTime start, DateTime end)
    {
        if (start.Year == end.Year)
        {
            return $"{start:d MMM} - {end:d MMM yyyy}";
        }
        return $"{start:d MMM yyyy} - {end:d MMM yyyy}";
    }

    private RenderFragment RenderTripCard(TripListItem item, string icon, bool isGray, bool isHighlighted) => __builder => {
        <div class="trip-card @(isGray ? "grayscale" : "") @(isHighlighted ? "active-trip" : "")" @onclick="() => NavigateToTrip(item.Slug)">
            <div class="card-top">
                <div class="trip-icon-container">
                    <span class="trip-icon">@icon</span>
                </div>
                <div class="member-badge">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    <span>@item.Config.Members.Count @(item.Config.Members.Count == 1 ? "Partecipante" : "Partecipanti")</span>
                </div>
            </div>
            <div class="card-bottom">
                <h3 class="trip-name">@item.Config.Name</h3>
                <p class="trip-dates">@FormatDates(item.Config.StartDate, item.Config.EndDate)</p>
            </div>
        </div>
    };

    private class TripListItem
    {
        public string Slug { get; set; } = "";
        public TripConfig Config { get; set; } = new();
    }
}

<style>
    .home-page {
        background-color: #F8FBF9;
        display: flex;
        flex-direction: column;
    }

    .app-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background-color: #FFFFFF;
        border-bottom: 1px solid #F0F0F0;
        position: sticky;
        top: 0;
        z-index: 999;
    }

    .brand-name {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1A3C2F;
        margin: 0;
    }

    .spacer { width: 40px; }

    .settings-btn {
        background: none;
        border: none;
        color: #495057;
        padding: 0.5rem;
        display: flex;
    }

    .content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 700;
        color: #1A3C2F;
        margin-bottom: 0;
    }

    .trips-sections {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .info-section {
        background-color: transparent;
        border-radius: 0;
        padding: 0;
        box-shadow: none;
        width: 100%;
        margin-bottom: 0.5rem;
    }

    .section-header {
        font-size: 0.75rem;
        font-weight: 800;
        color: #20563C;
        letter-spacing: 0.1em;
        margin-bottom: 0.75rem;
        text-transform: uppercase;
    }

    .trips-grid {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        width: 100%;
    }

    .trip-card {
        background-color: #FFFFFF;
        border-radius: 20px;
        padding: 1rem;
        cursor: pointer;
        transition: transform 0.1s, box-shadow 0.2s;
        border: 1px solid #F0F0F0;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
        width: 100%;
    }

    .trip-card:active {
        transform: scale(0.98);
    }

    .trip-card.active-trip {
        border: 2px solid #20563C;
    }

    .trip-card.grayscale {
        filter: grayscale(1);
        opacity: 0.8;
    }

    .card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .trip-icon-container {
        width: 40px;
        height: 40px;
        background-color: #FFFFFF;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    .member-badge {
        background-color: #E9F2EE;
        color: #20563C;
        padding: 0.25rem 0.6rem;
        border-radius: 16px;
        font-size: 0.75rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .trip-name {
        font-size: 1.15rem;
        font-weight: 700;
        color: #1A3C2F;
        margin: 0 0 0.15rem 0;
    }

    .trip-dates {
        font-size: 0.8rem;
        color: #6C757D;
        margin: 0;
    }

    .footer {
        margin-top: 1rem;
        padding: 0 1.5rem 2rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .btn-create {
        background-color: #20563C;
        color: #FFFFFF;
        border: none;
        border-radius: 20px;
        padding: 1.1rem;
        font-size: 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        box-shadow: 0 4px 12px rgba(32, 86, 60, 0.2);
    }

    .btn-add {
        background-color: #FFFFFF;
        color: #1A3C2F;
        border: 1px solid #E9ECEF;
        border-radius: 20px;
        padding: 1.1rem;
        font-size: 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    }

    .status-text, .empty-state {
        text-align: center;
        color: #6C757D;
        margin-top: 3rem;
    }

    .small { font-size: 0.9rem; }
</style>