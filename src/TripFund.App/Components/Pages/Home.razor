@page "/"

<div class="app-page">
    <header class="app-header">
        <div class="spacer"></div>
        <h1 class="brand-name">TripFund</h1>
        <button class="icon-btn" @onclick="NavigateToSettings">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#20563C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.1a2 2 0 0 1-1-1.72v-.51a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
                <circle cx="12" cy="12" r="3"></circle>
            </svg>
        </button>
    </header>

    <div class="content">
        <h2 class="page-title">I miei viaggi</h2>

        <div class="trips-sections">
            @if (isLoading)
            {
                <LoadingSpinner />
            }

            else if (currentTrips.Count == 0 && futureTrips.Count == 0 && pastTrips.Count == 0)
            {
                <div class="empty-state">
                    <p>Nessun viaggio trovato.</p>
                    <p class="small">Crea il tuo primo viaggio per iniziare!</p>
                </div>
            }
            else
            {
                @if (currentTrips.Any())
                {
                    <section class="info-section">
                        <h3 class="section-header-vibe">IN CORSO</h3>
                        <div class="trips-grid">
                            @foreach (var item in currentTrips)
                            {
                                @RenderTripCard(item, "🛫", false, true)
                            }
                        </div>
                    </section>
                }

                @if (futureTrips.Any())
                {
                    <section class="info-section">
                        <h3 class="section-header-vibe">FUTURI</h3>
                        <div class="trips-grid">
                            @foreach (var item in futureTrips)
                            {
                                @RenderTripCard(item, "🕒", false, false)
                            }
                        </div>
                    </section>
                }

                @if (pastTrips.Any())
                {
                    <section class="info-section">
                        <h3 class="section-header-vibe">PASSATI</h3>
                        <div class="trips-grid">
                            @foreach (var item in pastTrips)
                            {
                                @RenderTripCard(item, "🏁", true, false)
                            }
                        </div>
                    </section>
                }
            }
        </div>
    </div>

    <footer class="footer">
        <button class="btn-primary-vibe" @onclick="NavigateToCreate">Crea viaggio</button>
        <button class="btn-secondary-vibe" @onclick="HandleJoinTrip">Aggiungi viaggio esistente</button>
    </footer>
</div>

@code {
    private RenderFragment RenderTripCard(TripListItem item, string icon, bool isGray, bool isHighlighted) => __builder => {
        <div class="trip-card @(isGray ? "grayscale" : "") @(isHighlighted ? "active-trip" : "")" @onclick="() => NavigateToTrip(item.Slug)">
            <div class="card-top">
                <div class="trip-icon-container">
                    <span class="trip-icon">@icon</span>
                </div>
                <div class="member-badge">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    <span>@item.Config.Members.Count @(item.Config.Members.Count == 1 ? "Partecipante" : "Partecipanti")</span>
                </div>
            </div>
            <div class="card-bottom">
                <h3 class="trip-name">@item.Config.Name</h3>
                <p class="trip-dates">@FormatDates(item.Config.StartDate, item.Config.EndDate)</p>
            </div>
        </div>
    };
}

<style>
    .brand-name {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1A3C2F;
        margin: 0;
    }

    .spacer { width: 40px; }

    .page-title {
        font-size: 2rem;
        font-weight: 700;
        color: #1A3C2F;
        margin-bottom: 0;
    }

    .trips-sections {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .trips-grid {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        width: 100%;
    }

    .trip-card {
        background-color: #FFFFFF;
        border-radius: 20px;
        padding: 1rem;
        cursor: pointer;
        transition: transform 0.1s, box-shadow 0.2s;
        border: 1px solid #F0F0F0;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
        width: 100%;
    }

    .trip-card:active {
        transform: scale(0.98);
    }

    .trip-card.active-trip {
        border: 2px solid #20563C;
    }

    .trip-card.grayscale {
        filter: grayscale(1);
        opacity: 0.8;
    }

    .card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .trip-icon-container {
        width: 40px;
        height: 40px;
        background-color: #FFFFFF;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    .member-badge {
        background-color: #E9F2EE;
        color: #20563C;
        padding: 0.25rem 0.6rem;
        border-radius: 16px;
        font-size: 0.75rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .trip-name {
        font-size: 1.15rem;
        font-weight: 700;
        color: #1A3C2F;
        margin: 0 0 0.15rem 0;
    }

    .trip-dates {
        font-size: 0.8rem;
        color: #6C757D;
        margin: 0;
    }

    .footer {
        margin-top: 1rem;
        padding: 0 1.5rem 2rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .btn-secondary-vibe {
        background-color: #FFFFFF;
        color: #1A3C2F;
        border: 1px solid #E9ECEF;
        border-radius: 20px;
        padding: 1.1rem;
        font-size: 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    }

    .btn-secondary-vibe:active {
        transform: scale(0.98);
    }

    .status-text, .empty-state {
        text-align: center;
        color: #6C757D;
        margin-top: 3rem;
    }

    .small { font-size: 0.9rem; }
</style>
