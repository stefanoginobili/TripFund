@page "/trip/{tripSlug}/add-expense"

<div class="add-transaction-page">
    <header class="app-header">
        <button class="icon-btn" @onclick="GoBack">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </button>
        <h1 class="header-title">@(config?.Name ?? "...")</h1>
        <div class="header-actions">
            @if (editingInfo != null)
            {
                <div class="dropdown">
                    <button class="icon-btn" @onclick="ToggleMenu">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="1"></circle>
                            <circle cx="12" cy="5" r="1"></circle>
                            <circle cx="12" cy="19" r="1"></circle>
                        </svg>
                    </button>
                    @if (isMenuOpen)
                    {
                        <div class="popover-overlay-menu" @onclick="ToggleMenu"></div>
                        <div class="dropdown-menu-custom">
                            <button class="dropdown-item text-danger" @onclick="DeleteTransaction">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                    <polyline points="3 6 5 6 21 6"></polyline>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                </svg>
                                Elimina Spesa
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    </header>

    @if (config == null)
    {
        <LoadingSpinner />
    }

    else
    {
        @if (config.Currencies.Count > 1)
        {
            <CurrencySelector Currencies="@(new[] { selectedCurrency })" SelectedCurrency="@selectedCurrency" OnCurrencySelected="SelectCurrency" />
        }

        <div class="content">
            <div class="form-container">
                <div class="amount-tile">
                    <div class="tile-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="23 18 13.5 8.5 8.5 13.5 1 6"></polyline>
                            <polyline points="17 18 23 18 23 12"></polyline>
                        </svg>
                    </div>
                    <label class="tile-label">IMPORTO SPESA</label>
                    <div class="amount-section">
                        <span class="currency-symbol">@GetCurrencySymbol()</span>
                        <input type="text" inputmode="@(GetDecimals() > 0 ? "decimal" : "numeric")" class="amount-input" value="@totalAmount.ToString("F" + GetDecimals())" @onchange="OnAmountChanged" onfocus="headerLogic.selectText(this)" placeholder="@(GetDecimals() > 0 ? "0," + new string('0', GetDecimals()) : "0")" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Descrizione</label>
                    <input type="text" class="form-control" @bind="description" placeholder="es. Cena a Buenos Aires" />
                </div>

                <div class="datetime-row">
                    <NativeDatePicker Label="Data" @bind-Value="transactionDate" Class="flex-1" />
                    <NativeTimePicker Label="Ora" @bind-Value="transactionDate" Class="flex-1" />
                </div>

                <TimeZoneSelector Label="Fuso Orario" @bind-Value="timezoneId" />

                <div class="info-section">
                    <h3 class="section-header">Partecipanti</h3>
                    <div class="members-split-list">
                        @foreach (var member in memberSplits)
                        {
                            <div class="member-split-row">
                                <div class="member-basic-info">
                                    <div class="member-avatar">@member.Avatar</div>
                                    <div class="member-name">@member.Name</div>
                                    <div class="switch @(member.IsIncluded ? "on" : "off")" @onclick="() => ToggleMember(member)">
                                        <div class="switch-handle"></div>
                                    </div>
                                </div>
                                
                                @if (member.IsIncluded)
                                {
                                    <div class="split-controls">
                                        <div class="split-mode-toggle" @onclick="() => ToggleAuto(member)">
                                            @(member.IsAuto ? "Auto" : "Manuale")
                                        </div>
                                        <input type="text" inputmode="@(GetDecimals() > 0 ? "decimal" : "numeric")" class="split-amount-input @(member.IsAuto ? "readonly" : "")" 
                                               value="@((member.IsAuto ? member.CalculatedAmount : member.ManualAmount).ToString("F" + GetDecimals()))"
                                               @onchange="(e) => OnManualAmountChanged(member, e)"
                                               onfocus="headerLogic.selectText(this)"
                                               readonly="@member.IsAuto" />
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="info-section">
                    <h3 class="section-header">Allegati</h3>
                    <div class="attachments-row">
                        @foreach (var att in attachments)
                        {
                            <div class="attachment-pill">
                                <span>@GetAttachmentDisplayName(att)</span>
                                <button class="remove-btn" @onclick="() => RemoveAttachment(att)">×</button>
                            </div>
                        }
                    </div>
                    <div class="attachment-actions-dashed">
                        <div class="add-attachment-dashed" @onclick="CapturePhoto">
                            <div class="dashed-btn-content">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                                <span>Foto</span>
                            </div>
                        </div>
                        <div class="add-attachment-dashed" @onclick="PickFile">
                            <div class="dashed-btn-content">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><polyline points="13 2 13 9 20 9"></polyline></svg>
                                <span>File</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="info-section">
                    <h3 class="section-header">Luogo</h3>
                    @if (locationInfo != null)
                    {
                        <div class="location-card">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                            <div class="location-details">
                                <input type="text" class="location-input" @bind="locationInfo.Name" placeholder="Nome del luogo" />
                                <div class="location-coords">@locationInfo.Latitude.ToString("F6"), @locationInfo.Longitude.ToString("F6")</div>
                            </div>
                            <button class="remove-btn" @onclick="() => locationInfo = null">×</button>
                        </div>
                    }
                    else
                    {
                        <div class="add-location-dashed @(isLocating ? "locating" : "")" @onclick="FetchLocation">
                            <div class="dashed-btn-content">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                    @if (isLocating)
                                    {
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                        <circle cx="12" cy="10" r="3"></circle>
                                    }
                                    else
                                    {
                                        <line x1="12" y1="5" x2="12" y2="19"></line>
                                        <line x1="5" y1="12" x2="19" y2="12"></line>
                                    }
                                </svg>
                                <span>@(isLocating ? "Acquisizione..." : "Aggiungi posizione")</span>
                            </div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <p class="error-message">@errorMessage</p>
                }

                <button class="submit-btn" @onclick="HandleSubmit" disabled="@(isSubmitting || isLocating)">
                    @(isSubmitting ? "Salvataggio..." : "Salva")
                </button>
            </div>
        </div>
    }
</div>

<style>
    /* Reuse some styles from AddContribution */
    .add-transaction-page { background-color: #F8FBF9; min-height: 100vh; display: flex; flex-direction: column; }
    .app-header {
        position: sticky;
        top: 0;
        z-index: 999;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background-color: #FFFFFF;
        border-bottom: 1px solid #F0F0F0;
    }
    .header-title {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        font-size: 1.25rem;
        font-weight: 800;
        color: #1A3C2F;
        margin: 0;
        text-align: center;
        width: 60%;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .icon-btn { background: none; border: none; color: #1A3C2F; padding: 0.5rem; display: flex; align-items: center; justify-content: center; }
    
    .header-actions {
        display: flex;
        align-items: center;
        position: relative;
    }

    .dropdown-menu-custom {
        position: absolute;
        top: 100%;
        right: 0;
        background-color: #FFFFFF;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        padding: 0.5rem;
        z-index: 1101;
        min-width: 150px;
        display: flex;
        flex-direction: column;
        border: 1px solid #F0F0F0;
    }

    .dropdown-item {
        background: none; border: none; padding: 0.75rem 1rem; text-align: left; font-weight: 600; font-size: 0.95rem; color: #1A3C2F; display: flex; align-items: center; border-radius: 8px; width: 100%; white-space: nowrap;
    }

    .dropdown-item:hover:not(:disabled) {
        background-color: #F8FBF9;
    }

    .text-danger {
        color: #DC3545 !important;
    }

    .popover-overlay-menu {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: transparent;
        z-index: 1100;
    }

    .spacer { width: 36px; }
    .content { padding: 1.5rem; flex: 1; }
    .form-container { display: flex; flex-direction: column; gap: 1.5rem; }
    
    .amount-tile {
        background-color: #FCE8E8;
        border: none;
        border-radius: 28px;
        padding: 1.75rem 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
        margin-bottom: 0.5rem;
        box-shadow: 0 4px 12px rgba(220, 53, 69, 0.05);
    }

    .tile-icon {
        color: #DC3545;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .tile-label {
        font-size: 0.7rem;
        font-weight: 800;
        color: #DC3545;
        letter-spacing: 0.15em;
        text-transform: uppercase;
    }

    .amount-section { display: flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.5rem 0; }
    .currency-symbol { font-size: 2.75rem; font-weight: 700; color: #DC3545; }
    .amount-input { border: none; background: none; font-size: 3.75rem; font-weight: 700; color: #DC3545; width: 100%; max-width: 300px; text-align: center; outline: none; }

    .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
    .form-group label { font-size: 0.75rem; font-weight: 800; color: #1A3C2F; letter-spacing: 0.05em; text-transform: uppercase; }
    .form-control { padding: 0.8rem 1rem; border-radius: 12px; border: 1px solid #E0E0E0; background-color: #FFFFFF; font-size: 1rem; outline: none; }
    
    .flex-1 { flex: 1; }
    .datetime-row { display: flex; gap: 1rem; }
    .datetime-picker-box { background-color: #F1F3F5; border-radius: 16px; padding: 0.85rem 1rem; display: flex; align-items: center; gap: 0.75rem; position: relative; cursor: pointer; min-height: 56px; }
    .datetime-value { font-size: 1.1rem; font-weight: 700; color: #1A3C2F; }
    .hidden-picker { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; }
    
    .info-section {
        background-color: transparent;
        border-radius: 0;
        padding: 0;
        box-shadow: none;
        width: 100%;
        margin-bottom: 1.5rem;
    }

    .section-header {
        font-size: 0.8rem;
        font-weight: 800;
        color: #20563C;
        letter-spacing: 0.1em;
        margin-bottom: 1rem;
        text-transform: uppercase;
    }

    .members-split-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .member-split-row { background-color: #FFFFFF; padding: 0.75rem 1rem; border-radius: 16px; display: flex; flex-direction: column; gap: 0.75rem; box-shadow: 0 2px 8px rgba(0,0,0,0.02); }
    .member-basic-info { display: flex; align-items: center; gap: 0.75rem; }
    .member-avatar { font-size: 1.5rem; width: 36px; height: 36px; background-color: #F8FBF9; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .member-name { flex: 1; font-weight: 600; color: #1A3C2F; }

    .split-controls { display: flex; align-items: center; gap: 0.5rem; padding-top: 0.5rem; border-top: 1px solid #F8FBF9; }
    .split-mode-toggle { flex: 1; font-size: 0.8rem; font-weight: 700; color: #20563C; background-color: #D6EDE2; padding: 0.4rem 0.2rem; border-radius: 8px; cursor: pointer; text-align: center; }
    .split-amount-input { flex: 2; border: 1px solid #E0E0E0; border-radius: 8px; padding: 0.4rem 0.6rem; text-align: right; font-weight: 700; font-size: 1rem; color: #1A3C2F; outline: none; }
    .split-amount-input.readonly { background-color: #F8FBF9; border-color: transparent; }

    .switch { width: 40px; height: 22px; border-radius: 11px; padding: 2px; cursor: pointer; transition: background-color 0.2s; }
    .switch.on { background-color: #20563C; }
    .switch.off { background-color: #E0E0E0; }
    .switch-handle { width: 18px; height: 18px; background-color: #FFFFFF; border-radius: 50%; transition: transform 0.2s; }
    .switch.on .switch-handle { transform: translateX(18px); }

    .attachments-row { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; margin-bottom: 0.75rem; }
    .attachment-pill { background-color: #D6EDE2; color: #20563C; padding: 0.4rem 0.8rem; border-radius: 20px; font-size: 0.85rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; }
    .remove-btn { background: none; border: none; font-size: 1.2rem; line-height: 1; color: inherit; padding: 0; }
    
    .attachment-actions-dashed { display: flex; gap: 0.75rem; }
    .add-attachment-dashed {
        flex: 1;
        border: 2px dashed #D1D9E0;
        border-radius: 32px;
        padding: 0.75rem;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        transition: all 0.3s ease;
        background-color: transparent;
        color: #6C757D;
        font-weight: 600;
    }

    .add-location-dashed {
        border: 2px dashed #D1D9E0;
        border-radius: 32px;
        padding: 1rem;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        transition: all 0.3s ease;
        background-color: transparent;
        width: 100%;
        color: #6C757D;
        font-weight: 600;
    }
    .add-location-dashed.locating { opacity: 0.6; cursor: default; }
    .dashed-btn-content { display: flex; align-items: center; justify-content: center; }
    .location-card { background-color: #FFFFFF; padding: 0.75rem 1rem; border-radius: 16px; display: flex; align-items: center; gap: 0.75rem; box-shadow: 0 2px 8px rgba(0,0,0,0.02); }
    .location-details { flex: 1; display: flex; flex-direction: column; gap: 4px; }
    .location-input { border: 1px solid #E0E0E0; border-radius: 8px; background: #FFFFFF; font-weight: 700; color: #1A3C2F; padding: 0.4rem 0.6rem; width: 100%; outline: none; font-size: 1rem; transition: border-color 0.2s; }
    .location-input:focus { border-color: #20563C; }
    .location-coords { font-size: 0.75rem; color: #6C757D; }

    .submit-btn { background-color: #20563C; color: #FFFFFF; border: none; padding: 1rem; border-radius: 16px; font-weight: 700; font-size: 1.1rem; margin-top: 1rem; box-shadow: 0 4px 12px rgba(32, 86, 60, 0.2); }
    .submit-btn:disabled { opacity: 0.6; }
    .error-message { color: #DC3545; font-size: 0.9rem; text-align: center; }
</style>
