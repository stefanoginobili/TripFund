@page "/create-trip"

<div class="app-page">
    <header class="app-header">
        <button class="icon-btn" @onclick='async () => await JSRuntime.InvokeVoidAsync("history.back")'>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </button>
        <h1 class="header-title">Nuovo Viaggio</h1>
        <div style="width: 40px;"></div> <!-- Empty space to keep title centered -->
    </header>

    <div class="content">
        <GeneralInfoForm @bind-Name="tripName"
                         @bind-Slug="tripSlug"
                         @bind-StartDate="startDate"
                         @bind-EndDate="endDate"
                         @bind-Description="description"
                         IsCreate="true" />

        <CurrenciesForm @bind-Currencies="currencies" />

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="text-danger fw-bold text-center mt-3">@error</div>
        }

        <button class="btn-primary-vibe mt-4 mb-4" @onclick="HandleCreate">Crea</button>
    </div>
</div>

<style>
    .hero-section {
        text-align: center;
    }

    .globe-container {
        display: flex;
        justify-content: center;
        margin-bottom: 1.5rem;
    }

    .globe-icon {
        width: 80px;
        height: 80px;
        background-color: #D6EDE2;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
    }

    .main-title {
        font-size: 2rem;
        font-weight: 700;
        color: #1A3C2F;
        margin-bottom: 0.5rem;
    }

    .subtitle {
        font-size: 1rem;
        color: #6C757D;
    }

    .mt-3 { margin-top: 1rem; }
    .mt-4 { margin-top: 1.5rem; }
    .mb-4 { margin-bottom: 2rem; }
    .text-center { text-align: center; }
</style>
