@page "/create-trip"
@using TripFund.App.Models
@using TripFund.App.Services
@using TripFund.App.Utilities
@inject LocalTripStorageService Storage
@inject IDriveService Drive
@inject NavigationManager Nav

<div class="create-trip-page">
    <header class="app-header">
        <button class="back-btn" @onclick='() => Nav.NavigateTo("/")'>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </button>
        <h1 class="header-title">Nuovo Viaggio</h1>
        <button class="menu-btn">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="1"></circle>
                <circle cx="12" cy="5" r="1"></circle>
                <circle cx="12" cy="19" r="1"></circle>
            </svg>
        </button>
    </header>

    <main class="content">
        <div class="hero-section">
            <div class="globe-container">
                <div class="globe-icon">🌍</div>
            </div>
            <h2 class="main-title">Crea Viaggio</h2>
            <p class="subtitle">Inizia a pianificare la tua prossima avventura</p>
        </div>

        <div class="form-section">
            <div class="form-group mb-4">
                <label class="form-label">NOME VIAGGIO</label>
                <input type="text" class="form-control custom-input" 
                       placeholder="Esempio: Tour della Toscana" 
                       @bind="tripName" @oninput="OnNameInput" />
            </div>

            <div class="form-group mb-4">
                <label class="form-label">SLUG VIAGGIO</label>
                <div class="slug-display">
                    <input type="text" class="form-control custom-input readonly-input" 
                           @bind="tripSlug" placeholder="tour-toscana-2024" />
                </div>
            </div>

            <div class="date-card mb-4">
                <div class="card-header">
                    <span class="calendar-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                    </span>
                    <span class="card-title">Periodo del viaggio</span>
                </div>
                <div class="card-body">
                    <div class="date-col">
                        <label class="form-label">INIZIO</label>
                        <input type="date" class="form-control date-input" @bind="startDate" />
                    </div>
                    <div class="date-col">
                        <label class="form-label">FINE</label>
                        <input type="date" class="form-control date-input" @bind="endDate" />
                    </div>
                </div>
            </div>

            <div class="section-divider"></div>

            <div class="currency-section mb-4">
                <label class="form-label">VALUTE</label>
                @foreach (var curr in currencies)
                {
                    <div class="currency-item">
                        <div class="currency-info">
                            <span class="currency-badge">@curr.Code</span>
                            <span class="currency-symbol">@curr.Symbol</span>
                        </div>
                        <div class="currency-quota">
                            <input type="number" class="form-control small-input" @bind="curr.ExpectedQuota" placeholder="Quota" />
                        </div>
                        <button class="remove-btn" @onclick="() => RemoveCurrency(curr)">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                <line x1="6" y1="6" x2="18" y2="18"></line>
                            </svg>
                        </button>
                    </div>
                }

                <div class="add-currency-row mt-2">
                    <input type="text" class="form-control small-input" placeholder="Codice" @bind="newCurrCode" style="width: 70px;" />
                    <input type="text" class="form-control small-input" placeholder="Simbolo" @bind="newCurrSymbol" style="width: 60px;" />
                    <input type="number" class="form-control small-input" placeholder="Quota" @bind="newCurrQuota" />
                    <button class="btn-add" @onclick="AddCurrency">Aggiungi</button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="error-msg">@error</div>
            }
        </div>
    </main>

    <footer class="footer">
        <button class="btn-submit" @onclick="HandleCreate">
            <span class="cloud-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
                </svg>
            </span>
            Seleziona Cartella Drive e Crea
        </button>
    </footer>
</div>

@code {
    private string tripName = "";
    private string tripSlug = "";
    private DateTime startDate = DateTime.Today;
    private DateTime endDate = DateTime.Today.AddDays(7);
    private string error = "";

    private string newCurrCode = "";
    private string newCurrSymbol = "";
    private decimal newCurrQuota = 0;

    private List<CurrencyViewModel> currencies = new()
    {
        new CurrencyViewModel { Code = "EUR", Symbol = "€", ExpectedQuota = 500 }
    };

    private void OnNameInput(ChangeEventArgs e)
    {
        tripName = e.Value?.ToString() ?? "";
        tripSlug = SlugUtility.GenerateSlug(tripName);
    }

    private void AddCurrency()
    {
        if (string.IsNullOrWhiteSpace(newCurrCode)) return;
        if (currencies.Any(c => c.Code.Equals(newCurrCode, StringComparison.OrdinalIgnoreCase)))
        {
            error = "Valuta già presente.";
            return;
        }
        currencies.Add(new CurrencyViewModel
        {
            Code = newCurrCode.ToUpperInvariant(),
            Symbol = string.IsNullOrWhiteSpace(newCurrSymbol) ? newCurrCode : newCurrSymbol,
            ExpectedQuota = newCurrQuota
        });
        newCurrCode = "";
        newCurrSymbol = "";
        newCurrQuota = 0;
        error = "";
    }

    private void RemoveCurrency(CurrencyViewModel curr)
    {
        currencies.Remove(curr);
    }

    private async Task HandleCreate()
    {
        if (string.IsNullOrWhiteSpace(tripName)) { error = "Il nome è obbligatorio."; return; }
        if (string.IsNullOrWhiteSpace(tripSlug)) { error = "Lo slug è obbligatorio."; return; }
        if (currencies.Count == 0) { error = "Aggiungi almeno una valuta."; return; }

        var registry = await Storage.GetTripRegistryAsync();
        if (registry.Trips.ContainsKey(tripSlug))
        {
            error = "Esiste già un viaggio con questo slug locale.";
            return;
        }

        var folder = await Drive.PickFolderAsync();
        if (folder == null) return;

        var tripConfig = new TripConfig
        {
            Id = Guid.NewGuid().ToString(),
            Name = tripName,
            StartDate = startDate,
            EndDate = endDate,
            CreatedAt = DateTime.UtcNow,
            Currencies = currencies.ToDictionary(c => c.Code, c => new Currency
            {
                Symbol = c.Symbol,
                Name = c.Code,
                ExpectedQuotaPerMember = c.ExpectedQuota
            })
        };

        var settings = await Storage.GetAppSettingsAsync();
        if (settings != null)
        {
            tripConfig.Members[settings.AuthorSlug] = new User
            {
                Name = settings.AuthorName,
                Email = "",
                Avatar = "👤"
            };
        }

        await Storage.SaveTripConfigAsync(tripSlug, tripConfig);
        
        registry.Trips[tripSlug] = new TripRegistryEntry { DriveFolderId = folder.Id };
        await Storage.SaveTripRegistryAsync(registry);

        Nav.NavigateTo($"/trip/{tripSlug}");
    }

    private class CurrencyViewModel
    {
        public string Code { get; set; } = "";
        public string Symbol { get; set; } = "";
        public decimal ExpectedQuota { get; set; }
    }
}

