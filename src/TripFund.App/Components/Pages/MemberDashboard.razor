@page "/trip/{tripSlug}/member/{memberSlug}"
@using TripFund.App.Models
@using TripFund.App.Services
@inject LocalTripStorageService Storage
@inject NavigationManager Nav

<div class="dashboard-page">
    <header class="app-header">
        <button class="icon-btn" @onclick='() => Nav.NavigateTo($"/trip/{tripSlug}")'>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </button>
        <h1 class="header-title">Dettaglio Partecipante</h1>
        <div class="spacer"></div>
    </header>

    @if (config == null || member == null)
    {
        <p class="status-text">Caricamento...</p>
    }
    else
    {
        <div class="member-profile">
            <h1 class="trip-name">@config.Name</h1>
            <div class="profile-avatar">@member.Avatar</div>
            <h2 class="profile-name">@member.Name</h2>
            <p class="profile-email">@member.Email</p>
        </div>

        <div class="currency-selector">
            @foreach (var curr in config.Currencies.Keys)
            {
                <button class="currency-pill @(selectedCurrency == curr ? "active" : "")" @onclick="() => SelectCurrency(curr)">
                    @curr
                </button>
            }
        </div>

        <main class="content">
            <div class="summary-card">
                <p class="summary-label">Totale versato</p>
                <h2 class="summary-total">@FormatCurrency(totalContributed, selectedCurrency)</h2>
                <p class="summary-sub">Totale rimasto: <strong>@FormatCurrency(remainingBalance, selectedCurrency)</strong></p>
                
                <div class="progress-container">
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: @(progressPercentage)%"></div>
                    </div>
                    <div class="progress-labels">
                        <span>@FormatCurrency(totalContributed, selectedCurrency)</span>
                        <span>Quota prevista: @FormatCurrency(targetAmount, selectedCurrency)</span>
                    </div>
                </div>
            </div>

            <div class="quick-actions">
                <button class="action-btn contribute-btn" @onclick='() => Nav.NavigateTo($"/trip/{tripSlug}/add-contribution?member={memberSlug}&currency={selectedCurrency}")'>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Registra Versamento
                </button>
            </div>

            <div class="section-container">
                <h3 class="section-title">Transazioni utente</h3>
                <div class="transactions-list">
                    @if (!userTransactions.Any())
                    {
                        <p class="empty-text">Nessuna transazione per questo utente.</p>
                    }
                    @foreach (var t in userTransactions.OrderByDescending(x => x.OriginalTx.Date))
                    {
                        <div class="transaction-row" @onclick='() => Nav.NavigateTo($"/trip/{tripSlug}/transaction/{t.OriginalTx.Id}")'>
                            <div class="transaction-icon @(t.OriginalTx.Type == "expense" ? "expense-icon" : "contrib-icon")">
                                @if(t.OriginalTx.Type == "expense")
                                {
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"></polyline><polyline points="17 18 23 18 23 12"></polyline></svg>
                                }
                                else
                                {
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                                }
                            </div>
                            <div class="transaction-info">
                                <div class="transaction-desc">@(string.IsNullOrWhiteSpace(t.OriginalTx.Description) ? (t.OriginalTx.Type == "expense" ? "Spesa" : "Versamento") : t.OriginalTx.Description)</div>
                                <div class="transaction-date">@t.OriginalTx.Date.ToString("g") • @t.OriginalTx.Author</div>
                            </div>
                            <div class="transaction-amount @(t.OriginalTx.Type == "expense" ? "negative" : "positive")">
                                @(t.OriginalTx.Type == "expense" ? "-" : "+")@FormatCurrency(t.UserAmount, t.OriginalTx.Currency)
                            </div>
                        </div>
                    }
                </div>
            </div>
        </main>
    }
</div>

@code {
    [Parameter] public string tripSlug { get; set; } = "";
    [Parameter] public string memberSlug { get; set; } = "";
    
    private TripConfig? config;
    private User? member;
    private List<Transaction> allTransactions = new();
    private List<UserTransactionItem> userTransactions = new();
    
    private string selectedCurrency = "";
    
    private decimal totalContributed = 0;
    private decimal remainingBalance = 0;
    private decimal targetAmount = 0;
    private double progressPercentage = 0;

    protected override async Task OnInitializedAsync()
    {
        config = await Storage.GetTripConfigAsync(tripSlug);
        if (config != null)
        {
            if (config.Members.TryGetValue(memberSlug, out var m))
            {
                member = m;
            }
            if (config.Currencies.Any())
            {
                selectedCurrency = config.Currencies.Keys.First();
            }
            allTransactions = await Storage.GetTransactionsAsync(tripSlug);
            CalculateStats();
        }
    }

    private void SelectCurrency(string currencyCode)
    {
        selectedCurrency = currencyCode;
        CalculateStats();
    }

    private void CalculateStats()
    {
        if (config == null || member == null || string.IsNullOrEmpty(selectedCurrency)) return;

        var currencyConfig = config.Currencies.ContainsKey(selectedCurrency) ? config.Currencies[selectedCurrency] : null;
        if (currencyConfig == null) return;

        targetAmount = currencyConfig.ExpectedQuotaPerMember;

        var currentCurrencyTx = allTransactions.Where(t => t.Currency == selectedCurrency).ToList();
        
        userTransactions.Clear();
        totalContributed = 0;
        decimal mExpenses = 0;

        foreach (var t in currentCurrencyTx)
        {
            if (t.Split.TryGetValue(memberSlug, out decimal amount) && amount > 0)
            {
                userTransactions.Add(new UserTransactionItem { OriginalTx = t, UserAmount = amount });
                
                if (t.Type == "contribution") totalContributed += amount;
                else if (t.Type == "expense") mExpenses += amount;
            }
        }

        remainingBalance = totalContributed - mExpenses;
        progressPercentage = targetAmount > 0 ? Math.Min(100, (double)(totalContributed / targetAmount * 100)) : 0;
    }

    private string FormatCurrency(decimal amount, string currencyCode)
    {
        if (config != null && config.Currencies.TryGetValue(currencyCode, out var c))
        {
            string format = c.Decimals > 0 ? "N" + c.Decimals : "N0";
            return $"{c.Symbol} {amount.ToString(format)}";
        }
        return $"{amount:N2} {currencyCode}";
    }

    private class UserTransactionItem
    {
        public Transaction OriginalTx { get; set; } = new();
        public decimal UserAmount { get; set; }
    }
}

