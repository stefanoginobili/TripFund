@page "/trip/{tripSlug}/edit"
@using TripFund.App.Models
@using TripFund.App.Services
@using TripFund.App.Utilities
@inject LocalTripStorageService Storage
@inject NavigationManager Nav
@inject IAlertService Alerts

<div class="edit-trip-page">
    <header class="app-header">
        <button class="icon-btn" @onclick='() => Nav.NavigateTo($"/trip/{tripSlug}")'>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#20563C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </button>
        <h1 class="header-title">Modifica Viaggio</h1>
        <button class="icon-btn" @onclick="HandleSave">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#20563C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
        </button>
    </header>

    @if (config == null)
    {
        <div class="loading-container">
            <p>Caricamento...</p>
        </div>
    }
    else
    {
        <main class="content">
            <!-- GENERAL INFO SECTION -->
            <section class="info-section">
                <h3 class="section-header">INFORMAZIONI GENERALI</h3>
                
                <div class="form-group">
                    <label>Nome Viaggio</label>
                    <div class="input-wrapper">
                        <input type="text" @bind="config.Name" placeholder="es. Patagonia 2026" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Slug Identificativo</label>
                    <div class="input-wrapper read-only">
                        <input type="text" value="@tripSlug" readonly />
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lock-icon">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </div>
                </div>

                <div class="row-group">
                    <div class="form-group flex-1">
                        <label>Data Inizio</label>
                        <div class="input-wrapper icon-right">
                            <input type="date" @bind="config.StartDate" />
                        </div>
                    </div>
                    <div class="form-group flex-1">
                        <label>Data Fine</label>
                        <div class="input-wrapper icon-right">
                            <input type="date" @bind="config.EndDate" />
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Descrizione</label>
                    <div class="input-wrapper">
                        <textarea @bind="config.Description" placeholder="Aggiungi una descrizione..." rows="3"></textarea>
                    </div>
                </div>
            </section>

            <!-- PARTICIPANTS SECTION -->
            <section class="info-section">
                <div class="section-header-row">
                    <h3 class="section-header">PARTECIPANTI</h3>
                    <span class="status-badge">@config.Members.Count ATTIVI</span>
                </div>

                <div class="members-list">
                    @foreach (var member in config.Members)
                    {
                        <div class="member-item">
                            <div class="member-avatar-display">@member.Value.Avatar</div>
                            <div class="member-details">
                                <span class="member-name-text">@member.Value.Name</span>
                                <span class="member-slug-text">@member.Key</span>
                            </div>
                            @if (member.Key != authorName)
                            {
                                <button class="delete-member-btn" @onclick="() => RemoveMember(member.Key)">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="18" y1="6" x2="6" y2="18"></line>
                                        <line x1="6" y1="6" x2="18" y2="18"></line>
                                    </svg>
                                </button>
                            }
                        </div>
                    }
                </div>

                <div class="add-member-section">
                    <h4 class="sub-header">AGGIUNGI NUOVO MEMBRO</h4>
                    <div class="add-member-grid">
                        <div class="avatar-selector" @onclick="ToggleEmojiPicker">
                            <span class="selected-avatar">@newMemberAvatar</span>
                            <div class="plus-badge">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                    <line x1="12" y1="5" x2="12" y2="19"></line>
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                            </div>

                            @if (showEmojiPicker)
                            {
                                <div class="emoji-picker-popover" @onclick:stopPropagation>
                                    <div class="emoji-grid">
                                        @foreach (var emoji in emojis)
                                        {
                                            <button class="emoji-btn @(newMemberAvatar == emoji ? "selected" : "")" @onclick="() => SelectEmoji(emoji)">
                                                @emoji
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="name-input-container">
                            <input type="text" placeholder="Nome" @bind="newMemberName" @oninput="OnNewMemberNameInput" />
                        </div>
                        <div class="slug-input-container">
                            <input type="text" placeholder="Slug (auto)" @bind="newMemberSlug" />
                        </div>
                        <div class="email-input-container">
                            <input type="email" placeholder="Email invito" @bind="newMemberEmail" />
                        </div>
                        <button class="add-btn-small" @onclick="AddMember">
                            Aggiungi
                        </button>
                    </div>
                </div>
            </section>

            <!-- CURRENCIES SECTION -->
            <section class="info-section">
                <h3 class="section-header">CASSE DEL VIAGGIO</h3>
                <div class="currencies-list">
                    @foreach (var curr in config.Currencies)
                    {
                        <div class="currency-pill @(curr.Value.ExpectedQuotaPerMember > 0 ? "active" : "")">
                            <div class="pill-content">
                                <div class="currency-details-pill">
                                    <span class="currency-label">@curr.Key (@curr.Value.Symbol)</span>
                                    <span class="currency-meta">Quota: @curr.Value.ExpectedQuotaPerMember.ToString("N0") • Dec: @curr.Value.Decimals</span>
                                </div>
                            </div>
                            <button class="remove-curr-btn" @onclick="() => RemoveCurrency(curr.Key)">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <line x1="18" y1="6" x2="6" y2="18"></line>
                                    <line x1="6" y1="6" x2="18" y2="18"></line>
                                </svg>
                            </button>
                        </div>
                    }
                </div>

                <div class="add-currency-dashed @(isAddingCurrency ? "expanded" : "")" @onclick="() => isAddingCurrency = true">
                    @if (!isAddingCurrency)
                    {
                        <div class="dashed-btn-content">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                <line x1="12" y1="5" x2="12" y2="19"></line>
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                            <span>Aggiungi Cassa</span>
                        </div>
                    }
                    else
                    {
                        <div class="add-currency-form" @onclick:stopPropagation>
                            <div class="form-row">
                                <input type="text" placeholder="Codice (EUR)" @bind="newCurrCode" class="small-input" />
                                <input type="text" placeholder="Simbolo (€)" @bind="newCurrSymbol" class="small-input" />
                            </div>
                            <div class="form-row">
                                <input type="number" placeholder="Quota" @bind="newCurrQuota" class="small-input quota-input" />
                                <input type="number" placeholder="Dec" @bind="newCurrDecimals" class="small-input decimals-input" style="max-width: 60px;" />
                                <div class="action-btns">
                                    <button class="confirm-add-btn" @onclick="AddCurrency">OK</button>
                                    <button class="cancel-add-btn" @onclick="() => isAddingCurrency = false">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <line x1="18" y1="6" x2="6" y2="18"></line>
                                            <line x1="6" y1="6" x2="18" y2="18"></line>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <div class="error-container">
                @if (!string.IsNullOrEmpty(error))
                {
                    <p class="error-text">@error</p>
                }
            </div>

            <button class="save-btn-large" @onclick="HandleSave">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                    <polyline points="17 21 17 13 7 13 7 21"></polyline>
                    <polyline points="7 3 7 8 15 8"></polyline>
                </svg>
                Salva Modifiche
            </button>

            <button class="delete-trip-btn" @onclick="HandleDelete">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                </svg>
                Elimina Viaggio dal dispositivo
            </button>
            <p class="delete-info">
                Questa azione rimuoverà i dati locali. Se il viaggio è sincronizzato, potrai recuperarlo effettuando nuovamente l'accesso.
            </p>
        </main>
    }
</div>

@code {
    [Parameter] public string tripSlug { get; set; } = "";

    private TripConfig? config;
    private string error = "";
    private string deviceId = "";
    private string authorName = "";

    private string newMemberName = "";
    private string newMemberSlug = "";
    private string newMemberEmail = "";
    private string newMemberAvatar = "👤";
    private bool showEmojiPicker = false;
    private string[] emojis = new[] { 
        "👤", "👨", "👩", "🧔", "👴", "👵", "👶", "🦁", "🐯", "🐼", "🐨", "🦊", 
        "🍕", "🍔", "🍦", "🍩", "🍷", "🍺", "☕", "⚽", "🏀", "🎮", "🚗", "✈️", 
        "🏖️", "🏔️", "🗼", "🗽", "🌈", "🔥", "✨", "❤️", "🎒", "📸", "🗺️", "⛺" 
    };

    private string newCurrCode = "";
    private string newCurrSymbol = "";
    private decimal newCurrQuota = 0;
    private int newCurrDecimals = 2;
    private bool isAddingCurrency = false;

    protected override async Task OnInitializedAsync()
    {
        config = await Storage.GetTripConfigAsync(tripSlug);
        var settings = await Storage.GetAppSettingsAsync();
        deviceId = settings?.DeviceId ?? "";
        authorName = settings?.AuthorName ?? "";
    }

    private void ToggleEmojiPicker() => showEmojiPicker = !showEmojiPicker;
    
    private void SelectEmoji(string emoji)
    {
        newMemberAvatar = emoji;
        showEmojiPicker = false;
    }

    private void OnNewMemberNameInput(ChangeEventArgs e)
    {
        newMemberName = e.Value?.ToString() ?? "";
        newMemberSlug = SlugUtility.GenerateSlug(newMemberName);
    }

    private void AddMember()
    {
        if (config == null) return;
        if (string.IsNullOrWhiteSpace(newMemberSlug)) { error = "Lo slug è obbligatorio."; return; }
        if (config.Members.ContainsKey(newMemberSlug))
        {
            error = "Partecipante già presente.";
            return;
        }

        config.Members[newMemberSlug] = new User
        {
            Name = newMemberName,
            Email = newMemberEmail,
            Avatar = string.IsNullOrWhiteSpace(newMemberAvatar) ? "👤" : newMemberAvatar
        };

        newMemberName = "";
        newMemberSlug = "";
        newMemberEmail = "";
        newMemberAvatar = "👤";
        error = "";
    }

    private void RemoveMember(string slug)
    {
        config?.Members.Remove(slug);
    }

    private void AddCurrency()
    {
        if (config == null || string.IsNullOrWhiteSpace(newCurrCode)) return;
        string code = newCurrCode.ToUpperInvariant();
        if (config.Currencies.ContainsKey(code))
        {
            error = "Valuta già presente.";
            return;
        }

        config.Currencies[code] = new Currency
        {
            Symbol = string.IsNullOrWhiteSpace(newCurrSymbol) ? code : newCurrSymbol,
            Name = code,
            Decimals = newCurrDecimals,
            ExpectedQuotaPerMember = newCurrQuota
        };

        newCurrCode = "";
        newCurrSymbol = "";
        newCurrQuota = 0;
        newCurrDecimals = 2;
        error = "";
        isAddingCurrency = false;
    }

    private void RemoveCurrency(string code)
    {
        config?.Currencies.Remove(code);
    }

    private async Task HandleSave()
    {
        if (config == null) return;
        if (string.IsNullOrWhiteSpace(config.Name)) { error = "Il nome è obbligatorio."; return; }
        if (config.Currencies.Count == 0) { error = "Aggiungi almeno una valuta."; return; }

        var settings = await Storage.GetAppSettingsAsync();
        await Storage.SaveTripConfigAsync(tripSlug, config, settings?.DeviceId ?? "unknown");
        Nav.NavigateTo($"/trip/{tripSlug}");
    }

    private async Task HandleDelete()
    {
        bool confirm = await Alerts.ConfirmAsync(
            "Elimina Viaggio",
            "Sei sicuro di voler eliminare questo viaggio dal dispositivo? I dati su Google Drive rimarranno intatti.",
            "Elimina",
            "Annulla");

        if (confirm)
        {
            await Storage.DeleteTripAsync(tripSlug);
            Nav.NavigateTo("/");
        }
    }
}

