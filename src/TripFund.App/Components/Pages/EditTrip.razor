@page "/trip/{tripSlug}/edit"
@using TripFund.App.Models
@using TripFund.App.Services
@using TripFund.App.Utilities
@inject LocalTripStorageService Storage
@inject NavigationManager Nav

<div class="header">
    <button class="back-btn" @onclick='() => Nav.NavigateTo($"/trip/{tripSlug}")'>←</button>
    <h1 class="page-title">Modifica Viaggio</h1>
</div>

@if (config == null)
{
    <p class="p-3">Caricamento...</p>
}
else
{
    <div class="form-container p-3">
        <div class="mb-3">
            <label class="form-label">Slug (Sola lettura)</label>
            <input type="text" class="form-control" value="@tripSlug" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">Nome Viaggio</label>
            <input type="text" class="form-control" @bind="config.Name" />
        </div>

        <div class="mb-3">
            <label class="form-label">Descrizione</label>
            <textarea class="form-control" @bind="config.Description"></textarea>
        </div>

        <div class="row mb-3">
            <div class="col">
                <label class="form-label">Data Inizio</label>
                <input type="date" class="form-control" @bind="config.StartDate" />
            </div>
            <div class="col">
                <label class="form-label">Data Fine</label>
                <input type="date" class="form-control" @bind="config.EndDate" />
            </div>
        </div>

        <hr />

        <div class="section-title">Partecipanti</div>
        @foreach (var member in config.Members)
        {
            <div class="member-row mb-2 p-2 border rounded">
                <div class="d-flex align-items-center gap-2">
                    <input type="text" class="form-control form-control-sm avatar-input" @bind="member.Value.Avatar" style="width: 50px;" />
                    <div class="flex-grow-1">
                        <input type="text" class="form-control form-control-sm mb-1" @bind="member.Value.Name" placeholder="Nome" />
                        <input type="text" class="form-control form-control-sm mb-1" value="@member.Key" readonly placeholder="Slug" />
                        <input type="email" class="form-control form-control-sm" @bind="member.Value.Email" placeholder="Email" />
                    </div>
                    @if (member.Key != authorSlug)
                    {
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveMember(member.Key)">🗑️</button>
                    }
                </div>
            </div>
        }

        <div class="add-member border rounded p-2 mb-4 bg-light">
            <div class="d-flex align-items-center gap-2">
                <input type="text" class="form-control form-control-sm avatar-input" @bind="newMemberAvatar" style="width: 50px;" placeholder="👤" />
                <div class="flex-grow-1">
                    <input type="text" class="form-control form-control-sm mb-1" placeholder="Nome" @bind="newMemberName" @oninput="OnNewMemberNameInput" />
                    <input type="text" class="form-control form-control-sm mb-1" placeholder="Slug (modificabile)" @bind="newMemberSlug" />
                    <input type="email" class="form-control form-control-sm" placeholder="Email" @bind="newMemberEmail" />
                </div>
                <button class="btn btn-sm btn-primary" @onclick="AddMember">Aggiungi</button>
            </div>
        </div>

        <hr />

        <div class="section-title">Valute</div>
        @foreach (var curr in config.Currencies)
        {
            <div class="currency-row mb-2 p-2 border rounded">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <strong>@curr.Key (@curr.Value.Symbol)</strong>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveCurrency(curr.Key)">Rimuovi</button>
                </div>
                <div class="row">
                    <div class="col">
                        <label class="small">Quota prevista a persona</label>
                        <input type="number" class="form-control form-control-sm" @bind="curr.Value.ExpectedQuotaPerMember" />
                    </div>
                </div>
            </div>
        }

        <div class="add-currency border rounded p-2 mb-4 bg-light">
            <div class="row g-2">
                <div class="col-3">
                    <input type="text" class="form-control form-control-sm" placeholder="Codice" @bind="newCurrCode" />
                </div>
                <div class="col-2">
                    <input type="text" class="form-control form-control-sm" placeholder="Simbolo" @bind="newCurrSymbol" />
                </div>
                <div class="col">
                    <input type="number" class="form-control form-control-sm" placeholder="Quota" @bind="newCurrQuota" />
                </div>
                <div class="col-auto">
                    <button class="btn btn-sm btn-primary" @onclick="AddCurrency">Aggiungi</button>
                </div>
            </div>
        </div>

        <div class="error-message mb-3 text-danger">@error</div>

        <button class="btn btn-success w-100 py-3 mb-4" @onclick="HandleSave">
            Salva Modifiche
        </button>

        <div class="danger-zone border border-danger rounded p-3 mb-5">
            <h5 class="text-danger">Zona Pericolosa</h5>
            <p class="small text-muted">L'eliminazione rimuoverà il viaggio solo da questo dispositivo. I dati su Google Drive rimarranno intatti.</p>
            <button class="btn btn-danger w-100" @onclick="HandleDelete">
                Elimina Viaggio
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public string tripSlug { get; set; } = "";

    private TripConfig? config;
    private string error = "";
    private string authorSlug = "";

    private string newMemberName = "";
    private string newMemberSlug = "";
    private string newMemberEmail = "";
    private string newMemberAvatar = "👤";

    private string newCurrCode = "";
    private string newCurrSymbol = "";
    private decimal newCurrQuota = 0;

    protected override async Task OnInitializedAsync()
    {
        config = await Storage.GetTripConfigAsync(tripSlug);
        var settings = await Storage.GetAppSettingsAsync();
        authorSlug = settings?.AuthorSlug ?? "";
    }

    private void OnNewMemberNameInput(ChangeEventArgs e)
    {
        newMemberName = e.Value?.ToString() ?? "";
        newMemberSlug = SlugUtility.GenerateSlug(newMemberName);
    }

    private void AddMember()
    {
        if (config == null) return;
        if (string.IsNullOrWhiteSpace(newMemberSlug)) return;
        if (config.Members.ContainsKey(newMemberSlug))
        {
            error = "Partecipante già presente.";
            return;
        }

        config.Members[newMemberSlug] = new User
        {
            Name = newMemberName,
            Email = newMemberEmail,
            Avatar = string.IsNullOrWhiteSpace(newMemberAvatar) ? "👤" : newMemberAvatar
        };

        newMemberName = "";
        newMemberSlug = "";
        newMemberEmail = "";
        newMemberAvatar = "👤";
        error = "";
    }

    private void RemoveMember(string slug)
    {
        config?.Members.Remove(slug);
    }

    private void AddCurrency()
    {
        if (config == null || string.IsNullOrWhiteSpace(newCurrCode)) return;
        string code = newCurrCode.ToUpperInvariant();
        if (config.Currencies.ContainsKey(code))
        {
            error = "Valuta già presente.";
            return;
        }

        config.Currencies[code] = new Currency
        {
            Symbol = string.IsNullOrWhiteSpace(newCurrSymbol) ? code : newCurrSymbol,
            Name = code,
            ExpectedQuotaPerMember = newCurrQuota
        };

        newCurrCode = "";
        newCurrSymbol = "";
        newCurrQuota = 0;
        error = "";
    }

    private void RemoveCurrency(string code)
    {
        config?.Currencies.Remove(code);
    }

    private async Task HandleSave()
    {
        if (config == null) return;
        if (string.IsNullOrWhiteSpace(config.Name)) { error = "Il nome è obbligatorio."; return; }
        if (config.Currencies.Count == 0) { error = "Aggiungi almeno una valuta."; return; }

        await Storage.SaveTripConfigAsync(tripSlug, config);
        Nav.NavigateTo($"/trip/{tripSlug}");
    }

    private async Task HandleDelete()
    {
        // Simple confirmation would be better but for now we just delete as requested
        var registry = await Storage.GetTripRegistryAsync();
        if (registry.Trips.ContainsKey(tripSlug))
        {
            registry.Trips.Remove(tripSlug);
            await Storage.SaveTripRegistryAsync(registry);
        }

        var tripDir = Path.Combine(FileSystem.AppDataDirectory, tripSlug);
        if (Directory.Exists(tripDir))
        {
            Directory.Delete(tripDir, true);
        }

        Nav.NavigateTo("/");
    }
}

<style>
    .header {
        display: flex;
        align-items: center;
        padding: 1rem;
        border-bottom: 1px solid #eee;
    }
    .back-btn {
        background: none;
        border: none;
        font-size: 1.5rem;
        margin-right: 1rem;
    }
    .page-title {
        font-size: 1.25rem;
        font-weight: bold;
        margin: 0;
    }
    .section-title {
        font-weight: bold;
        margin-bottom: 0.5rem;
    }
    .avatar-input {
        text-align: center;
        font-size: 1.2rem;
    }
</style>
