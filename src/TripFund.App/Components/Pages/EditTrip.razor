@page "/trip/{tripSlug}/edit"

<NavigationLock ConfirmExternalNavigation="@HasChanges()" OnBeforeInternalNavigation="HandleBeforeInternalNavigation" />

<div class="app-page">
    <header class="app-header">
        <button class="icon-btn" @onclick="GoBack">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#20563C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </button>
        <h1 class="header-title">Modifica Viaggio</h1>
        <div class="header-actions">
            <VibeMenu>
                <Trigger>
                    <button class="icon-btn">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#20563C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="5" r="1"></circle>
                            <circle cx="12" cy="12" r="1"></circle>
                            <circle cx="12" cy="19" r="1"></circle>
                        </svg>
                    </button>
                </Trigger>
                <ChildContent>
                    <button class="dropdown-item-vibe text-danger" @onclick="HandleDelete">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        </svg>
                        Elimina Viaggio
                    </button>
                </ChildContent>
            </VibeMenu>
        </div>
    </header>

    @if (config == null)
    {
        <LoadingSpinner />
    }
    else
    {
        <div class="content">
            <!-- GENERAL INFO SECTION -->
            <GeneralInfoForm @bind-Name="config.Name"
                             @bind-Slug="tripSlug"
                             @bind-StartDate="config.StartDate"
                             @bind-EndDate="config.EndDate"
                             @bind-Description="config.Description"
                             IsCreate="false"
                             IsReadonly="@isReadonly" />

            <!-- CURRENCIES SECTION -->
            <CurrenciesForm @bind-Currencies="config.Currencies" IsReadonly="@isReadonly" />

            <!-- CATEGORIES SECTION -->
            <CategoriesForm @bind-Categories="config.Categories.Expenses" IsReadonly="@isReadonly" />

            <!-- PARTICIPANTS SECTION -->
            <section class="info-section">
                <h3 class="section-header-vibe">PARTECIPANTI</h3>

                <div class="members-list">
                    <SortableList TItem="KeyValuePair<string, User>" 
                                  Items="config.Members" 
                                  KeySelector="i => i.Key"
                                  IsReadonly="isReadonly" 
                                  OnReorder="HandleMemberReorder">
                        <ItemTemplate Context="member">
                            @if (editingMemberSlug == member.Key)
                            {
                                <div id="edit-member-form" class="member-edit-container w-100">
                                    <div class="new-member-form">

                                        <div class="new-member-header">
                                            <span class="header-icon">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M12 20h9"></path>
                                                    <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                                                </svg>
                                            </span>
                                            <span class="new-member-title">Modifica Partecipante</span>
                                        </div>

                                        <div class="member-form-row">
                                            <div class="avatar-col">
                                                <VibeMenu>
                                                    <Trigger>
                                                        <div class="avatar-input-box" @onclick="ToggleEmojiPicker">
                                                            <span>@newMemberAvatar</span>
                                                        </div>
                                                    </Trigger>
                                                    <ChildContent>
                                                        <div class="emoji-picker-container">
                                                            <div class="emoji-grid">
                                                                @foreach (var emoji in emojis)
                                                                {
                                                                    <button class="emoji-btn @(newMemberAvatar == emoji ? "selected" : "")" @onclick="() => SelectEmoji(emoji)">
                                                                        @emoji
                                                                    </button>
                                                                }
                                                            </div>
                                                        </div>
                                                    </ChildContent>
                                                </VibeMenu>
                                            </div>
                                            <div class="name-col">
                                                <label>NOME</label>
                                                <input type="text" class="form-control-vibe" @bind="newMemberName" @onblur="TrimMemberName" />
                                            </div>
                                        </div>

                                        <div class="member-form-full-row">
                                            <label>EMAIL</label>
                                            <input type="email" class="form-control-vibe" @bind="newMemberEmail" @onblur="TrimMemberEmail" />
                                        </div>

                                        <div class="member-form-footer">
                                            <div class="slug-col">
                                                <label>SLUG</label>
                                                <input type="text" value="@newMemberSlug" readonly class="form-control-vibe readonly-input" />
                                            </div>
                                            <div class="action-buttons">
                                                <button class="confirm-btn" @onclick="AddMember">
                                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                                        <polyline points="20 6 9 17 4 12"></polyline>
                                                    </svg>
                                                </button>
                                                <button class="cancel-btn" @onclick="CancelMemberEdit">
                                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <line x1="18" y1="6" x2="6" y2="18"></line>
                                                        <line x1="6" y1="6" x2="18" y2="18"></line>
                                                    </svg>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="member-item-content">
                                    <div class="member-avatar-display">@member.Value.Avatar</div>
                                    <div class="member-details">
                                        <span class="member-name-text">@member.Value.Name</span>
                                    </div>
                                </div>
                            }
                        </ItemTemplate>
                        <MenuTemplate Context="member">
                            <button class="dropdown-item-vibe" @onclick="async () => { await StartEditMember(member.Key, member.Value); }">
                                Modifica
                            </button>
                            <button class="dropdown-item-vibe text-danger" @onclick="async () => { await ConfirmDeleteMember(member.Key); }">
                                Elimina
                            </button>
                        </MenuTemplate>
                    </SortableList>
                </div>

                @if (!isReadonly)
                {
                    <div class="add-item-dashed @(isAddingMember ? "expanded" : "")" @onclick="() => { if(!isAddingMember) { CancelMemberEdit(); isAddingMember = true; shouldScrollMember = true; } }">
                        @if (!isAddingMember)
                        {
                            <div class="dashed-btn-content">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <line x1="12" y1="5" x2="12" y2="19"></line>
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                                <span>Aggiungi Partecipante</span>
                            </div>
                        }
                        else
                        {
                            <div id="new-member-form" class="new-member-form" @onclick:stopPropagation>
                                <div class="new-member-header">
                                    <span class="header-icon">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="12" y1="5" x2="12" y2="19"></line>
                                            <line x1="5" y1="12" x2="19" y2="12"></line>
                                        </svg>
                                    </span>
                                    <span class="new-member-title">Nuovo Partecipante</span>
                                </div>

                                <div class="member-form-row">
                                    <div class="avatar-col">
                                        <VibeMenu>
                                            <Trigger>
                                                <div class="avatar-input-box" @onclick="ToggleEmojiPicker">
                                                    <span>@newMemberAvatar</span>
                                                </div>
                                            </Trigger>
                                            <ChildContent>
                                                <div class="emoji-picker-container">
                                                    <div class="emoji-grid">
                                                        @foreach (var emoji in emojis)
                                                        {
                                                            <button class="emoji-btn @(newMemberAvatar == emoji ? "selected" : "")" @onclick="() => SelectEmoji(emoji)">
                                                                @emoji
                                                            </button>
                                                        }
                                                    </div>
                                                </div>
                                            </ChildContent>
                                        </VibeMenu>
                                    </div>
                                    <div class="name-col">
                                        <label>NOME</label>
                                        <input type="text" class="form-control-vibe" @bind="newMemberName" @oninput="OnNewMemberNameInput" @onblur="TrimMemberName" />
                                    </div>
                                </div>

                                <div class="member-form-full-row">
                                    <label>EMAIL</label>
                                    <input type="email" class="form-control-vibe" @bind="newMemberEmail" @onblur="TrimMemberEmail" />
                                </div>

                                <div class="member-form-footer">
                                    <div class="slug-col">
                                        <label>SLUG</label>
                                        <input type="text" class="form-control-vibe" @bind="newMemberSlug" @onblur="TrimMemberSlug" />
                                    </div>
                                    <div class="action-buttons">
                                        <button class="confirm-btn" @onclick="AddMember">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="20 6 9 17 4 12"></polyline>
                                            </svg>
                                        </button>
                                        <button class="cancel-btn" @onclick="() => isAddingMember = false">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                                <line x1="6" y1="6" x2="18" y2="18"></line>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>

            <div class="error-container">
                @if (!string.IsNullOrEmpty(error))
                {
                    <p class="error-text">@error</p>
                }
            </div>

            <button class="btn-vibe btn-primary-vibe" @onclick="HandleSave" disabled="@(isReadonly || !HasChanges())">Salva</button>
        </div>
    }
</div>

<style>
    .me-2 { margin-right: 0.5rem; }

    .content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .members-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    .member-edit-container {
        border: 2px dashed #D1D9E0;
        border-radius: 32px;
        background-color: #FFFFFF;
        margin-bottom: 0.75rem;
    }

    .new-member-form {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        text-align: left;
        width: 100%;
    }

    .new-member-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: #1A3C2F;
        margin-bottom: 0.5rem;
    }

    .header-icon {
        display: flex;
        color: #20563C;
    }

    .new-member-title {
        font-weight: 700;
        font-size: 1rem;
    }

    .member-form-row {
        display: flex;
        gap: 1rem;
        align-items: flex-end;
    }

    .avatar-col {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .avatar-col label, .name-col label, .member-form-full-row label, .slug-col label {
        font-size: 0.7rem;
        font-weight: 700;
        color: #8E9AAF;
        letter-spacing: 0.05em;
    }

    .avatar-input-box {
        width: 56px;
        height: 56px;
        background-color: #F1F3F5;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        cursor: pointer;
    }

    .name-col {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .member-form-full-row {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .member-form-footer {
        display: flex;
        align-items: flex-end;
        gap: 1rem;
    }

    .slug-col {
        flex: 1;
        display: flex;
        .member-actions {
            display: flex;
            gap: 0.5rem;
        }

        .emoji-picker-container { width: 100%; max-width: calc(100vw - 4rem); }

        flex-direction: column;
        width: 100%;
        max-width: calc(100vw - 3rem);
    }

    .more-actions-container {
        position: relative;
        display: flex;
        align-items: center;
    }

    .action-trigger {
        display: flex;
        align-items: center;
        color: #ADB5BD;
        cursor: pointer;
        padding: 0.5rem;
        margin: -0.5rem;
    }

    .emoji-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 0.5rem;
        max-height: 300px;
        overflow-y: auto;
    }

    .emoji-btn {
        background: none;
        border: none;
        font-size: 1.5rem;
        padding: 0.25rem;
        border-radius: 8px;
        transition: background-color 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
    }

    .emoji-btn:hover {
        background-color: #F0F2F5;
    }

    .emoji-btn.selected {
        background-color: #D6EDE2;
    }

    .error-container { text-align: center; }
    .error-text { color: #DC3545; font-size: 0.85rem; font-weight: 600; }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
    }

    .confirm-btn, .cancel-btn {
        background-color: #F1F3F5;
        border: none;
        border-radius: 12px;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .confirm-btn { color: #20563C; }
    .cancel-btn { color: #6C757D; }

    .confirm-btn:active { background-color: #D6EDE2; }
    .cancel-btn:active { background-color: #E9ECEF; }

    .dropdown-item-vibe.disabled {
        opacity: 0.5;
        cursor: default;
        pointer-events: none;
    }
</style>
