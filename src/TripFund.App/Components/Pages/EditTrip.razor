@page "/trip/{tripSlug}/edit"
@using TripFund.App.Models
@using TripFund.App.Services
@using TripFund.App.Utilities
@inject LocalTripStorageService Storage
@inject NavigationManager Nav
@inject IAlertService Alerts

<div class="edit-trip-page">
    <header class="app-header">
        <button class="icon-btn" @onclick='() => Nav.NavigateTo($"/trip/{tripSlug}")'>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#20563C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </button>
        <h1 class="header-title">Modifica Viaggio</h1>
        <div class="header-actions">
            <button class="icon-btn" @onclick="ToggleHeaderMenu">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#20563C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="5" r="1"></circle>
                    <circle cx="12" cy="12" r="1"></circle>
                    <circle cx="12" cy="19" r="1"></circle>
                </svg>
            </button>
            @if (isHeaderMenuOpen)
            {
                <div class="header-dropdown">
                    <div class="dropdown-item-custom text-danger" @onclick="HandleDelete">
                        Elimina
                    </div>
                </div>
            }
        </div>
    </header>

    @if (config == null)
    {
        <div class="loading-container">
            <p>Caricamento...</p>
        </div>
    }
    else
    {
        <main class="content">
            <!-- GENERAL INFO SECTION -->
            <section class="info-section">
                <h3 class="section-header">INFORMAZIONI GENERALI</h3>
                
                <div class="form-group">
                    <label>Nome Viaggio</label>
                    <div class="input-wrapper">
                        <input type="text" @bind="config.Name" placeholder="es. Patagonia 2026" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Slug</label>
                    <div class="input-wrapper read-only">
                        <input type="text" value="@tripSlug" readonly />
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lock-icon">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </div>
                </div>

                <div class="row-group">
                    <div class="form-group flex-1">
                        <label>Data Inizio</label>
                        <div class="date-picker-wrapper">
                            <span class="date-display">@FormatDate(config.StartDate)</span>
                            <input type="date" @bind="config.StartDate" class="native-date-input" />
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="calendar-icon">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                        </div>
                    </div>
                    <div class="form-group flex-1">
                        <label>Data Fine</label>
                        <div class="date-picker-wrapper">
                            <span class="date-display">@FormatDate(config.EndDate)</span>
                            <input type="date" @bind="config.EndDate" class="native-date-input" />
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="calendar-icon">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Descrizione</label>
                    <div class="input-wrapper">
                        <textarea @bind="config.Description" placeholder="Aggiungi una descrizione..." rows="3"></textarea>
                    </div>
                </div>
            </section>

            <!-- PARTICIPANTS SECTION -->
            <section class="info-section">
                <div class="section-header-row">
                    <h3 class="section-header">PARTECIPANTI</h3>
                    <span class="status-badge">@config.Members.Count ATTIVI</span>
                </div>

                <div class="members-list">
                    @foreach (var member in config.Members)
                    {
                        @if (editingMemberSlug == member.Key)
                        {
                            <div class="member-edit-container">
                                <div class="new-member-form">
                                    <div class="new-member-header">
                                        <span class="user-plus-icon">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                                <circle cx="8.5" cy="7" r="4"></circle>
                                                <line x1="20" y1="8" x2="20" y2="14"></line>
                                                <line x1="17" y1="11" x2="23" y2="11"></line>
                                            </svg>
                                        </span>
                                        <span class="new-member-title">Modifica Partecipante</span>
                                    </div>

                                    <div class="member-form-row">
                                        <div class="avatar-col">
                                            <label>AVATAR</label>
                                            <div class="avatar-input-box" @onclick="ToggleEmojiPicker">
                                                <span>@newMemberAvatar</span>
                                                @if (showEmojiPicker)
                                                {
                                                    <div class="emoji-picker-popover" @onclick:stopPropagation>
                                                        <div class="emoji-grid">
                                                            @foreach (var emoji in emojis)
                                                            {
                                                                <button class="emoji-btn @(newMemberAvatar == emoji ? "selected" : "")" @onclick="() => SelectEmoji(emoji)">
                                                                    @emoji
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                        <div class="name-col">
                                            <label>NOME</label>
                                            <input type="text" @bind="newMemberName" placeholder="Esempio: Andrea" />
                                        </div>
                                    </div>

                                    <div class="member-form-full-row">
                                        <label>EMAIL</label>
                                        <input type="email" @bind="newMemberEmail" placeholder="andrea@esempio.com" />
                                    </div>

                                    <div class="member-form-footer">
                                        <div class="slug-col">
                                            <label>SLUG</label>
                                            <input type="text" value="@newMemberSlug" readonly class="readonly-input-form" />
                                        </div>
                                        <div class="action-buttons">
                                            <button class="confirm-btn" @onclick="AddMember">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                                    <polyline points="20 6 9 17 4 12"></polyline>
                                                </svg>
                                            </button>
                                            <button class="cancel-btn" @onclick="CancelMemberEdit">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <line x1="18" y1="6" x2="6" y2="18"></line>
                                                    <line x1="6" y1="6" x2="18" y2="18"></line>
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="member-item">
                                <div class="member-avatar-display">@member.Value.Avatar</div>
                                <div class="member-details">
                                    <span class="member-name-text">@member.Value.Name</span>
                                    <span class="member-slug-text">@member.Key</span>
                                </div>
                                <div class="more-actions-container">
                                    <div class="action-trigger" @onclick="() => ToggleMemberMenu(member.Key)">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="5" r="1"></circle>
                                            <circle cx="12" cy="12" r="1"></circle>
                                            <circle cx="12" cy="19" r="1"></circle>
                                        </svg>
                                    </div>
                                    @if (openMenuMemberSlug == member.Key)
                                    {
                                        var keys = config.Members.Keys.ToList();
                                        int index = keys.IndexOf(member.Key);
                                        bool isFirst = index == 0;
                                        bool isLast = index == keys.Count - 1;

                                        <div class="actions-dropdown">
                                            <div class="dropdown-item-custom" @onclick="() => StartEditMember(member.Key, member.Value)">
                                                Modifica
                                            </div>
                                            <div class="dropdown-item-custom @(isFirst ? "disabled" : "")" @onclick="() => { if(!isFirst) MoveMemberUp(member.Key); }">
                                                Sposta su
                                            </div>
                                            <div class="dropdown-item-custom @(isLast ? "disabled" : "")" @onclick="() => { if(!isLast) MoveMemberDown(member.Key); }">
                                                Sposta giù
                                            </div>
                                            <div class="dropdown-item-custom text-danger" @onclick="() => ConfirmDeleteMember(member.Key)">
                                                Elimina
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="add-member-dashed @(isAddingMember ? "expanded" : "")" @onclick="() => isAddingMember = true">
                    @if (!isAddingMember)
                    {
                        <div class="dashed-btn-content">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                <line x1="12" y1="5" x2="12" y2="19"></line>
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                            <span>Aggiungi Partecipante</span>
                        </div>
                    }
                    else
                    {
                        <div class="new-member-form" @onclick:stopPropagation>
                            <div class="new-member-header">
                                <span class="user-plus-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                        <circle cx="8.5" cy="7" r="4"></circle>
                                        <line x1="20" y1="8" x2="20" y2="14"></line>
                                        <line x1="17" y1="11" x2="23" y2="11"></line>
                                    </svg>
                                </span>
                                <span class="new-member-title">Nuovo Partecipante</span>
                            </div>

                            <div class="member-form-row">
                                <div class="avatar-col">
                                    <label>AVATAR</label>
                                    <div class="avatar-input-box" @onclick="ToggleEmojiPicker">
                                        <span>@newMemberAvatar</span>
                                        @if (showEmojiPicker)
                                        {
                                            <div class="emoji-picker-popover" @onclick:stopPropagation>
                                                <div class="emoji-grid">
                                                    @foreach (var emoji in emojis)
                                                    {
                                                        <button class="emoji-btn @(newMemberAvatar == emoji ? "selected" : "")" @onclick="() => SelectEmoji(emoji)">
                                                            @emoji
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="name-col">
                                    <label>NOME</label>
                                    <input type="text" @bind="newMemberName" placeholder="Esempio: Andrea" @oninput="OnNewMemberNameInput" />
                                </div>
                            </div>

                            <div class="member-form-full-row">
                                <label>EMAIL</label>
                                <input type="email" @bind="newMemberEmail" placeholder="andrea@esempio.com" />
                            </div>

                            <div class="member-form-footer">
                                <div class="slug-col">
                                    <label>SLUG</label>
                                    <input type="text" @bind="newMemberSlug" placeholder="andrea-7890" />
                                </div>
                                <div class="action-buttons">
                                    <button class="confirm-btn" @onclick="AddMember">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="20 6 9 17 4 12"></polyline>
                                        </svg>
                                    </button>
                                    <button class="cancel-btn" @onclick="() => isAddingMember = false">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="18" y1="6" x2="6" y2="18"></line>
                                            <line x1="6" y1="6" x2="18" y2="18"></line>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- CURRENCIES SECTION -->
            <section class="info-section">
                <h3 class="section-header">CASSE DEL VIAGGIO</h3>
                <div class="currencies-list">
                    @foreach (var curr in config.Currencies)
                    {
                        @if (editingCurrencyCode == curr.Key)
                        {
                            <div class="currency-edit-container">
                                <div class="new-currency-form">
                                    <div class="new-currency-header">
                                        <span class="wallet-icon">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"></path>
                                                <path d="M4 6v12c0 1.1.9 2 2 2h14v-4"></path>
                                                <path d="M18 12a2 2 0 0 0-2 2c0 1.1.9 2 2 2h4v-4h-4z"></path>
                                            </svg>
                                        </span>
                                        <span class="new-currency-title">Modifica Cassa</span>
                                    </div>
                                    
                                    <div class="new-currency-grid">
                                        <div class="new-curr-col">
                                            <label>CODICE</label>
                                            <input type="text" value="@newCurrCode" readonly class="readonly-input-form" />
                                        </div>
                                        <div class="new-curr-col">
                                            <label>SIMBOLO</label>
                                            <input type="text" @bind="newCurrSymbol" placeholder="€" />
                                        </div>
                                        <div class="new-curr-col">
                                            <label>DECIMALI</label>
                                            <input type="number" @bind="newCurrDecimals" />
                                        </div>
                                    </div>
                                    
                                    <div class="new-currency-footer">
                                        <div class="new-curr-col quota-col">
                                            <label>QUOTA</label>
                                            <input type="number" @bind="newCurrQuota" placeholder="1000" />
                                        </div>
                                        <div class="action-buttons">
                                            <button class="confirm-btn" @onclick="AddCurrency">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                                    <polyline points="20 6 9 17 4 12"></polyline>
                                                </svg>
                                            </button>
                                            <button class="cancel-btn" @onclick="CancelCurrencyEdit">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <line x1="18" y1="6" x2="6" y2="18"></line>
                                                    <line x1="6" y1="6" x2="18" y2="18"></line>
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="currency-card">
                                <span class="currency-code">@curr.Key</span>
                                <div class="currency-value-container">
                                    <span class="currency-quota-value">@FormatCurrency(curr.Value.ExpectedQuotaPerMember, curr.Key)</span>
                                    <div class="more-actions-container">
                                        <div class="action-trigger" @onclick="() => ToggleCurrencyMenu(curr.Key)">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <circle cx="12" cy="5" r="1"></circle>
                                                <circle cx="12" cy="12" r="1"></circle>
                                                <circle cx="12" cy="19" r="1"></circle>
                                            </svg>
                                        </div>
                                        @if (openMenuCurrencyCode == curr.Key)
                                        {
                                            var keys = config.Currencies.Keys.ToList();
                                            int index = keys.IndexOf(curr.Key);
                                            bool isFirst = index == 0;
                                            bool isLast = index == keys.Count - 1;

                                            <div class="actions-dropdown">
                                                <div class="dropdown-item-custom" @onclick="() => StartEditCurrency(curr.Key, curr.Value)">
                                                    Modifica
                                                </div>
                                                <div class="dropdown-item-custom @(isFirst ? "disabled" : "")" @onclick="() => { if(!isFirst) MoveCurrencyUp(curr.Key); }">
                                                    Sposta su
                                                </div>
                                                <div class="dropdown-item-custom @(isLast ? "disabled" : "")" @onclick="() => { if(!isLast) MoveCurrencyDown(curr.Key); }">
                                                    Sposta giù
                                                </div>
                                                <div class="dropdown-item-custom text-danger" @onclick="() => ConfirmDeleteCurrency(curr.Key)">
                                                    Elimina
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="add-currency-dashed @(isAddingCurrency ? "expanded" : "")" @onclick="() => isAddingCurrency = true">
                    @if (!isAddingCurrency)
                    {
                        <div class="dashed-btn-content">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                <line x1="12" y1="5" x2="12" y2="19"></line>
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                            <span>Aggiungi Cassa</span>
                        </div>
                    }
                    else
                    {
                        <div class="new-currency-form" @onclick:stopPropagation>
                            <div class="new-currency-header">
                                <span class="wallet-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"></path>
                                        <path d="M4 6v12c0 1.1.9 2 2 2h14v-4"></path>
                                        <path d="M18 12a2 2 0 0 0-2 2c0 1.1.9 2 2 2h4v-4h-4z"></path>
                                    </svg>
                                </span>
                                <span class="new-currency-title">Nuova Cassa</span>
                            </div>
                            
                            <div class="new-currency-grid">
                                <div class="new-curr-col">
                                    <label>CODICE</label>
                                    <input type="text" @bind="newCurrCode" placeholder="EUR" />
                                </div>
                                <div class="new-curr-col">
                                    <label>SIMBOLO</label>
                                    <input type="text" @bind="newCurrSymbol" placeholder="€" />
                                </div>
                                <div class="new-curr-col">
                                    <label>DECIMALI</label>
                                    <input type="number" @bind="newCurrDecimals" />
                                </div>
                            </div>
                            
                            <div class="new-currency-footer">
                                <div class="new-curr-col quota-col">
                                    <label>QUOTA</label>
                                    <input type="number" @bind="newCurrQuota" placeholder="1000" />
                                </div>
                                <div class="action-buttons">
                                    <button class="confirm-btn" @onclick="AddCurrency">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="20 6 9 17 4 12"></polyline>
                                        </svg>
                                    </button>
                                    <button class="cancel-btn" @onclick="() => isAddingCurrency = false">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="18" y1="6" x2="6" y2="18"></line>
                                            <line x1="6" y1="6" x2="18" y2="18"></line>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <div class="error-container">
                @if (!string.IsNullOrEmpty(error))
                {
                    <p class="error-text">@error</p>
                }
            </div>

            <button class="save-btn-large" @onclick="HandleSave">Salva</button>
        </main>
    }
</div>

@code {
    [Parameter] public string tripSlug { get; set; } = "";

    private TripConfig? config;
    private string error = "";
    private string deviceId = "";
    private string authorName = "";

    private string newMemberName = "";
    private string newMemberSlug = "";
    private string newMemberEmail = "";
    private string newMemberAvatar = "👤";
    private bool showEmojiPicker = false;
    private bool isAddingMember = false;
    private string? openMenuMemberSlug = null;
    private string? editingMemberSlug = null;
    private string[] emojis = new[] { 
        "👤", "👨", "👩", "🧔", "👴", "👵", "👶", "🦁", "🐯", "🐼", "🐨", "🦊", 
        "🍕", "🍔", "🍦", "🍩", "🍷", "🍺", "☕", "⚽", "🏀", "🎮", "🚗", "✈️", 
        "🏖️", "🏔️", "🗼", "🗽", "🌈", "🔥", "✨", "❤️", "🎒", "📸", "🗺️", "⛺" 
    };

    private string newCurrCode = "";
    private string newCurrSymbol = "";
    private decimal newCurrQuota = 0;
    private int newCurrDecimals = 2;
    private bool isAddingCurrency = false;
    private string? openMenuCurrencyCode = null;
    private string? editingCurrencyCode = null;
    private bool isHeaderMenuOpen = false;

    private void ToggleHeaderMenu() => isHeaderMenuOpen = !isHeaderMenuOpen;

    protected override async Task OnInitializedAsync()
    {
        config = await Storage.GetTripConfigAsync(tripSlug);
        var settings = await Storage.GetAppSettingsAsync();
        deviceId = settings?.DeviceId ?? "";
        authorName = settings?.AuthorName ?? "";
    }

    private void ToggleEmojiPicker() => showEmojiPicker = !showEmojiPicker;
    
    private void SelectEmoji(string emoji)
    {
        newMemberAvatar = emoji;
        showEmojiPicker = false;
    }

    private void OnNewMemberNameInput(ChangeEventArgs e)
    {
        newMemberName = e.Value?.ToString() ?? "";
        newMemberSlug = SlugUtility.GenerateSlug(newMemberName);
    }

    private void AddMember()
    {
        if (config == null) return;
        if (string.IsNullOrWhiteSpace(newMemberSlug)) { error = "Lo slug è obbligatorio."; return; }
        
        // If not editing, check for duplicates
        if (editingMemberSlug == null && config.Members.ContainsKey(newMemberSlug))
        {
            error = "Partecipante già presente.";
            return;
        }

        config.Members[newMemberSlug] = new User
        {
            Name = newMemberName,
            Email = newMemberEmail,
            Avatar = string.IsNullOrWhiteSpace(newMemberAvatar) ? "👤" : newMemberAvatar
        };

        newMemberName = "";
        newMemberSlug = "";
        newMemberEmail = "";
        newMemberAvatar = "👤";
        error = "";
        isAddingMember = false;
        editingMemberSlug = null;
    }

    private void RemoveMember(string slug)
    {
        config?.Members.Remove(slug);
    }

    private void ToggleMemberMenu(string slug)
    {
        if (openMenuMemberSlug == slug) openMenuMemberSlug = null;
        else openMenuMemberSlug = slug;
    }

    private void StartEditMember(string slug, User m)
    {
        editingMemberSlug = slug;
        newMemberSlug = slug;
        newMemberName = m.Name;
        newMemberEmail = m.Email ?? "";
        newMemberAvatar = m.Avatar;
        openMenuMemberSlug = null;
    }

    private void CancelMemberEdit()
    {
        editingMemberSlug = null;
        newMemberSlug = "";
        newMemberName = "";
        newMemberEmail = "";
        newMemberAvatar = "👤";
    }

    private void MoveMemberUp(string slug)
    {
        if (config == null) return;
        var keys = config.Members.Keys.ToList();
        int index = keys.IndexOf(slug);
        if (index <= 0) return;

        var prevKey = keys[index - 1];
        var currentVal = config.Members[slug];
        var prevVal = config.Members[prevKey];

        var newDict = new Dictionary<string, User>();
        foreach (var key in keys)
        {
            if (key == prevKey) newDict[slug] = currentVal;
            else if (key == slug) newDict[prevKey] = prevVal;
            else newDict[key] = config.Members[key];
        }
        config.Members = newDict;
        openMenuMemberSlug = null;
    }

    private void MoveMemberDown(string slug)
    {
        if (config == null) return;
        var keys = config.Members.Keys.ToList();
        int index = keys.IndexOf(slug);
        if (index < 0 || index >= keys.Count - 1) return;

        var nextKey = keys[index + 1];
        var currentVal = config.Members[slug];
        var nextVal = config.Members[nextKey];

        var newDict = new Dictionary<string, User>();
        foreach (var key in keys)
        {
            if (key == slug) newDict[nextKey] = nextVal;
            else if (key == nextKey) newDict[slug] = currentVal;
            else newDict[key] = config.Members[key];
        }
        config.Members = newDict;
        openMenuMemberSlug = null;
    }

    private async Task ConfirmDeleteMember(string slug)
    {
        openMenuMemberSlug = null;
        bool confirm = await Alerts.ConfirmAsync(
            "Elimina Partecipante",
            $"Sei sicuro di voler eliminare {config?.Members[slug].Name}? Questa azione non può essere annullata.",
            "Elimina",
            "Annulla");

        if (confirm)
        {
            RemoveMember(slug);
        }
    }

    private void AddCurrency()
    {
        if (config == null || string.IsNullOrWhiteSpace(newCurrCode)) return;
        string code = newCurrCode.ToUpperInvariant();
        
        // If not editing, check for duplicates
        if (editingCurrencyCode == null && config.Currencies.ContainsKey(code))
        {
            error = "Valuta già presente.";
            return;
        }

        config.Currencies[code] = new Currency
        {
            Symbol = string.IsNullOrWhiteSpace(newCurrSymbol) ? code : newCurrSymbol,
            Name = code,
            Decimals = newCurrDecimals,
            ExpectedQuotaPerMember = newCurrQuota
        };

        newCurrCode = "";
        newCurrSymbol = "";
        newCurrQuota = 0;
        newCurrDecimals = 2;
        error = "";
        isAddingCurrency = false;
        editingCurrencyCode = null;
    }

    private void RemoveCurrency(string code)
    {
        config?.Currencies.Remove(code);
    }

    private void MoveCurrencyUp(string code)
    {
        if (config == null) return;
        var keys = config.Currencies.Keys.ToList();
        int index = keys.IndexOf(code);
        if (index <= 0) return;

        var prevKey = keys[index - 1];
        var currentVal = config.Currencies[code];
        var prevVal = config.Currencies[prevKey];

        var newDict = new Dictionary<string, Currency>();
        foreach (var key in keys)
        {
            if (key == prevKey) newDict[code] = currentVal;
            else if (key == code) newDict[prevKey] = prevVal;
            else newDict[key] = config.Currencies[key];
        }
        config.Currencies = newDict;
        openMenuCurrencyCode = null;
    }

    private void MoveCurrencyDown(string code)
    {
        if (config == null) return;
        var keys = config.Currencies.Keys.ToList();
        int index = keys.IndexOf(code);
        if (index < 0 || index >= keys.Count - 1) return;

        var nextKey = keys[index + 1];
        var currentVal = config.Currencies[code];
        var nextVal = config.Currencies[nextKey];

        var newDict = new Dictionary<string, Currency>();
        foreach (var key in keys)
        {
            if (key == code) newDict[nextKey] = nextVal;
            else if (key == nextKey) newDict[code] = currentVal;
            else newDict[key] = config.Currencies[key];
        }
        config.Currencies = newDict;
        openMenuCurrencyCode = null;
    }

    private void ToggleCurrencyMenu(string code)
    {
        if (openMenuCurrencyCode == code) openMenuCurrencyCode = null;
        else openMenuCurrencyCode = code;
    }

    private void StartEditCurrency(string code, Currency c)
    {
        editingCurrencyCode = code;
        newCurrCode = code;
        newCurrSymbol = c.Symbol;
        newCurrDecimals = c.Decimals;
        newCurrQuota = c.ExpectedQuotaPerMember;
        openMenuCurrencyCode = null;
    }

    private void CancelCurrencyEdit()
    {
        editingCurrencyCode = null;
        newCurrCode = "";
        newCurrSymbol = "";
        newCurrDecimals = 2;
        newCurrQuota = 0;
    }

    private async Task ConfirmDeleteCurrency(string code)
    {
        openMenuCurrencyCode = null;
        bool confirm = await Alerts.ConfirmAsync(
            "Elimina Valuta",
            $"Sei sicuro di voler eliminare la cassa in {code}? Tutte le transazioni in questa valuta potrebbero non essere più visualizzate correttamente.",
            "Elimina",
            "Annulla");

        if (confirm)
        {
            RemoveCurrency(code);
        }
    }

    private string FormatCurrency(decimal amount, string currencyCode)
    {
        if (config != null && config.Currencies.TryGetValue(currencyCode, out var c))
        {
            string format = c.Decimals > 0 ? "N" + c.Decimals : "N0";
            return $"{c.Symbol} {amount.ToString(format)}";
        }
        return $"{amount:N2} {currencyCode}";
    }

    private string FormatDate(DateTime date)
    {
        return date.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("it-IT"));
    }

    private async Task HandleSave()
    {
        if (config == null) return;
        if (string.IsNullOrWhiteSpace(config.Name)) { error = "Il nome è obbligatorio."; return; }
        if (config.Currencies.Count == 0) { error = "Aggiungi almeno una valuta."; return; }

        var settings = await Storage.GetAppSettingsAsync();
        await Storage.SaveTripConfigAsync(tripSlug, config, settings?.DeviceId ?? "unknown");
        Nav.NavigateTo($"/trip/{tripSlug}");
    }

    private async Task HandleDelete()
    {
        bool confirm = await Alerts.ConfirmAsync(
            "Elimina Viaggio",
            "Sei sicuro di voler eliminare questo viaggio dal dispositivo?",
            "Elimina",
            "Annulla");

        if (confirm)
        {
            await Storage.DeleteTripAsync(tripSlug);
            Nav.NavigateTo("/");
        }
    }
}

