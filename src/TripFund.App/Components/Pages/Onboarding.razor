@page "/onboarding"

<div class="app-page onboarding-page">
    <header class="app-header header-no-border">
        <h1 class="brand-name">TripFund</h1>
    </header>

    <div class="onboarding-content">
        <div class="icon-container">
            <img src="images/tripfund.svg" class="app-logo-onboarding" alt="TripFund Logo" />
        </div>

        <div class="welcome-text">
            <h2 class="main-title">Welcome on board</h2>
            <p class="subtitle">Configura il tuo profilo per iniziare</p>
        </div>

        <div class="card-vibe text-left">
            <div class="form-group-vibe mb-4">
                <label for="authorName" class="form-label-vibe">Nome Autore</label>
                <input type="text" id="authorName" class="form-control-vibe" 
                       @bind="authorName" @bind:event="oninput" @onblur="TrimAuthorName" />
            </div>

            <div class="form-group-vibe mb-2">
                <label class="form-label-vibe">Device ID</label>
                <div class="input-with-icon">
                    <input type="text" class="form-control-vibe readonly-input" 
                           value="@DeviceId" readonly />
                    <span class="lock-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </span>
                </div>
            </div>
            <p class="help-text">Identificativo univoco del dispositivo per il versionamento.</p>
            
        </div>
        
        <button class="btn-vibe btn-primary-vibe mt-4" 
                disabled="@(string.IsNullOrWhiteSpace(authorName))"
                @onclick="SaveSettings">
            Inizia
        </button>
    </div>
</div>

<style>
    .onboarding-page {
        align-items: center;
        padding: 1.5rem;
    }

    .header-no-border {
        border-bottom: none;
        background-color: transparent;
        margin-bottom: 2rem;
    }

    .brand-name {
        color: #20563C;
        font-weight: 700;
        font-size: 1.5rem;
        margin: 0;
        width: 100%;
        text-align: center;
    }

    .onboarding-content {
        flex: 1;
        width: 100%;
        max-width: 400px;
        text-align: center;
    }

    .icon-container {
        display: flex;
        justify-content: center;
        margin-bottom: 1.5rem;
    }

    .app-logo-onboarding {
        width: 100px;
        height: 100px;
        filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.1));
    }

    .welcome-text {
        margin-bottom: 2rem;
    }

    .main-title {
        font-weight: 700;
        font-size: 1.8rem;
        color: #212529;
        margin-bottom: 0.5rem;
    }

    .subtitle {
        color: #6C757D;
        font-size: 1rem;
    }

    .text-left { text-align: left; }

    .readonly-input {
        background-color: #FFFFFF !important;
        color: #ADB5BD;
    }

    .input-with-icon {
        position: relative;
    }

    .lock-icon {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #ADB5BD;
    }

    .help-text {
        font-size: 0.75rem;
        color: #6C757D;
        margin-top: 0.5rem;
    }

    .arrow-icon {
        display: flex;
        align-items: center;
    }

    .ms-2 { margin-left: 0.5rem; }
    .mt-4 { margin-top: 1.5rem; }
    .mb-2 { margin-bottom: 0.5rem; }
    .mb-4 { margin-bottom: 1.5rem; }
</style>
