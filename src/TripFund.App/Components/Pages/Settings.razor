@page "/settings"
@using TripFund.App.Models
@using TripFund.App.Services
@using TripFund.App.Utilities
@inject LocalTripStorageService Storage
@inject NavigationManager Nav

<div class="settings-page">
    <header class="app-header">
        <button class="back-btn" @onclick='() => Nav.NavigateTo("/")'>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </button>
        <h1 class="header-title">Impostazioni</h1>
        <div style="width: 40px;"></div> <!-- Spacer to center title -->
    </header>

    <main class="content">
        <div class="form-card">
            <div class="form-group mb-4">
                <label class="form-label">NOME AUTORE</label>
                <div class="input-wrapper">
                    <input type="text" class="form-control custom-input" 
                           @bind="authorName" @bind:event="oninput" 
                           placeholder="Marco Rossi" />
                    <span class="input-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                        </svg>
                    </span>
                </div>
                <p class="help-text">Questo nome apparirà nei tuoi documenti ufficiali.</p>
            </div>

            <div class="form-group">
                <label class="form-label">DEVICE ID</label>
                <div class="input-wrapper">
                    <input type="text" class="form-control custom-input readonly-input" 
                           value="@DisplayDeviceId" readonly />
                    <span class="input-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </span>
                </div>
                <p class="help-text">L'identificativo univoco del dispositivo non può essere modificato.</p>
            </div>
        </div>
    </main>

    <footer class="footer">
        <button class="btn-submit" disabled="@(string.IsNullOrWhiteSpace(authorName))" @onclick="SaveSettings">Salva</button>
    </footer>
</div>

@code {
    private string authorName = string.Empty;
    private string? deviceId = null;

    private string DisplayDeviceId => deviceId ?? (string.IsNullOrEmpty(authorName) ? "mario-rossi-abcd1234" : $"{SlugUtility.GenerateSlug(authorName).Trim('-')}-xxxxxxxx".Trim('-'));

    protected override async Task OnInitializedAsync()
    {
        var settings = await Storage.GetAppSettingsAsync();
        if (settings != null)
        {
            authorName = settings.AuthorName;
            deviceId = settings.DeviceId;
        }
    }

    private async Task SaveSettings()
    {
        if (string.IsNullOrWhiteSpace(authorName)) return;

        // If for some reason it's missing (should not happen after onboarding),
        // we generate a fallback but we never overwrite an existing one.
        var finalDeviceId = deviceId ?? $"{SlugUtility.GenerateSlug(authorName).Trim('-')}-{Guid.NewGuid().ToString("n").Substring(0, 8)}".Trim('-');

        var settings = new AppSettings
        {
            AuthorName = authorName,
            DeviceId = finalDeviceId
        };

        await Storage.SaveAppSettingsAsync(settings);
        deviceId = finalDeviceId;
        Nav.NavigateTo("/");
    }
}

<style>
    .settings-page {
        background-color: #F8FBF9;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        margin: -1.5rem;
    }

    .app-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background-color: #FFFFFF;
        border-bottom: 1px solid #F0F0F0;
    }

    .header-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1A3C2F;
        margin: 0;
    }

    .back-btn, .menu-btn {
        background: none;
        border: none;
        color: #1A3C2F;
        padding: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .content {
        flex: 1;
        padding: 2rem 1.5rem;
    }

    .hero-section {
        margin-bottom: 2.5rem;
    }

    .main-title {
        font-size: 2rem;
        font-weight: 700;
        color: #1A3C2F;
        margin-bottom: 0.5rem;
    }

    .subtitle {
        font-size: 1rem;
        color: #6C757D;
        line-height: 1.4;
    }

    .form-card {
        background-color: #FFFFFF;
        border-radius: 28px;
        padding: 2rem;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
    }

    .form-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 700;
        color: #6C757D;
        letter-spacing: 0.05em;
        margin-bottom: 0.75rem;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .custom-input {
        background-color: #F8F9FA;
        border: none;
        border-radius: 16px;
        padding: 1.1rem 1.25rem;
        padding-right: 3rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: #1A3C2F;
        width: 100%;
    }

    .custom-input:focus {
        background-color: #F1F3F5;
        outline: none;
        box-shadow: none;
    }

    .readonly-input {
        background-color: #F1F3F5;
        color: #ADB5BD;
        cursor: not-allowed;
    }

    .input-icon {
        position: absolute;
        right: 1.25rem;
        color: #20563C;
        display: flex;
    }

    .readonly-input + .input-icon {
        color: #ADB5BD;
    }

    .help-text {
        font-size: 0.85rem;
        color: #6C757D;
        margin-top: 0.75rem;
        font-style: italic;
    }

    .footer {
        padding: 1.5rem;
        background-color: #F8FBF9;
    }

    .btn-submit {
        background-color: #20563C;
        color: #FFFFFF;
        border: none;
        border-radius: 20px;
        width: 100%;
        padding: 1.25rem;
        font-size: 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        box-shadow: 0 8px 24px rgba(32, 86, 60, 0.2);
        transition: opacity 0.2s;
    }

    .btn-submit:disabled {
        opacity: 0.6;
        box-shadow: none;
    }

    .check-icon {
        display: flex;
    }
</style>
