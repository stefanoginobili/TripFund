@page "/trip/{tripSlug}/transaction/{transactionId}"

<div class="app-page">
    <header class="app-header">
        <button class="icon-btn" @onclick='() => Nav.NavigateTo($"/trip/{tripSlug}?currency={currency}")'>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </button>
        <h1 class="header-title">@(config?.Name ?? "Dettaglio Transazione")</h1>
        <div class="header-actions">
            <div class="dropdown">
                <button class="icon-btn" @onclick="ToggleMenu">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="1"></circle>
                        <circle cx="12" cy="5" r="1"></circle>
                        <circle cx="12" cy="19" r="1"></circle>
                    </svg>
                </button>
                @if (isMenuOpen)
                {
                    <div class="popover-overlay" @onclick="ToggleMenu"></div>
                    <div class="dropdown-menu-vibe">
                        <button class="dropdown-item-vibe" @onclick="EditTransaction" disabled="@(!canEdit)">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                            </svg>
                            Modifica @(transaction?.Type == "expense" ? "Spesa" : "Versamento")
                        </button>
                    </div>
                }
            </div>
        </div>
    </header>

    @if (transaction == null || config == null)
    {
        <LoadingSpinner />
    }

    else
    {
        <div class="content">
            <div class="transaction-summary-card">
                <div class="transaction-icon round @(transaction.Type == "expense" ? "expense-icon" : "contrib-icon")">
                    @if(transaction.Type == "expense")
                    {
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"></polyline><polyline points="17 18 23 18 23 12"></polyline></svg>
                    }
                    else
                    {
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                    }
                </div>
                <h2 class="amount-title @(transaction.Type == "expense" ? "text-danger" : "text-success")">
                    @FormatAmountWithCode(transaction.Amount, transaction.Currency)
                </h2>
                <p class="transaction-desc">@(string.IsNullOrWhiteSpace(transaction.Description) ? (transaction.Type == "expense" ? "Spesa" : "Versamento") : transaction.Description)</p>
                <p class="transaction-meta">@GetDisplayDate(transaction)</p>
                <p class="transaction-meta tz-name">orario di @GetTimeZoneDisplayName(transaction)</p>
                <p class="transaction-meta author-line">Registrato da @transaction.Author</p>
            </div>

            <div class="info-section">
                <h3 class="section-header-vibe">Partecipanti</h3>
                <div class="split-list">
                    @foreach (var split in transaction.Split)
                    {
                        var isMissing = !config.Members.ContainsKey(split.Key);
                        var memberName = !isMissing ? config.Members[split.Key].Name : split.Key;
                        var memberAvatar = !isMissing ? config.Members[split.Key].Avatar : "❓";

                        <div class="split-row @(isMissing ? "missing-member" : "")">
                            <div class="member-avatar">@memberAvatar</div>
                            <div class="member-name">@memberName</div>
                            <div class="split-amount">@FormatCurrency(split.Value.Amount, transaction.Currency)</div>
                        </div>
                    }
                </div>
            </div>

            @if (previews.Any())
            {
                <div class="info-section">
                    <h3 class="section-header-vibe">Allegati</h3>
                    <div class="attachments-grid">
                        @foreach (var preview in previews)
                        {
                            <div class="attachment-preview-wrapper" @onclick="() => OpenAttachment(preview.FileName)">
                                <div class="attachment-square">
                                    @if (preview.IsImage && !string.IsNullOrEmpty(preview.PreviewUrl))
                                    {
                                        <img src="@preview.PreviewUrl" alt="@preview.FileName" />
                                    }
                                    else
                                    {
                                        <div class="file-icon-placeholder">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
                                                <polyline points="13 2 13 9 20 9"></polyline>
                                            </svg>
                                            <span class="file-ext">@(Path.GetExtension(preview.FileName).TrimStart('.').ToUpper())</span>
                                        </div>
                                    }
                                </div>
                                <div class="attachment-name">@preview.DisplayTimestamp</div>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (transaction.Location != null)
            {
                <div class="info-section">
                    <h3 class="section-header-vibe">Luogo</h3>
                    <div class="info-card clickable" @onclick="OpenMap">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 text-muted">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                            <circle cx="12" cy="10" r="3"></circle>
                        </svg>
                        <div class="location-text">
                            <div class="location-name">@(string.IsNullOrWhiteSpace(transaction.Location.Name) ? "Posizione" : transaction.Location.Name)</div>
                            <div class="location-coords">@transaction.Location.Latitude.ToString("F6"), @transaction.Location.Longitude.ToString("F6")</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .me-2 { margin-right: 0.5rem; }

    .content {
        flex: 1;
        padding: 2rem 1.5rem;
    }

    .transaction-summary-card {
        background-color: #FFFFFF;
        border-radius: 24px;
        padding: 2rem 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        margin-bottom: 2rem;
    }

    .transaction-icon {
        width: 64px;
        height: 64px;
        margin-bottom: 1rem;
    }

    .amount-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .transaction-desc {
        font-size: 1.1rem;
        font-weight: 600;
        color: #1A3C2F;
        margin-bottom: 0.25rem;
        text-align: center;
    }

    .transaction-meta {
        font-size: 0.9rem;
        color: #6C757D;
        margin: 0;
    }

    .tz-name {
        font-size: 0.8rem;
        opacity: 0.8;
    }

    .author-line {
        margin-top: 0.5rem !important;
    }

    .split-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .split-row {
        background-color: #FFFFFF;
        padding: 1rem;
        border-radius: 16px;
        display: flex;
        align-items: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    }

    .split-row.missing-member {
        filter: grayscale(100%);
        opacity: 0.7;
    }

    .member-avatar {
        font-size: 1.5rem;
        margin-right: 1rem;
        width: 40px;
        height: 40px;
        background-color: #F8FBF9;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .member-name {
        flex: 1;
        font-weight: 600;
        color: #1A3C2F;
    }

    .split-amount {
        font-weight: 700;
        color: #1A3C2F;
    }

    .info-card {
        background-color: #FFFFFF;
        padding: 1rem;
        border-radius: 16px;
        display: flex;
        align-items: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
        font-weight: 500;
        color: #1A3C2F;
    }

    .info-card.clickable {
        cursor: pointer;
    }

    .info-card.clickable:active {
        background-color: #F8FBF9;
    }

    .location-text {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .location-name {
        font-weight: 600;
        color: #1A3C2F;
    }

    .location-coords {
        font-size: 0.75rem;
        color: #6C757D;
    }

    .attachments-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    .attachment-preview-wrapper {
        display: flex;
        flex-direction: column;
        gap: 6px;
        cursor: pointer;
    }

    .attachment-square {
        aspect-ratio: 1 / 1;
        width: 100%;
        background-color: #FFFFFF;
        border: 1px solid #E0E0E0;
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    }

    .attachment-square img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .file-icon-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        color: #6C757D;
    }

    .file-ext {
        font-size: 0.6rem;
        font-weight: 800;
        margin-top: 2px;
    }

    .attachment-name {
        font-size: 0.7rem;
        color: #6C757D;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        text-align: center;
    }
</style>
