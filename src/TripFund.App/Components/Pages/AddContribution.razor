@page "/trip/{tripSlug}/add-contribution"

<div class="app-page">
    <header class="app-header">
        <button class="icon-btn" @onclick="GoBack">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </button>
        <h1 class="header-title">@(config?.Name ?? "...")</h1>
        <div class="header-actions">
            @if (editingTransaction != null)
            {
                <div class="dropdown">
                    <button class="icon-btn" @onclick="ToggleMenu">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="1"></circle>
                            <circle cx="12" cy="5" r="1"></circle>
                            <circle cx="12" cy="19" r="1"></circle>
                        </svg>
                    </button>
                    @if (isMenuOpen)
                    {
                        <div class="popover-overlay" @onclick="ToggleMenu"></div>
                        <div class="dropdown-menu-vibe">
                            <button class="dropdown-item-vibe text-danger" @onclick="DeleteTransaction">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                    <polyline points="3 6 5 6 21 6"></polyline>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                </svg>
                                Elimina Versamento
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    </header>

    @if (config == null)
    {
        <LoadingSpinner />
    }
    else
    {
        <div class="content">
            @if (config.Currencies.Count > 1)
            {
                <CurrencySelector Currencies="@(new[] { selectedCurrency })" SelectedCurrency="@selectedCurrency" OnCurrencySelected="SelectCurrency" />
            }
            <div class="form-container-vibe">
                <div class="amount-tile amount-tile-contribution">
                    <div class="tile-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                            <polyline points="17 6 23 6 23 12"></polyline>
                        </svg>
                    </div>
                    <label class="tile-label">Importo Versamento</label>
                    <div class="amount-section">
                        <span class="currency-symbol">@GetCurrencySymbol()</span>
                        <input type="text" inputmode="@(GetDecimals() > 0 ? "decimal" : "numeric")" class="amount-input" value="@amount.ToString("F" + GetDecimals())" @onchange="OnAmountChanged" onfocus="headerLogic.selectText(this)" placeholder="@(GetDecimals() > 0 ? "0," + new string('0', GetDecimals()) : "0")" />
                    </div>
                </div>

                <div class="form-group-vibe">
                    <label class="form-label-vibe">Descrizione</label>
                    <input type="text" class="form-control-vibe" @bind="description" @onblur="TrimDescription" placeholder="es. Versamento iniziale" />
                </div>

                <div class="datetime-row">
                    <NativeDatePicker Label="Data" @bind-Value="transactionDate" Class="flex-1" />
                    <NativeTimePicker Label="Ora" @bind-Value="transactionDate" Class="flex-1" />
                </div>

                <TimeZoneSelector Label="Fuso Orario" @bind-Value="timezoneId" />

                <div class="form-group-vibe">
                    <label class="form-label-vibe">Partecipante</label>
                    <div class="custom-member-selector @(isMemberSelectorOpen ? "open" : "")" @onclick="ToggleMemberSelector">
                        @if (string.IsNullOrEmpty(selectedMemberSlug))
                        {
                            <div class="selected-member-placeholder">Seleziona...</div>
                        }
                        else if (config.Members.TryGetValue(selectedMemberSlug, out var m))
                        {
                            <div class="member-selector-item">
                                <div class="member-avatar-circle" style="background-color: #D6EDE2; color: #20563C;">
                                    @if (m.Avatar.Length > 2) { <span>@m.Avatar</span> } else { <span class="emoji">@m.Avatar</span> }
                                </div>
                                <div class="member-selector-info">
                                    <div class="member-selector-name">@m.Name</div>
                                    <div class="member-selector-total">Quota versata: @GetCurrencySymbol() @GetMemberTotal(selectedMemberSlug).ToString("N" + GetDecimals())</div>
                                </div>
                                <div class="selector-arrow">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="7 9 12 4 17 9"></polyline>
                                        <polyline points="7 15 12 20 17 15"></polyline>
                                    </svg>
                                </div>
                            </div>
                        }

                        @if (isMemberSelectorOpen)
                        {
                            <div class="member-selector-dropdown" @onclick:stopPropagation>
                                @foreach (var member in config.Members)
                                {
                                    bool isSelected = selectedMemberSlug == member.Key;
                                    <div id="@(isSelected ? "selected-member-item" : null)" 
                                         class="dropdown-member-item @(isSelected ? "selected" : "")" 
                                         @onclick="() => SelectMember(member.Key)">
                                        <div class="member-avatar-circle small">
                                            @member.Value.Avatar
                                        </div>
                                        <div class="member-selector-info">
                                            <div class="member-selector-name">@member.Value.Name</div>
                                            <div class="member-selector-total">Quota versata: @GetCurrencySymbol() @GetMemberTotal(member.Key).ToString("N" + GetDecimals())</div>
                                        </div>
                                        @if (isSelected)
                                        {
                                            <div class="check-icon">
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#20563C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                                    <polyline points="20 6 9 17 4 12"></polyline>
                                                </svg>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                @if (isMemberSelectorOpen)
                {
                    <div class="popover-overlay" @onclick="ToggleMemberSelector"></div>
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <p class="text-danger fw-bold" style="text-align: center;">@errorMessage</p>
                }

                <button class="btn-primary-vibe mt-2 mb-4" @onclick="HandleSubmit" disabled="@(isSubmitting || !HasChanges())">
                    @(isSubmitting ? "Salvataggio..." : "Salva")
                </button>
            </div>
        </div>
    }
</div>

<style>
    .datetime-row { display: flex; gap: 1rem; }

    .custom-member-selector {
        position: relative;
        background-color: #FFFFFF;
        border-radius: 16px;
        padding: 0.75rem 1rem;
        border: 1px solid #E0E0E0;
        cursor: pointer;
        min-height: 72px;
        display: flex;
        align-items: center;
        transition: all 0.2s;
    }

    .custom-member-selector.open {
        border-color: #20563C;
        z-index: 1201;
    }

    .selected-member-placeholder {
        color: #6C757D;
        font-weight: 600;
    }

    .member-selector-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        width: 100%;
    }

    .member-avatar-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .member-avatar-circle.small {
        width: 36px;
        height: 36px;
        font-size: 1.1rem;
        background-color: #F1F3F5;
    }

    .member-selector-info {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .member-selector-name {
        font-weight: 800;
        color: #1A3C2F;
        font-size: 1.1rem;
    }

    .member-selector-total {
        font-size: 0.85rem;
        color: #6C757D;
        font-weight: 600;
    }

    .selector-arrow {
        color: #6C757D;
    }

    .member-selector-dropdown {
        position: absolute;
        bottom: calc(100% + 8px);
        left: 0;
        right: 0;
        background-color: #FFFFFF;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.12);
        z-index: 1202;
        max-height: 300px;
        overflow-y: auto;
        padding: 0.5rem;
        border: 1px solid #F0F0F0;
    }

    .dropdown-member-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        border-radius: 12px;
        transition: background-color 0.2s;
    }

    .dropdown-member-item:hover {
        background-color: #F8FBF9;
    }

    .dropdown-member-item.selected {
        background-color: #D6EDE2;
    }

    .check-icon {
        margin-left: auto;
    }

    .mt-2 { margin-top: 0.5rem; }
    .mb-4 { margin-bottom: 2rem; }
    .me-2 { margin-right: 0.5rem; }
</style>
