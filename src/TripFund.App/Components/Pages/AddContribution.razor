        text-align: center;
        outline: none;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-group label {
        font-size: 0.75rem;
        font-weight: 800;
        color: #1A3C2F;
        letter-spacing: 0.05em;
