@page "/trip/{tripSlug}/add-contribution"
@using TripFund.App.Models
@using TripFund.App.Services
@using TripFund.App.Utilities
@inject LocalTripStorageService Storage
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<div class="add-transaction-page">
    <header class="app-header">
        <button class="icon-btn" @onclick="GoBack">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </button>
        <h1 class="header-title">Registra Versamento</h1>
        <div class="spacer"></div>
    </header>

    @if (config == null)
    {
        <p class="status-text">Caricamento...</p>
    }
    else
    {
        <CurrencySelector Currencies="config.Currencies.Keys" SelectedCurrency="@selectedCurrency" OnCurrencySelected="SelectCurrency" />

        <main class="content">
            <div class="form-container">
                <div class="amount-section">
                    <span class="currency-symbol">@GetCurrencySymbol()</span>
                    <input type="text" inputmode="@(GetDecimals() > 0 ? "decimal" : "numeric")" class="amount-input" value="@amount.ToString("F" + GetDecimals(), System.Globalization.CultureInfo.InvariantCulture)" @onchange="OnAmountChanged" onfocus="headerLogic.selectText(this)" placeholder="@(GetDecimals() > 0 ? "0." + new string('0', GetDecimals()) : "0")" />
                </div>

                <div class="datetime-row">
                    <div class="form-group flex-1">
                        <label>Data</label>
                        <div class="datetime-picker-box">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#20563C" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                            <span class="datetime-value">@GetFormattedDate()</span>
                            <input type="date" class="hidden-picker" value="@transactionDate.ToString("yyyy-MM-dd")" @onchange="OnDateChanged" />
                        </div>
                    </div>
                    <div class="form-group flex-1">
                        <label>Ora</label>
                        <div class="datetime-picker-box">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#20563C" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                            <span class="datetime-value">@transactionDate.ToString("HH:mm")</span>
                            <input type="time" class="hidden-picker" value="@transactionDate.ToString("HH:mm")" @onchange="OnTimeChanged" />
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Partecipante</label>
                    <div class="custom-member-selector @(isMemberSelectorOpen ? "open" : "")" @onclick="ToggleMemberSelector">
                        @if (string.IsNullOrEmpty(selectedMemberSlug))
                        {
                            <div class="selected-member-placeholder">Seleziona membro...</div>
                        }
                        else if (config.Members.TryGetValue(selectedMemberSlug, out var m))
                        {
                            <div class="member-selector-item">
                                <div class="member-avatar-circle" style="background-color: #D6EDE2; color: #20563C;">
                                    @if (m.Avatar.Length > 2) { <span>@m.Avatar</span> } else { <span class="emoji">@m.Avatar</span> }
                                </div>
                                <div class="member-selector-info">
                                    <div class="member-selector-name">@m.Name</div>
                                    <div class="member-selector-total">Versati: @GetCurrencySymbol() @GetMemberTotal(selectedMemberSlug).ToString("N" + GetDecimals())</div>
                                </div>
                                <div class="selector-arrow">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="7 15 12 10 17 15"></polyline>
                                        <polyline points="7 9 12 4 17 9"></polyline>
                                    </svg>
                                </div>
                            </div>
                        }

                        @if (isMemberSelectorOpen)
                        {
                            <div class="member-selector-dropdown" @onclick:stopPropagation>
                                @foreach (var member in config.Members)
                                {
                                    <div class="dropdown-member-item @(selectedMemberSlug == member.Key ? "selected" : "")" @onclick="() => SelectMember(member.Key)">
                                        <div class="member-avatar-circle small">
                                            @member.Value.Avatar
                                        </div>
                                        <div class="member-selector-info">
                                            <div class="member-selector-name">@member.Value.Name</div>
                                            <div class="member-selector-total">Versati: @GetCurrencySymbol() @GetMemberTotal(member.Key).ToString("N" + GetDecimals())</div>
                                        </div>
                                        @if (selectedMemberSlug == member.Key)
                                        {
                                            <div class="check-icon">
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#20563C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                                    <polyline points="20 6 9 17 4 12"></polyline>
                                                </svg>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                @if (isMemberSelectorOpen)
                {
                    <div class="popover-overlay" @onclick="ToggleMemberSelector"></div>
                }

                <div class="form-group switch-group">
                    <label>Invia ricevuta via email</label>
                    <div class="switch @(sendReceipt ? "on" : "off")" @onclick="() => sendReceipt = !sendReceipt">
                        <div class="switch-handle"></div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <p class="error-message">@errorMessage</p>
                }

                <button class="submit-btn" @onclick="HandleSubmit" disabled="@isSubmitting">
                    @(isSubmitting ? "Salvataggio..." : "Salva")
                </button>
            </div>
        </main>
    }
</div>

@code {
    [Parameter] public string tripSlug { get; set; } = "";
    
    [SupplyParameterFromQuery] public string? member { get; set; }
    [SupplyParameterFromQuery] public string? currency { get; set; }
    [SupplyParameterFromQuery] public string? edit { get; set; }

    private TripConfig? config;
    private Transaction? editingTransaction;
    private List<Transaction> allTransactions = new();
    private string selectedCurrency = "";
    private string selectedMemberSlug = "";
    private decimal amount;
    private DateTime transactionDate = DateTime.Now;
    private bool sendReceipt = false;
    private string errorMessage = "";
    private string deviceId = "";
    private string authorName = "";
    private bool isSubmitting = false;
    private bool isMemberSelectorOpen = false;

    protected override async Task OnInitializedAsync()
    {
        config = await Storage.GetTripConfigAsync(tripSlug);
        allTransactions = await Storage.GetTransactionsAsync(tripSlug);
        var settings = await Storage.GetAppSettingsAsync();
        deviceId = settings?.DeviceId ?? "unknown";
        authorName = settings?.AuthorName ?? "Unknown";

        if (config != null)
        {
            if (!string.IsNullOrEmpty(edit))
            {
                editingTransaction = await Storage.GetLatestTransactionVersionAsync(tripSlug, edit);
                if (editingTransaction != null && editingTransaction.Type == "contribution")
                {
                    selectedCurrency = editingTransaction.Currency;
                    amount = editingTransaction.Amount;
                    transactionDate = editingTransaction.Date.ToLocalTime();
                    selectedMemberSlug = editingTransaction.Split.Keys.FirstOrDefault() ?? "";
                }
            }

            if (editingTransaction == null)
            {
                amount = 0;
                if (!string.IsNullOrEmpty(currency) && config.Currencies.ContainsKey(currency))
                {
                    selectedCurrency = currency;
                }
                else if (config.Currencies.Any())
                {
                    selectedCurrency = config.Currencies.Keys.First();
                }

                if (!string.IsNullOrEmpty(member) && config.Members.ContainsKey(member))
                {
                    selectedMemberSlug = member;
                }
            }
        }
    }

    private void ToggleMemberSelector() => isMemberSelectorOpen = !isMemberSelectorOpen;

    private void SelectMember(string slug)
    {
        selectedMemberSlug = slug;
        isMemberSelectorOpen = false;
    }

    private decimal GetMemberTotal(string slug)
    {
        if (allTransactions == null) return 0;
        return allTransactions
            .Where(t => t.Type == "contribution" && t.Currency == selectedCurrency && t.Split != null && t.Split.ContainsKey(slug))
            .Sum(t => t.Amount);
    }

    private void SelectCurrency(string currencyCode)
    {
        if (editingTransaction == null) selectedCurrency = currencyCode;
    }

    private async Task GoBack()
    {
        await JSRuntime.InvokeVoidAsync("history.back");
    }

    private string GetFormattedDate()
    {
        var today = DateTime.Today;
        if (transactionDate.Date == today) return "Oggi";
        if (transactionDate.Date == today.AddDays(-1)) return "Ieri";
        return transactionDate.ToString("dd/MM/yyyy");
    }

    private void OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            transactionDate = new DateTime(date.Year, date.Month, date.Day, transactionDate.Hour, transactionDate.Minute, 0);
        }
    }

    private void OnTimeChanged(ChangeEventArgs e)
    {
        if (TimeSpan.TryParse(e.Value?.ToString(), out var time))
        {
            transactionDate = transactionDate.Date.Add(time);
        }
    }

    private void OnAmountChanged(ChangeEventArgs e)
    {
        var input = e.Value?.ToString()?.Replace(",", ".");
        if (decimal.TryParse(input, System.Globalization.CultureInfo.InvariantCulture, out decimal val))
        {
            amount = Math.Round(val, GetDecimals());
        }
    }

    private string GetCurrencySymbol()
    {
        if (config != null && config.Currencies.TryGetValue(selectedCurrency, out var c))
        {
            return c.Symbol;
        }
        return "";
    }

    private int GetDecimals()
    {
        if (config != null && config.Currencies.TryGetValue(selectedCurrency, out var c))
        {
            return c.Decimals;
        }
        return 2;
    }

    private string GetStep()
    {
        int decimals = GetDecimals();
        if (decimals <= 0) return "1";
        return (1 / Math.Pow(10, decimals)).ToString(System.Globalization.CultureInfo.InvariantCulture);
    }

    private async Task HandleSubmit()
    {
        errorMessage = "";

        if (amount <= 0)
        {
            errorMessage = "Inserire un importo valido.";
            return;
        }

        if (string.IsNullOrEmpty(selectedMemberSlug))
        {
            errorMessage = "Selezionare un membro.";
            return;
        }

        isSubmitting = true;

        var transaction = new Transaction
        {
            Id = editingTransaction?.Id ?? TransactionIdGenerator.GenerateId(),
            Type = "contribution",
            Date = transactionDate.ToUniversalTime(),
            Currency = selectedCurrency,
            Amount = amount,
            Description = "Versamento in cassa",
            Author = authorName,
            Split = new Dictionary<string, SplitInfo> { { selectedMemberSlug, new SplitInfo { Amount = amount, Manual = true } } }
        };

        try
        {
            await Storage.SaveTransactionAsync(tripSlug, transaction, deviceId);
            
            // TODO: Invia ricevuta via email se sendReceipt è true (Task 10)
            
            await GoBack();
        }
        catch (Exception ex)
        {
            errorMessage = "Errore durante il salvataggio: " + ex.Message;
            isSubmitting = false;
        }
    }
}

<style>
